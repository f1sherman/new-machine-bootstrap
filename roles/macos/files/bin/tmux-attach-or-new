#!/bin/bash
# Attach to an existing unattached tmux session, or create a new one.
# Used as Ghostty's command so that restarting Ghostty reconnects to
# existing sessions instead of creating new empty ones each time.

if tmux list-sessions &>/dev/null; then
  session=$(tmux list-sessions -F '#{session_attached} #{session_name}' 2>/dev/null |
    awk '$1 == "0" {print substr($0, index($0,$2)); exit}')
  if [ -n "$session" ]; then
    exec /opt/homebrew/bin/tmux attach -t "=$session"
  fi
fi

exec /opt/homebrew/bin/tmux new-session

#!/bin/bash
set -euo pipefail

# Ghostty launches this via `bash --noprofile --norc`, so GUI startup may not
# include mise or Homebrew paths. Normalize PATH before running helpers or
# starting tmux so `env ruby` and other tool lookups hit managed installs first.
pathprepend() {
  local dir="${1%/}"
  [ -d "$dir" ] || return 0
  PATH=":$PATH:"
  PATH="${PATH//:$dir:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
  PATH="$dir:$PATH"
}

PATH="${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"
pathprepend "/usr/local/sbin"
pathprepend "/usr/local/bin"
pathprepend "/opt/homebrew/sbin"
pathprepend "/opt/homebrew/bin"
pathprepend "$HOME/.local/bin"
pathprepend "${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims"
export PATH

state_dir="$HOME/.local/state/terminal-restore"
manifest="$state_dir/ghostty-layout.last-good.json"
marker="$state_dir/reconcile.done"
reconcile_log="$state_dir/reconcile.log"

if [ "$(uname -s)" = "Darwin" ] && [ -f "$manifest" ]; then
  boot_epoch="$(sysctl -n kern.boottime | awk -F '[ ,}]+' '{print $4}')"
  marker_epoch="$(cat "$marker" 2>/dev/null || printf '0')"

  if [ "$marker_epoch" -lt "$boot_epoch" ] && \
    jq -e --argjson boot_epoch "$boot_epoch" \
      '(.saved_at | type) == "number" and .saved_at < $boot_epoch' \
      "$manifest" >/dev/null 2>&1
  then
    "$HOME/.local/bin/ghostty-layout-reconcile" >/dev/null 2>>"$reconcile_log" &
  fi
fi

exec "$HOME/.local/bin/tmux-restore-client"

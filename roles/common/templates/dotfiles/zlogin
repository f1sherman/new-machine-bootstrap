# Mise shims — lightweight alternative to `mise activate`. Shims are small
# binaries under $MISE_DATA_DIR/shims that dispatch to the right tool version
# based on the .tool-versions / mise.toml discovered at exec time. Unlike
# `mise activate`, this avoids a 300ms precmd hook on every prompt and the
# 500ms+ activate fork on every login shell.
#
# Trade-off: shims don't update PATH to include the tool's own bin dir on
# cd, so `python` → correct version via shim, but `which python` shows the
# shim path, not the real binary. Good enough for most flows.
_mise_shims="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims"
if [[ -d "$_mise_shims" ]]; then
  path=("$_mise_shims" $path)
fi
unset _mise_shims

# Update tmux window name on directory change and before each prompt
if [[ -n "$TMUX" ]]; then
  _tmux_window_name_update() {
    command tmux-session-name "$TMUX_PANE" &>/dev/null &!
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook chpwd _tmux_window_name_update
  add-zsh-hook precmd _tmux_window_name_update
fi

# Load any machine-specific customizations
if [ -f ~/.zshrc.local ]; then
  # shellcheck disable=SC1090
  . ~/.zshrc.local
fi

# Mise shims are set in .zshenv (applies to all shells), so nothing to do here.

# Compinit with daily cache regeneration. Prezto's completion module is
# disabled in .zpreztorc (for perf), so compinit has to run here. The full
# compaudit + compdump is slow (~800ms); `compinit -C` skips the security
# audit and reuses the existing dump. Full run happens at most once per 24h.
autoload -Uz compinit
if [[ -f ~/.zcompdump && -z ~/.zcompdump(#qNmh+24) ]]; then
  compinit -C
else
  compinit
fi

# Initialize zoxide (smarter cd with frecency-based directory jumping)
# --cmd cd replaces the cd builtin; cdi opens interactive fzf picker
# Must be initialized at the very end of ~/.zshrc (after compinit and any
# other tools that register chpwd hooks)
# Skip under Claude Code: its snapshot-replay shell can't restore
# chpwd_functions, so zoxide can't track visits and its doctor would
# false-positive on every cd.
if [[ -z "$CLAUDECODE" ]] && command -v zoxide > /dev/null; then
  # Cache the output of `zoxide init` to avoid forking zoxide on every shell.
  # Regenerate only when the zoxide binary is newer than the cache file.
  _zoxide_cache="${HOME}/.cache/zsh/zoxide-init.zsh"
  _zoxide_bin="$(command -v zoxide)"
  if [[ ! -f "$_zoxide_cache" || "$_zoxide_bin" -nt "$_zoxide_cache" ]]; then
    mkdir -p "${_zoxide_cache:h}"
    "$_zoxide_bin" init zsh --cmd cd > "$_zoxide_cache"
  fi
  source "$_zoxide_cache"
  unset _zoxide_cache _zoxide_bin
fi


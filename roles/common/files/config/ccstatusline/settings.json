{
  "version": 3,
  "lines": [
    [
      {
        "id": "1",
        "type": "custom-command",
        "color": "cyan",
        "commandPath": "jq -r '.model.id // .model // \"\" | gsub(\"^claude-\"; \"\") | gsub(\"-[0-9]{8}$\"; \"\") | gsub(\"(?<a>[a-z]+)-(?<v>[0-9]+)-(?<m>[0-9]+)\"; \"\\(.a)\\(.v).\\(.m)\")'"
      },
      {
        "id": "2",
        "type": "context-percentage-usable",
        "color": "brightBlack",
        "rawValue": true,
        "metadata": {
          "inverse": "true"
        }
      }
    ],
    [],
    []
  ],
  "flexMode": "full-minus-40",
  "compactThreshold": 60,
  "colorLevel": 2,
  "defaultPadding": " ",
  "inheritSeparatorColors": false,
  "globalBold": false,
  "powerline": {
    "enabled": true,
    "separators": [
      "\ue0b1"
    ],
    "separatorInvertBackground": [
      false
    ],
    "startCaps": [],
    "endCaps": [],
    "theme": "nord-aurora",
    "autoAlign": false
  }
}

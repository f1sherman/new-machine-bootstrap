#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

pane_id() {
  printf '%s\n' "${TMUX_PANE:-}"
}

state_file() {
  printf '%s/%s.%s\n' "$TMUX_AGENT_STATE_DIR" "$1" "$2"
}

set_pane_option() {
  local pane="$1" key="$2" value="$3"
  if [[ -n "${TMUX_AGENT_STATE_DIR:-}" ]]; then
    mkdir -p "$TMUX_AGENT_STATE_DIR"
    printf '%s' "$value" >"$(state_file "$pane" "$key")"
  else
    tmux set-option -pt "$pane" "$key" "$value" >/dev/null 2>&1 || true
  fi
}

clear_pane_option() {
  local pane="$1" key="$2"
  if [[ -n "${TMUX_AGENT_STATE_DIR:-}" ]]; then
    rm -f "$(state_file "$pane" "$key")"
  else
    tmux set-option -pt "$pane" -u "$key" >/dev/null 2>&1 || true
  fi
}

get_pane_option() {
  local pane="$1" key="$2"
  if [[ -n "${TMUX_AGENT_STATE_DIR:-}" ]]; then
    [[ -f "$(state_file "$pane" "$key")" ]] || return 1
    cat "$(state_file "$pane" "$key")"
  else
    tmux show-options -qv -p -t "$pane" "$key" 2>/dev/null
  fi
}

sanitize_subject() {
  printf '%s' "$*" \
    | tr '\r\n\t' '   ' \
    | tr -d '\000-\010\013\014\016-\037\177' \
    | sed -E 's/[[:space:]]+/ /g; s/^ //; s/ $//'
}

clear_obsolete_options() {
  local pane="$1" key
  for key in @agent_subject @agent_subject_stale @agent_subject_done @agent_completed_window_label; do
    clear_pane_option "$pane" "$key"
  done
}

set_task() {
  local pane="$1" label="$2" source="$3" state="$4"
  set_pane_option "$pane" @task_label "$label"
  set_pane_option "$pane" @task_source "$source"
  set_pane_option "$pane" @task_state "$state"
  clear_obsolete_options "$pane"
}

persistent_identity_source() {
  case "$1" in
    goal|manual) return 0 ;;
    *) return 1 ;;
  esac
}

clear_task_options() {
  local pane="$1"
  clear_pane_option "$pane" @task_label
  clear_pane_option "$pane" @task_source
  clear_pane_option "$pane" @task_state
  clear_pane_option "$pane" @task_context
  clear_obsolete_options "$pane"
}

clear_worktree_options() {
  local pane="$1"
  clear_pane_option "$pane" @agent_worktree_path
  clear_pane_option "$pane" @agent_worktree_pid
  clear_pane_option "$pane" @pane-link
  clear_pane_option "$pane" @pane-link-source
}

fallback_cwd_label() {
  local path label
  if [[ -n "${TMUX_AGENT_STATE_CURRENT_PATH:-}" ]]; then
    path="$TMUX_AGENT_STATE_CURRENT_PATH"
  else
    path="$(tmux display-message -p -t "$1" '#{pane_current_path}' 2>/dev/null || true)"
  fi
  label="${path%/}"
  label="${label##*/}"
  [[ -n "$label" ]] || label="/"
  printf '%s\n' "$label"
}

live_path_label() {
  local pane="$1" path label
  path="$(get_pane_option "$pane" @agent_worktree_path 2>/dev/null || true)"
  [[ -n "$path" && -x "${TMUX_AGENT_STATE_LABEL_FORMAT_BIN:-}" ]] || return 1
  label="$("${TMUX_AGENT_STATE_LABEL_FORMAT_BIN}" local "$path" 2>/dev/null || true)"
  [[ -n "$label" ]] || return 1
  printf '%s\n' "$label"
}

context_suffix() {
  local label="${1:-}" task_label="${2:-}" task_state="${3:-}" prefix
  label="${label#✓ }"
  prefix="~ $task_label · "
  if [[ -n "$task_label" && "$label" == "$prefix"* ]]; then
    label="${label#"$prefix"}"
  elif [[ -z "$task_label" && "$label" == "~ "*" · "* ]]; then
    label="${label##* · }"
  elif [[ "$label" =~ ^\((.*)\)\ (.+)$ ]]; then
    label="${BASH_REMATCH[2]}"
  fi
  printf '%s\n' "$label"
}

truncate_top_label() {
  local helper
  helper="${TMUX_TASK_LABEL_BIN:-$script_dir/tmux-task-label}"
  [[ -x "$helper" ]] || helper="${HOME:-}/.local/bin/tmux-task-label"
  "$helper" truncate "$1"
}

render() {
  local pane="$1" task_label task_state task_context structured existing live structured_context context pane_label window_label
  task_label="$(get_pane_option "$pane" @task_label 2>/dev/null || true)"
  task_state="$(get_pane_option "$pane" @task_state 2>/dev/null || true)"
  task_context="$(get_pane_option "$pane" @task_context 2>/dev/null || true)"
  structured="$(get_pane_option "$pane" @pane-title-structured 2>/dev/null || true)"
  existing="$(get_pane_option "$pane" @pane-label 2>/dev/null || true)"
  live="$(live_path_label "$pane" 2>/dev/null || true)"
  structured_context=""
  if [[ -n "$task_label" && -n "$structured" && "$existing" == *" | "* ]]; then
    case "$existing" in
      "~ $task_label · "*|"($task_label) "*|"✓ ($task_label) "*)
        structured_context="$(context_suffix "$existing" "$task_label" "$task_state")"
        ;;
    esac
  fi

  if [[ -n "$live" ]]; then
    context="$(context_suffix "$live" "$task_label" "$task_state")"
    [[ -z "$task_label" ]] || set_pane_option "$pane" @task_context "$context"
  elif [[ -n "$structured_context" ]]; then
    context="$structured_context"
    set_pane_option "$pane" @task_context "$context"
  elif [[ -n "$task_label" && -n "$task_context" ]]; then
    context="$task_context"
  elif [[ -n "$existing" ]]; then
    context="$(context_suffix "$existing" "$task_label" "$task_state")"
    [[ -z "$task_label" ]] || set_pane_option "$pane" @task_context "$context"
  else
    context="$(fallback_cwd_label "$pane")"
    [[ -z "$task_label" ]] || set_pane_option "$pane" @task_context "$context"
  fi

  if [[ -n "$task_label" && "$task_state" == "provisional" ]]; then
    window_label="~ $task_label"
    pane_label="~ $task_label · $context"
  elif [[ -n "$task_label" && "$task_state" == "active" ]]; then
    window_label="$task_label"
    if [[ -n "$live" ]]; then
      pane_label="$live"
    else
      pane_label="($task_label) $context"
    fi
  elif [[ -n "$task_label" && "$task_state" == "completed" ]]; then
    window_label="✓ $task_label"
    pane_label="✓ ($task_label) $context"
  else
    context="$(context_suffix "$context")"
    pane_label="$context"
    window_label="${context%% | *}"
  fi

  set_pane_option "$pane" @pane-label "$pane_label"
  set_pane_option "$pane" @window-label "$(truncate_top_label "$window_label")"
}

refresh() {
  local pane="$1"
  render "$pane"
  command -v tmux-window-label >/dev/null 2>&1 && tmux-window-label "$pane" >/dev/null 2>&1 || true
  command -v tmux-remote-title >/dev/null 2>&1 && tmux-remote-title publish >/dev/null 2>&1 || true
}

set_identity() {
  local pane="$1" source="$2" subject="$3" max_length
  case "$source" in
    goal) max_length=80 ;;
    manual) max_length=512 ;;
    *) return 0 ;;
  esac
  subject="$(sanitize_subject "$subject")"
  [[ -n "$subject" ]] || return 0
  (( ${#subject} <= max_length )) || return 0
  set_task "$pane" "$subject" "$source" active
  refresh "$pane"
}

default_branch_for_path() {
  local path="$1" branch
  branch="$(git -C "$path" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  branch="${branch#origin/}"
  if [[ -n "$branch" ]]; then
    printf '%s\n' "$branch"
  fi
}

activate_branch() {
  local pane="$1" path="$2" branch default_branch current_source current_state
  [[ "$path" = /* && -d "$path" ]] || return 0
  [[ "$(git -C "$path" rev-parse --is-inside-work-tree 2>/dev/null || true)" == "true" ]] || return 0
  branch="$(git -C "$path" branch --show-current 2>/dev/null || true)"
  [[ -n "$branch" ]] || return 0
  default_branch="$(default_branch_for_path "$path")"
  if [[ -n "$default_branch" ]]; then
    [[ "$branch" != "$default_branch" ]] || return 0
  else
    [[ "$branch" != "main" && "$branch" != "master" ]] || return 0
  fi

  set_pane_option "$pane" @agent_worktree_path "$path"
  current_source="$(get_pane_option "$pane" @task_source 2>/dev/null || true)"
  current_state="$(get_pane_option "$pane" @task_state 2>/dev/null || true)"
  if [[ "$current_state" == "active" ]] && persistent_identity_source "$current_source"; then
    refresh "$pane"
    return 0
  fi
  set_task "$pane" "$branch" branch active
  refresh "$pane"
}

capture_structured_context() {
  local pane="$1" structured existing context
  structured="$(get_pane_option "$pane" @pane-title-structured 2>/dev/null || true)"
  existing="$(get_pane_option "$pane" @pane-label 2>/dev/null || true)"
  [[ -n "$structured" && "$existing" == *" | "* ]] || return 0
  context="$(context_suffix "$existing" "" "")"
  [[ -n "$context" ]] && set_pane_option "$pane" @task_context "$context"
}

complete_task() {
  local pane="$1" label source
  label="$(get_pane_option "$pane" @task_label 2>/dev/null || true)"
  source="$(get_pane_option "$pane" @task_source 2>/dev/null || true)"
  [[ -n "$label" && -n "$source" ]] || return 0
  persistent_identity_source "$source" && return 0
  set_task "$pane" "$label" "$source" completed
}

print_status() {
  local pane="$1" state source label
  state="$(get_pane_option "$pane" @task_state 2>/dev/null || true)"
  source="$(get_pane_option "$pane" @task_source 2>/dev/null || true)"
  label="$(get_pane_option "$pane" @task_label 2>/dev/null || true)"
  [[ -n "$state" && -n "$source" && -n "$label" ]] || return 0
  printf '%s\t%s\t%s\n' "$state" "$source" "$label"
}

require_pane() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || exit 0
  pane_id
}

cmd="${1:-}"
shift || true
pane="$(require_pane)"

case "$cmd" in
  set-kind)
    case "${1:-}" in
      claude|codex|pi)
        set_pane_option "$pane" @agent_kind "$1"
        clear_obsolete_options "$pane"
        ;;
      *) exit 0 ;;
    esac
    refresh "$pane"
    ;;
  set-provisional)
    subject="$(sanitize_subject "$*")"
    [[ -n "$subject" ]] || exit 0
    (( ${#subject} <= 512 )) || exit 0
    current_source="$(get_pane_option "$pane" @task_source 2>/dev/null || true)"
    current_state="$(get_pane_option "$pane" @task_state 2>/dev/null || true)"
    if [[ "$current_state" == "active" ]]; then
      case "$current_source" in branch|goal|manual) exit 0 ;; esac
    fi
    if [[ -z "$current_state" || "$current_state" == "completed" ]]; then
      clear_pane_option "$pane" @task_context
    fi
    set_task "$pane" "$subject" agent provisional
    refresh "$pane"
    ;;
  set-identity)
    source="${1:-}"
    shift || true
    set_identity "$pane" "$source" "$*"
    ;;
  activate-branch)
    activate_branch "$pane" "${1:-}"
    ;;
  clear-worktree)
    clear_worktree_options "$pane"
    refresh "$pane"
    ;;
  complete-worktree)
    capture_structured_context "$pane"
    clear_worktree_options "$pane"
    complete_task "$pane"
    refresh "$pane"
    ;;
  clear-task)
    clear_task_options "$pane"
    refresh "$pane"
    ;;
  refresh)
    refresh "$pane"
    ;;
  status)
    print_status "$pane"
    ;;
  *)
    exit 0
    ;;
esac

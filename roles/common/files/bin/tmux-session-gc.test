#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-session-gc"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

bindir="$(mktemp -d "$TMPROOT/bin.XXXXXX")"
cat > "$bindir/tmux" <<'EOF'
#!/usr/bin/env bash
set -eu

printf '%s\n' "$*" >> "$TMUX_SESSION_GC_LOG"

case "${1:-}" in
  list-sessions)
    printf '%s\n' "$TMUX_SESSION_GC_LIST"
    ;;
  kill-session)
    exit 0
    ;;
  *)
    printf 'unexpected tmux invocation: %s\n' "$*" >&2
    exit 99
    ;;
esac
EOF
chmod +x "$bindir/tmux"

home="$TMPROOT/home"
state_dir="$home/.local/state/tmux/session-gc"
mkdir -p "$state_dir"

# stale: unattached for 15 days, should be killed
printf '%s' "$(( $(date +%s) - 15 * 24 * 60 * 60 ))" > \
  "$state_dir/stale.101.unattached_since"
# attached: marker should be cleaned because it's now attached
printf '%s' "$(date +%s)" > \
  "$state_dir/attached.103.unattached_since"
# reused: a stale marker for an old session_created should be removed
# in favor of a fresh one for the current session_created
printf '%s' "$(( $(date +%s) - 15 * 24 * 60 * 60 ))" > \
  "$state_dir/reused.201.unattached_since"

log="$(mktemp "$TMPROOT/tmux.XXXXXX")"
PATH="$bindir:$PATH" \
HOME="$home" \
TMUX_SESSION_GC_LOG="$log" \
TMUX_SESSION_GC_LIST=$'stale\t0\t101\nfresh\t0\t102\nattached\t1\t103\nreused\t0\t202' \
"$SCRIPT" --days 14

grep -Fqx 'kill-session -t =stale' "$log"
[ ! -f "$state_dir/stale.101.unattached_since" ]
[ -f "$state_dir/fresh.102.unattached_since" ]
[ ! -f "$state_dir/attached.103.unattached_since" ]
[ ! -f "$state_dir/reused.201.unattached_since" ]
[ -f "$state_dir/reused.202.unattached_since" ]
! grep -Fq 'kill-session -t =reused' "$log"

printf 'PASS\n'

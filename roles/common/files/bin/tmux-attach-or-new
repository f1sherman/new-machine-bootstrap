#!/usr/bin/env bash
set -euo pipefail

# Ghostty (and other GUI terminals) launch this via `bash --noprofile --norc`,
# so GUI startup may not include mise or Homebrew paths. Normalize PATH before
# running tmux so it can find the right binaries (including flock).
pathprepend() {
  local dir="${1%/}"
  [ -d "$dir" ] || return 0
  PATH=":$PATH:"
  PATH="${PATH//:$dir:/:}"
  PATH="${PATH#:}"
  PATH="${PATH%:}"
  PATH="$dir:$PATH"
}

PATH="${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"
pathprepend "/usr/local/sbin"
pathprepend "/usr/local/bin"
pathprepend "/opt/homebrew/sbin"
pathprepend "/opt/homebrew/bin"
pathprepend "$HOME/.local/bin"
pathprepend "${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims"
export PATH

restore_log_lib="${TMUX_RESTORE_LOG_LIB:-$HOME/.local/bin/tmux-restore-log.sh}"
if [ -r "$restore_log_lib" ]; then
  # shellcheck source=/dev/null
  source "$restore_log_lib"
else
  tmux_restore_rotate_log() { :; }
  tmux_restore_log_event() { :; }
fi
tmux_restore_rotate_log
tmux_restore_log_event helper_invoked "tty=$(tty 2>/dev/null || printf none)"

LOCK_FILE="${TMUX_ATTACH_LOCK_FILE:-/tmp/tmux-attach-or-new.lock}"
LOCK_TIMEOUT="${TMUX_ATTACH_LOCK_TIMEOUT:-30}"
GHOSTTY_MANIFEST="${TMUX_GHOSTTY_MANIFEST:-$HOME/.local/state/tmux/ghostty-session-manifest.json}"
GHOSTTY_RESTORE_QUEUE="${TMUX_GHOSTTY_RESTORE_QUEUE:-$HOME/.local/state/tmux/ghostty-restore-queue.json}"
lock_held=0
reserved_target=""

resurrect_snapshot() {
  local resurrect_dir resurrect_link resurrect_target

  resurrect_dir="${TMUX_RESURRECT_DIR:-$HOME/.local/share/tmux/resurrect}"
  resurrect_link="$resurrect_dir/last"
  if [ -L "$resurrect_link" ]; then
    resurrect_target="$(readlink "$resurrect_link" 2>/dev/null || true)"
    case "$resurrect_target" in
      /*) ;;
      *) resurrect_target="$(dirname "$resurrect_link")/$resurrect_target" ;;
    esac
    printf '%s\n' "${resurrect_target:-none}"
  elif [ -e "$resurrect_link" ]; then
    printf '%s\n' "$resurrect_link"
  else
    printf '%s\n' none
  fi
}

replace_restore_queue() {
  local queue_dir tmp

  queue_dir="$(dirname "$GHOSTTY_RESTORE_QUEUE")"
  mkdir -p "$queue_dir" 2>/dev/null || return 1
  tmp="$(mktemp "$queue_dir/ghostty-restore-queue.XXXXXX" 2>/dev/null)" || return 1
  if ! cat >"$tmp" || ! chmod 0600 "$tmp" || ! mv "$tmp" "$GHOSTTY_RESTORE_QUEUE"; then
    rm -f "$tmp"
    return 1
  fi
}

resolve_ghostty_app_pid() {
  local login_pid app_pid app_command

  if [ -n "${TMUX_GHOSTTY_APP_PID:-}" ]; then
    app_pid="$TMUX_GHOSTTY_APP_PID"
  else
    login_pid="$(ps -o ppid= -p "$$" 2>/dev/null | tr -d '[:space:]')"
    app_pid="$(ps -o ppid= -p "$login_pid" 2>/dev/null | tr -d '[:space:]')"
    app_command="$(ps -o command= -p "$app_pid" 2>/dev/null || true)"
    case "$app_command" in
      */Ghostty.app/Contents/MacOS/ghostty*) ;;
      *) return 1 ;;
    esac
  fi
  case "$app_pid" in
    ''|*[!0-9]*) return 1 ;;
  esac
  printf '%s\n' "$app_pid"
}

unlock_startup() {
  if [ "$lock_held" = "1" ]; then
    flock -u 9 || true
    lock_held=0
    tmux_restore_log_event lock_released
  fi
}

fallback_shell() {
  local reason shell status

  reason="$1"
  unlock_startup
  tmux_restore_log_event fallback_shell "reason=$reason"
  printf '%s\n' "[tmux] Startup failed ($reason); run tmux-restore-debug-report for details." >&2
  shell="${TMUX_ATTACH_FALLBACK_SHELL:-${SHELL:-/bin/zsh}}"
  shopt -s execfail
  set +e
  export TMUX_ATTACH_FALLBACK=1
  exec "$shell" -l
  status=$?
  set -e
  tmux_restore_log_event fallback_exec_failed "reason=$reason" "shell=$shell" "status=$status"
  printf '%s\n' "[tmux] Unable to start fallback shell $shell (status $status)." >&2
  exit "$status"
}

cleanup_reservation() {
  local owner owner_after target unset_status

  [ -n "$reserved_target" ] || return 0
  target="$reserved_target"

  if ! flock -w "$LOCK_TIMEOUT" 9; then
    owner="$(tmux show-options -qv -t "$target" @ghostty_attach_owner 2>/dev/null || true)"
    unset_status=0
    if [ "$owner" = "$$" ]; then
      tmux set-option -qu -t "$target" @ghostty_attach_owner 2>/dev/null || unset_status=$?
      owner_after="$(tmux show-options -qv -t "$target" @ghostty_attach_owner 2>/dev/null || true)"
    else
      owner_after="$owner"
    fi
    tmux_restore_log_event reservation_cleanup_degraded \
      "target=$target" "reason=lock_timeout" "owner=${owner:-none}" "status=$unset_status"
    if [ "$owner_after" != "$$" ]; then
      reserved_target=""
    fi
    return 0
  fi
  lock_held=1
  owner="$(tmux show-options -qv -t "$target" @ghostty_attach_owner 2>/dev/null || true)"
  if [ "$owner" = "$$" ]; then
    if tmux set-option -qu -t "$target" @ghostty_attach_owner 2>/dev/null; then
      reserved_target=""
      tmux_restore_log_event reservation_released "target=$target"
    fi
  else
    reserved_target=""
  fi
  unlock_startup
}

exec 9>"$LOCK_FILE"
lock_started=$SECONDS
tmux_restore_log_event lock_attempt "timeout_seconds=$LOCK_TIMEOUT"
if flock -n 9; then
  lock_held=1
  tmux_restore_log_event lock_acquired "wait_seconds=$((SECONDS - lock_started))"
else
  printf '%s\n' '[tmux] Waiting for saved sessions to restore...'
  if ! flock -w "$LOCK_TIMEOUT" 9; then
    tmux_restore_log_event lock_failed "wait_seconds=$((SECONDS - lock_started))" "reason=timeout"
    fallback_shell lock_timeout
  fi
  lock_held=1
  tmux_restore_log_event lock_acquired "wait_seconds=$((SECONDS - lock_started))"
fi

sessions_output=""
has_server=0
restore_state="unset"
if sessions_output="$(tmux list-sessions -F '#{session_id}'$'\t''#{session_attached}'$'\t''#{==:#{session_name},__bootstrap__}'$'\t''owner=#{@ghostty_attach_owner}'$'\t''#{session_name}' 2>/dev/null)"; then
  has_server=1
  restore_state="$(tmux show-options -gqv @ghostty_restore_state 2>/dev/null || true)"
  restore_state="${restore_state:-unset}"
fi
tmux_restore_log_event server_snapshot "phase=pre_decision" "has_server=$has_server" \
  "restore_state=$restore_state" "sessions=${sessions_output:-none}"

restored=0
if [ "$has_server" = "0" ]; then
  bootstrap_started=$SECONDS
  tmux_restore_log_event bootstrap_start "session=__bootstrap__"
  if tmux new-session -d -s __bootstrap__; then
    bootstrap_status=0
  else
    bootstrap_status=$?
  fi
  tmux_restore_log_event bootstrap_end "session=__bootstrap__" \
    "elapsed_seconds=$((SECONDS - bootstrap_started))" "status=$bootstrap_status"
  [ "$bootstrap_status" = "0" ] || fallback_shell bootstrap_create_failed
  tmux set-option -gq @ghostty_restore_state running || fallback_shell restore_state_failed

  socket_path="$(tmux display-message -p -t __bootstrap__ '#{socket_path}' 2>/dev/null || true)"
  restore_wrapper="${TMUX_RESURRECT_RESTORE_WRAPPER:-$HOME/.local/bin/tmux-resurrect-restore-wrapper}"
  restore_snapshot="$(resurrect_snapshot)"
  restore_started=$SECONDS
  tmux_restore_log_event restore_start "snapshot=$restore_snapshot" "wrapper=$restore_wrapper" "socket=${socket_path:-unknown}"
  if TMUX="${socket_path},$$,0" "$restore_wrapper"; then
    restore_status=0
  else
    restore_status=$?
  fi
  tmux_restore_log_event restore_end "snapshot=$restore_snapshot" \
    "elapsed_seconds=$((SECONDS - restore_started))" "status=$restore_status"
  if [ "$restore_status" = "0" ]; then
    tmux set-option -gq @ghostty_restore_state ok || fallback_shell restore_state_failed
    restored=1
  else
    tmux set-option -gq @ghostty_restore_state failed 2>/dev/null || true
    fallback_shell restore_failed
  fi

  sessions_output="$(tmux list-sessions -F '#{session_id}'$'\t''#{session_attached}'$'\t''#{==:#{session_name},__bootstrap__}'$'\t''owner=#{@ghostty_attach_owner}'$'\t''#{session_name}' 2>/dev/null)" \
    || fallback_shell session_list_failed
  tmux_restore_log_event server_snapshot "phase=post_restore" "has_server=1" \
    "restore_state=ok" "sessions=${sessions_output:-none}"
else
  case "$restore_state" in
    failed)
      fallback_shell restore_failed
      ;;
    running)
      tmux set-option -gq @ghostty_restore_state failed 2>/dev/null || true
      tmux_restore_log_event restore_abandoned "previous_state=running" "status=failed"
      fallback_shell restore_abandoned
      ;;
  esac
fi

target=""
tab="$(printf '\t')"
ghostty_app_pid=""
if [ -f "$GHOSTTY_MANIFEST" ]; then
  ghostty_app_pid="$(resolve_ghostty_app_pid 2>/dev/null || true)"
fi

if [ -n "$ghostty_app_pid" ]; then
  queue_pid="$(jq -er '
    select(
      .version == 1 and
      (.ghostty_pid | type == "number") and
      (.pending | type == "array") and
      all(.pending[]; type == "string")
    )
    | .ghostty_pid
  ' "$GHOSTTY_RESTORE_QUEUE" 2>/dev/null || true)"
  if [ "$queue_pid" != "$ghostty_app_pid" ]; then
    manifest_pid="$(jq -er '.ghostty_pid | select(type == "number")' "$GHOSTTY_MANIFEST" 2>/dev/null || true)"
    if [ -n "$manifest_pid" ] && [ "$manifest_pid" != "$ghostty_app_pid" ]; then
      queue_json="$(jq -e --argjson ghostty_pid "$ghostty_app_pid" '
        [.windows[].tabs[].session_name] as $pending
        | select(
            .version == 1 and
            ($pending | length) > 0 and
            all($pending[]; type == "string")
          )
        | {version: 1, ghostty_pid: $ghostty_pid, pending: $pending}
      ' "$GHOSTTY_MANIFEST" 2>/dev/null || true)"
      if [ -z "$queue_json" ]; then
        tmux_restore_log_event restore_queue_skipped \
          "ghostty_pid=$ghostty_app_pid" "reason=invalid_manifest"
      elif printf '%s\n' "$queue_json" | replace_restore_queue; then
        pending_count="$(jq '.pending | length' "$GHOSTTY_RESTORE_QUEUE")"
        tmux_restore_log_event restore_queue_initialized \
          "ghostty_pid=$ghostty_app_pid" "sessions=$pending_count"
      else
        tmux_restore_log_event restore_queue_skipped \
          "ghostty_pid=$ghostty_app_pid" "reason=queue_write_failed"
      fi
    else
      if jq -n --argjson ghostty_pid "$ghostty_app_pid" \
        '{version: 1, ghostty_pid: $ghostty_pid, pending: []}' | replace_restore_queue; then
        tmux_restore_log_event restore_queue_skipped \
          "ghostty_pid=$ghostty_app_pid" "reason=current_process_manifest"
      else
        tmux_restore_log_event restore_queue_skipped \
          "ghostty_pid=$ghostty_app_pid" "reason=queue_write_failed"
      fi
    fi
  fi

  while candidate_name="$(jq -er '.pending[0] | select(type == "string")' "$GHOSTTY_RESTORE_QUEUE" 2>/dev/null)"; do
    if ! jq '.pending |= .[1:]' "$GHOSTTY_RESTORE_QUEUE" 2>/dev/null | replace_restore_queue; then
      tmux_restore_log_event restore_queue_candidate_skipped \
        "session=$candidate_name" "reason=queue_write_failed"
      break
    fi

    candidate_id="$(tmux display-message -p -t "=$candidate_name:" '#{session_id}' 2>/dev/null || true)"
    if [ -z "$candidate_id" ]; then
      tmux_restore_log_event restore_queue_candidate_skipped \
        "session=$candidate_name" "reason=missing"
      continue
    fi

    candidate_found=0
    while IFS="$tab" read -r session_id attached bootstrap owner_field _session_name; do
      [ "$session_id" = "$candidate_id" ] || continue
      candidate_found=1
      if [ "$bootstrap" != "0" ]; then
        tmux_restore_log_event restore_queue_candidate_skipped \
          "session=$candidate_name" "reason=bootstrap"
        break
      fi
      if [ "$attached" != "0" ]; then
        tmux_restore_log_event restore_queue_candidate_skipped \
          "session=$candidate_name" "reason=attached"
        break
      fi

      owner="${owner_field#owner=}"
      if [ -n "$owner" ]; then
        if kill -0 "$owner" 2>/dev/null; then
          tmux_restore_log_event restore_queue_candidate_skipped \
            "session=$candidate_name" "reason=reserved"
          break
        fi
        tmux set-option -qu -t "$session_id" @ghostty_attach_owner 2>/dev/null || true
        tmux_restore_log_event reservation_reclaimed "target=$session_id" "owner=$owner"
      fi

      target="$session_id"
      tmux_restore_log_event restore_queue_claimed \
        "ghostty_pid=$ghostty_app_pid" "session=$candidate_name" "target=$target"
      break
    done <<EOF
$sessions_output
EOF

    [ -n "$target" ] && break
    if [ "$candidate_found" = "0" ]; then
      tmux_restore_log_event restore_queue_candidate_skipped \
        "session=$candidate_name" "reason=missing"
    fi
  done
fi

if [ -z "$target" ] && [ -n "$ghostty_app_pid" ] && \
  [ "$(jq -r '.pending | length' "$GHOSTTY_RESTORE_QUEUE" 2>/dev/null || printf unknown)" = "0" ]; then
  tmux_restore_log_event restore_queue_exhausted "ghostty_pid=$ghostty_app_pid"
fi

while [ -z "$target" ] && IFS="$tab" read -r session_id attached bootstrap owner_field _session_name; do
  [ -n "$session_id" ] || continue
  [ "$bootstrap" = "0" ] || continue
  [ "$attached" = "0" ] || continue

  owner="${owner_field#owner=}"
  if [ -n "$owner" ]; then
    if kill -0 "$owner" 2>/dev/null; then
      continue
    fi
    tmux set-option -qu -t "$session_id" @ghostty_attach_owner 2>/dev/null || true
    tmux_restore_log_event reservation_reclaimed "target=$session_id" "owner=$owner"
  fi

  target="$session_id"
  break
done <<EOF
$sessions_output
EOF

if [ -z "$target" ]; then
  target="$(tmux new-session -d -P -F '#{session_id}' 2>/dev/null)" \
    || fallback_shell session_create_failed
fi

[ -n "$target" ] || fallback_shell session_create_failed
tmux set-option -q -t "$target" @ghostty_attach_owner "$$" \
  || fallback_shell reservation_failed
reserved_target="$target"
tmux_restore_log_event reservation_acquired "target=$target"

if [ "$restored" = "1" ]; then
  tmux kill-session -t __bootstrap__ 2>/dev/null || true
fi

unlock_startup
trap cleanup_reservation EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM

attach_started=$SECONDS
tmux_restore_log_event attach_start "target=$target"
if tmux attach -t "$target"; then
  attach_status=0
else
  attach_status=$?
fi
tmux_restore_log_event attach_end "target=$target" \
  "elapsed_seconds=$((SECONDS - attach_started))" "status=$attach_status"

cleanup_reservation
[ "$attach_status" = "0" ] && exit 0
fallback_shell attach_failed

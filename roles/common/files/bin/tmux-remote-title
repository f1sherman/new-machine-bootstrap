#!/usr/bin/env bash
set -u

mode="${1:-publish}"
pane_id="${TMUX_PANE:-}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
devpod_name_helper="${TMUX_DEVPOD_NAME_BIN:-$script_dir/tmux-devpod-name}"

[ -x "$devpod_name_helper" ] || devpod_name_helper="${HOME:-}/.local/bin/tmux-devpod-name"

pane_info() {
  local format

  if [ -n "${TMUX_REMOTE_TITLE_PANE_PATH:-}" ] || [ -n "${TMUX_REMOTE_TITLE_PANE_TTY:-}" ] || [ -n "${TMUX_REMOTE_TITLE_PANE_COMMAND:-}" ] || [ -n "${TMUX_REMOTE_TITLE_EDGE_FLAGS:-}" ] || [ -n "${TMUX_REMOTE_TITLE_SESSION_ID:-}" ] || [ -n "${TMUX_REMOTE_TITLE_WINDOW_ID:-}" ] || [ -n "${TMUX_REMOTE_TITLE_PANE_ACTIVE:-}" ]; then
    printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "${TMUX_REMOTE_TITLE_PANE_PATH:-}" \
      "${TMUX_REMOTE_TITLE_PANE_TTY:-}" \
      "${TMUX_REMOTE_TITLE_PANE_COMMAND:-}" \
      "${TMUX_REMOTE_TITLE_EDGE_FLAGS:-}" \
      "${TMUX_REMOTE_TITLE_SESSION_ID:-}" \
      "${TMUX_REMOTE_TITLE_WINDOW_ID:-}" \
      "${TMUX_REMOTE_TITLE_PANE_ACTIVE:-1}"
    return 0
  fi

  [ -n "$pane_id" ] || return 1
  printf -v format '#{pane_current_path}\t#{pane_tty}\t#{pane_current_command}\t#{?pane_at_left,h,}#{?pane_at_bottom,j,}#{?pane_at_top,k,}#{?pane_at_right,l,}\t#{session_id}\t#{window_id}\t#{pane_active}'
  tmux display-message -p -t "$pane_id" "$format" 2>/dev/null
}

read_pane_option() {
  local option_name="$1"
  if [ "$option_name" = "@agent_worktree_path" ] && [ -n "${TMUX_REMOTE_TITLE_WORKTREE_PATH:-}" ]; then
    printf '%s\n' "$TMUX_REMOTE_TITLE_WORKTREE_PATH"
    return 0
  fi
  if [ "$option_name" = "@agent_worktree_pid" ] && [ -n "${TMUX_REMOTE_TITLE_WORKTREE_PID:-}" ]; then
    printf '%s\n' "$TMUX_REMOTE_TITLE_WORKTREE_PID"
    return 0
  fi
  if [ "$option_name" = "@agent_activity" ] && [ -n "${TMUX_REMOTE_TITLE_ACTIVITY:-}" ]; then
    printf '%s\n' "$TMUX_REMOTE_TITLE_ACTIVITY"
    return 0
  fi
  if [ "$option_name" = "@pr_state" ] && [ -n "${TMUX_REMOTE_TITLE_PR_STATE:-}" ]; then
    printf '%s\n' "$TMUX_REMOTE_TITLE_PR_STATE"
    return 0
  fi

  [ -n "$pane_id" ] || return 1
  tmux show-options -qv -p -t "$pane_id" "$option_name" 2>/dev/null
}

get_process_lines() {
  local pane_tty="$1"
  if [ -n "${TMUX_REMOTE_TITLE_PS_FILE:-}" ] && [ -f "${TMUX_REMOTE_TITLE_PS_FILE}" ]; then
    cat "${TMUX_REMOTE_TITLE_PS_FILE}"
  elif [ -n "$pane_tty" ]; then
    ps -o pid=,stat=,comm=,args= -t "$pane_tty" 2>/dev/null
  fi
}

is_agent_process() {
  local comm="$1" args="$2"
  case "$comm" in
    claude|codex)
      return 0
      ;;
  esac
  printf '%s\n' "$args" | grep -Eq '(^|[[:space:]])([^[:space:]]*/)?(claude|codex)([[:space:]]|$)'
}

detect_agent_pid() {
  local pane_tty="$1"
  local line pid stat comm args fg_pid="" any_pid=""

  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    read -r pid stat comm args <<< "$line"
    is_agent_process "${comm:-}" "${args:-}" || continue
    any_pid="$pid"
    case "$stat" in
      *+*)
        fg_pid="$pid"
        ;;
    esac
  done < <(get_process_lines "$pane_tty")

  if [ -n "$fg_pid" ]; then
    printf '%s\n' "$fg_pid"
  elif [ -n "$any_pid" ]; then
    printf '%s\n' "$any_pid"
  fi
}

git_branch_for_path() {
  local path="$1"
  local gitdir head content real

  while [ -n "$path" ] && [ "$path" != "/" ]; do
    if [ -d "$path/.git" ]; then
      gitdir="$path/.git"
      break
    fi

    if [ -f "$path/.git" ]; then
      IFS= read -r content < "$path/.git" || return 1
      real="${content#gitdir: }"
      case "$real" in
        /*) gitdir="$real" ;;
        *) gitdir="$path/$real" ;;
      esac
      break
    fi

    path="${path%/*}"
  done

  [ -n "${gitdir:-}" ] && [ -r "$gitdir/HEAD" ] || return 1
  IFS= read -r head < "$gitdir/HEAD" || return 1
  case "$head" in
    ref:\ refs/heads/*)
      printf '%s\n' "${head#ref: refs/heads/}"
      return 0
      ;;
  esac

  return 1
}

dir_basename() {
  local raw="${1%/}"
  raw="${raw##*/}"
  [ -n "$raw" ] || raw="/"
  printf '%s\n' "$raw"
}

repo_root_for_path() {
  local path="$1" common_dir top_level

  top_level="$(git -C "$path" rev-parse --path-format=absolute --show-toplevel 2>/dev/null)" || return 1
  common_dir="$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  common_dir="${common_dir%/}"

  case "$common_dir" in
    */.git)
      printf '%s\n' "${common_dir%/*}"
      ;;
    *)
      printf '%s\n' "$top_level"
      ;;
  esac
}

repo_basename() {
  local root
  root="$(repo_root_for_path "$1")" || return 1
  dir_basename "$root"
}

dirty_marker() {
  [ -n "$(git --no-optional-locks -C "$1" status --porcelain 2>/dev/null)" ]
}

formatted_local_path_label() {
  local path="$1" repo branch

  repo="$(repo_basename "$path" 2>/dev/null || true)"
  branch="$(git_branch_for_path "$path" 2>/dev/null || true)"

  if [ -n "$branch" ] && [ -n "$repo" ]; then
    if dirty_marker "$path"; then
      printf '(*%s) %s\n' "$branch" "$repo"
    else
      printf '(%s) %s\n' "$branch" "$repo"
    fi
    return 0
  fi

  if [ -n "$repo" ]; then
    printf '%s\n' "$repo"
  else
    dir_basename "$path"
  fi
}

formatted_explicit_remote_label() {
  printf '%s | %s\n' "$(formatted_local_path_label "$1")" "$2"
}

formatted_remote_path_label() {
  local path="$1" repo

  repo="$(repo_basename "$path" 2>/dev/null || true)"
  if [ -n "$repo" ]; then
    printf '%s\n' "$repo"
  else
    dir_basename "$path"
  fi
}

formatted_remote_label() {
  printf '%s | %s\n' "$(formatted_remote_path_label "$1")" "$2"
}

append_ind_marker() {
  local title="$1" activity pr_state
  activity="$(read_pane_option "@agent_activity" 2>/dev/null || true)"
  pr_state="$(read_pane_option "@pr_state" 2>/dev/null || true)"
  if [ -n "$activity" ] || [ -n "$pr_state" ]; then
    printf '%s [nmb-ind=%s,%s]\n' "$title" "$activity" "$pr_state"
  else
    printf '%s\n' "$title"
  fi
}

append_edge_marker() {
  local title="$1" pane_command="$2" edge_flags="$3"

  if [ -n "${TMUX_REMOTE_TITLE_SUPPRESS_EDGE:-}" ]; then
    printf '%s\n' "$title"
    return 0
  fi

  case "$pane_command" in
    *vim*)
      printf '%s\n' "$title"
      return 0
      ;;
  esac

  if [ -n "$edge_flags" ]; then
    printf '%s [nmb-edge=%s]\n' "$title" "$edge_flags"
  else
    printf '%s\n' "$title"
  fi
}

is_git_worktree_path() {
  local path="$1"
  [ -d "$path" ] || return 1
  [ "$(git -C "$path" rev-parse --is-inside-work-tree 2>/dev/null)" = "true" ]
}

is_linked_worktree() {
  local path="$1" git_dir common_dir
  git_dir="$(git -C "$path" rev-parse --path-format=absolute --git-dir 2>/dev/null)" || return 1
  common_dir="$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  [ "$git_dir" != "$common_dir" ]
}

is_valid_explicit_path() {
  local path="$1"
  is_git_worktree_path "$path" || return 1
  git_branch_for_path "$path" >/dev/null 2>&1
}

host_tag() {
  if [ -n "${TMUX_REMOTE_TITLE_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_REMOTE_TITLE_HOST_TAG"
  elif [ -n "${CODESPACES:-}" ] && [ -n "${CODESPACE_NAME:-}" ]; then
    printf '%s\n' "$CODESPACE_NAME"
  elif [ -n "${DEVPOD_WORKSPACE_ID:-}" ]; then
    "$devpod_name_helper" "" "$(hostname -s 2>/dev/null || true)" 2>/dev/null || true
  elif [ -n "${SSH_CONNECTION:-}" ]; then
    hostname -s 2>/dev/null
  fi
}

managed_task_title() {
  local task_label="$1" task_state="$2" task_context="$3" host="$4" context
  [ -n "$task_label" ] && [ -n "$task_context" ] || return 1
  context="$task_context"
  if [ "${context##* | }" != "$host" ]; then
    context="$context | $host"
  fi

  case "$task_state" in
    provisional) printf '~ %s · %s\n' "$task_label" "$context" ;;
    active) printf '(%s) %s\n' "$task_label" "$context" ;;
    completed) printf '✓ (%s) %s\n' "$task_label" "$context" ;;
    *) return 1 ;;
  esac
}

matching_client_ttys() {
  local source_session_id="$1" source_window_id="$2"
  local client_tty client_session_id client_window_id format

  printf -v format '#{client_tty}\t#{session_id}\t#{window_id}'
  tmux list-clients -F "$format" 2>/dev/null |
    while IFS=$'\t' read -r client_tty client_session_id client_window_id; do
      [ -n "$client_tty" ] || continue
      [ "$client_session_id" = "$source_session_id" ] || continue
      [ "$client_window_id" = "$source_window_id" ] || continue
      printf '%s\n' "$client_tty"
    done
}

publish_title() {
  local title="$1" source_session_id="$2" source_window_id="$3" pane_active="$4"
  local client_tty

  [ "$pane_active" = "1" ] || return 0
  [ -n "$source_session_id" ] || return 0
  [ -n "$source_window_id" ] || return 0

  while IFS= read -r client_tty; do
    [ -n "$client_tty" ] || continue
    printf '\033]2;%s\033\\' "$title" > "$client_tty" 2>/dev/null || true
  done < <(matching_client_ttys "$source_session_id" "$source_window_id")
}

main() {
  local pane_path pane_tty pane_command edge_flags source_session_id source_window_id pane_active
  local host title worktree_path worktree_pid active_agent_pid info task_label task_state task_context

  info="$(pane_info)" || exit 0
  [ -n "$info" ] || exit 0
  pane_path="${info%%$'\t'*}"
  info="${info#*$'\t'}"
  pane_tty="${info%%$'\t'*}"
  info="${info#*$'\t'}"
  pane_command="${info%%$'\t'*}"
  info="${info#*$'\t'}"
  edge_flags="${info%%$'\t'*}"
  info="${info#*$'\t'}"
  source_session_id="${info%%$'\t'*}"
  info="${info#*$'\t'}"
  source_window_id="${info%%$'\t'*}"
  pane_active="${info#*$'\t'}"
  [ -n "$pane_path" ] || exit 0

  host="$(host_tag)"
  [ -n "$host" ] || exit 0

  task_label="$(read_pane_option "@task_label" 2>/dev/null || true)"
  task_state="$(read_pane_option "@task_state" 2>/dev/null || true)"
  task_context="$(read_pane_option "@task_context" 2>/dev/null || true)"
  if [ -n "$task_label" ] && [ -n "$task_state" ] && [ -n "$task_context" ]; then
    title="$(managed_task_title "$task_label" "$task_state" "$task_context" "$host" 2>/dev/null || true)"
  fi

  worktree_path="$(read_pane_option "@agent_worktree_path" 2>/dev/null || true)"
  worktree_pid="$(read_pane_option "@agent_worktree_pid" 2>/dev/null || true)"

  if [ -z "${title:-}" ] && [ -n "$worktree_path" ] && is_valid_explicit_path "$worktree_path"; then
    if [ -z "$worktree_pid" ]; then
      title="$(formatted_explicit_remote_label "$worktree_path" "$host" 2>/dev/null || true)"
    else
      active_agent_pid="$(detect_agent_pid "$pane_tty")"
      if [ -n "$active_agent_pid" ] && [ "$active_agent_pid" = "$worktree_pid" ]; then
        title="$(formatted_explicit_remote_label "$worktree_path" "$host" 2>/dev/null || true)"
      fi
    fi
  fi

  if [ -z "${title:-}" ]; then
    title="$(formatted_remote_label "$pane_path" "$host" 2>/dev/null || true)"
  fi
  title="$(append_ind_marker "$title")"
  title="$(append_edge_marker "$title" "${pane_command:-}" "${edge_flags:-}")"

  case "$mode" in
    print)
      printf '%s\n' "$title"
      ;;
    publish)
      publish_title "$title" "$source_session_id" "$source_window_id" "$pane_active"
      ;;
    *)
      exit 0
      ;;
  esac
}

main
exit 0

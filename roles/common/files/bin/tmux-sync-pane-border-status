#!/usr/bin/env bash
set -euo pipefail

pane_id="${1:-${TMUX_PANE:-}}"
[ -n "$pane_id" ] || exit 0

window_id="$(tmux display-message -p -t "$pane_id" '#{window_id}' 2>/dev/null || true)"
[ -n "$window_id" ] || exit 0

tmux set-window-option -q -t "$window_id" pane-border-status bottom 2>/dev/null || true
exit 0

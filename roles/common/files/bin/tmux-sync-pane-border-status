#!/usr/bin/env bash
set -euo pipefail

# Skip when something else is managing the status/border bars (e.g. a
# system-level /etc/tmux.conf). Opt out with: tmux set -g @managed-bars off
if [ "$(tmux show -gv @managed-bars 2>/dev/null)" = "off" ]; then
  exit 0
fi

pane_id="${1:-${TMUX_PANE:-}}"
[ -n "$pane_id" ] || exit 0

window_id="$(tmux display-message -p -t "$pane_id" '#{window_id}' 2>/dev/null || true)"
[ -n "$window_id" ] || exit 0

tmux set-window-option -q -t "$window_id" pane-border-status bottom 2>/dev/null || true
exit 0

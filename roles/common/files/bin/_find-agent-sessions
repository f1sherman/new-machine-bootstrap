#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "open3"
require "shellwords"
require "time"

USAGE = "Usage: _find-agent-sessions [24h|4h|2d|today|yesterday] [--json]\n"
NO_SUMMARY = "recent session activity"

def abort_usage
  warn USAGE
  exit 1
end

def parse_args(argv)
  window = "24h"
  json_output = false

  until argv.empty?
    arg = argv.shift
    case arg
    when "--json"
      json_output = true
    when "today", "yesterday"
      window = arg
    when /\A\d+[hd]\z/
      window = arg
    else
      abort_usage
    end
  end

  [window, json_output]
end

def command_exists?(command)
  ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? do |dir|
    path = File.join(dir, command)
    File.file?(path) && File.executable?(path)
  end
end

def capture_stdout(*command)
  stdout, _stderr, status = Open3.capture3(*command)
  status.success? ? stdout : ""
rescue Errno::ENOENT
  ""
end

def parse_json(text, fallback)
  stripped = text.to_s.strip
  return fallback if stripped.empty?

  JSON.parse(stripped)
rescue JSON::ParserError
  fallback
end

def time_window(window)
  now = Time.now

  case window
  when "today"
    start = Time.local(now.year, now.month, now.day)
    [start.to_i, now.to_i]
  when "yesterday"
    midnight = Time.local(now.year, now.month, now.day)
    [(midnight - 86_400).to_i, midnight.to_i]
  when /\A(\d+)h\z/
    hours = Regexp.last_match(1).to_i
    [now.to_i - (hours * 3600), now.to_i]
  when /\A(\d+)d\z/
    days = Regexp.last_match(1).to_i
    [now.to_i - (days * 86_400), now.to_i]
  else
    abort_usage
  end
end

def coarse_days(start_epoch, end_epoch)
  duration = end_epoch - start_epoch
  ((duration + 86_399) / 86_400) + 1
end

def list_sessions(command, days)
  return [] unless command_exists?(command)

  parse_json(capture_stdout(command, "--json", "--days", days.to_s, "--limit", "500"), [])
end

def read_session(command, file)
  return {} unless command_exists?(command)

  parse_json(capture_stdout(command, file, "--json"), {})
end

def trim_one_line(text)
  text.to_s.gsub(/\s+/, " ").strip
end

def truncate_text(text, max = 96)
  return text if text.length <= max

  "#{text[0, max - 3]}..."
end

def shell_double_quote(text)
  text.to_s.gsub(/["\\$`]/) { |char| "\\#{char}" }
end

def repo_and_worktree_from_cwd(cwd)
  return ["", ""] if cwd.to_s.empty?

  marker = "/.worktrees/"
  if cwd.include?(marker)
    prefix, suffix = cwd.split(marker, 2)
    [File.basename(prefix), suffix.to_s.split("/", 2).first.to_s]
  else
    [File.basename(cwd), ""]
  end
end

def push_recent(list, value, max_size)
  return if value.to_s.empty?

  list << value
  list.shift while list.length > max_size
end

def each_jsonl(file)
  return enum_for(:each_jsonl, file) unless block_given?

  File.foreach(file) do |line|
    next if line.strip.empty?

    parsed = parse_json(line, nil)
    yield parsed if parsed.is_a?(Hash)
  end
end

def codex_recent_lines(file)
  message_lines = []
  command_lines = []

  each_jsonl(file) do |row|
    case row["type"]
    when "response_item"
      payload = row["payload"]
      next unless payload.is_a?(Hash)
      next unless payload["type"] == "message"
      next unless %w[user assistant].include?(payload["role"])

      Array(payload["content"]).each do |item|
        next unless item.is_a?(Hash)
        next unless %w[input_text output_text].include?(item["type"])

        push_recent(message_lines, item["text"].to_s, 80)
      end
    when "function_call"
      payload = row["payload"]
      next unless payload.is_a?(Hash)

      args = parse_json(payload["arguments"], nil)
      command = args.is_a?(Hash) ? args["command"] : nil
      push_recent(command_lines, command.to_s, 40)
    end
  end

  message_lines + command_lines
end

def claude_text_from_message(message)
  content = message["content"]

  case content
  when String
    content
  when Array
    content.map do |item|
      next unless item.is_a?(Hash)
      next unless item["type"] == "text"

      item["text"]
    end.compact.join("\n")
  else
    ""
  end
end

def claude_recent_lines(file)
  lines = []

  each_jsonl(file) do |row|
    case row["type"]
    when "user"
      next if row["isMeta"] == true

      push_recent(lines, claude_text_from_message(row.fetch("message", {})), 80)
    when "assistant"
      push_recent(lines, claude_text_from_message(row.fetch("message", {})), 80)
    end
  end

  lines
end

def recent_lines_for_tool(tool, file)
  tool == "Codex" ? codex_recent_lines(file) : claude_recent_lines(file)
end

def entry_branch(entry)
  entry["gitBranch"].to_s.tap do |branch|
    return branch unless branch.empty?
  end

  git = entry["git"]
  return "" unless git.is_a?(Hash)

  git["branch"].to_s
end

def read_branch(read_json)
  return read_json["git_branch"].to_s unless read_json["git_branch"].to_s.empty?
  return read_json["gitBranch"].to_s unless read_json["gitBranch"].to_s.empty?

  git = read_json["git"]
  return "" unless git.is_a?(Hash)

  git["branch"].to_s
end

def summary_candidates(read_json, preview, tool, file)
  candidates = []
  candidates << preview.to_s unless preview.to_s.empty?
  candidates.concat(Array(read_json["user_messages"]).map(&:to_s))
  candidates.concat(Array(read_json["assistant_messages"]).map(&:to_s))
  candidates.concat(Array(read_json["shell_commands"]).map(&:to_s))
  candidates.concat(Array(read_json["bash_commands"]).map(&:to_s))
  candidates.concat(recent_lines_for_tool(tool, file))
  candidates
end

def summary_skip?(line)
  return true if line.empty?
  return true if line.start_with?("<")
  return true if line.start_with?("tool:")

  lower = line.downcase
  return true if lower == "--- project-doc ---"

  fixed_patterns = [
    "agents.md instructions",
    "environment_context",
    "you are codex",
    "you are claude",
    "the user interrupted the previous turn on purpose",
    "using-superpowers",
    "start-of-session requirement",
    "* workspace:",
    "* bias toward action.",
    "* spec approval and plan execution:",
    "* pull requests:",
    "* worktrees:",
    "* comments:",
    "* scripts/snippets:",
    "* json/yaml parsing:",
    "* multi-line commands:",
    "* testing:",
    "* temp files:",
    "* verification:"
  ]

  return true if fixed_patterns.any? { |pattern| lower.include?(pattern) }
  return true if lower.include?("user name:") && lower.include?("work style:")

  false
end

def weak_summary?(line)
  lower = line.downcase
  return true if lower.start_with?("#")

  [
    "continue",
    "continue.",
    "resume",
    "resume.",
    "test prompt",
    "did you clean up?",
    "merged, clean up",
    "cleanup"
  ].include?(lower)
end

def build_summary(read_json, preview, tool, file)
  fallback = nil

  summary_candidates(read_json, preview, tool, file).each do |candidate|
    cleaned = trim_one_line(candidate)
    next if cleaned.empty?
    next if summary_skip?(cleaned)

    if weak_summary?(cleaned)
      fallback ||= cleaned
      next
    end

    return truncate_text(cleaned)
  end

  fallback ? truncate_text(fallback) : NO_SUMMARY
end

def recent_signal_lines(read_json, tool, file)
  lines = []
  lines.concat(Array(read_json["assistant_messages"]).map(&:to_s))
  lines.concat(Array(read_json["shell_commands"]).map(&:to_s))
  lines.concat(Array(read_json["bash_commands"]).map(&:to_s))
  lines.concat(recent_lines_for_tool(tool, file))
  lines
end

def cleanup_signal?(line)
  [
    "worktree-done",
    "worktree-delete",
    "git worktree remove",
    "git branch -d",
    "tmux-agent-worktree clear",
    "cleanup complete",
    "cleaned up",
    "branch cleanup",
    "worktree cleanup"
  ].any? { |pattern| line.include?(pattern) }
end

def merge_signal?(line)
  line.include?("gh pr merge") ||
    (line.include?("pr #") && line.include?(" merged")) ||
    line.include?("pull request merged") ||
    line.include?("merged the pull request") ||
    line.include?("_merge_pull_request") ||
    line.include?("merge pull request")
end

def pr_created_signal?(line)
  line.include?("gh pr create") ||
    line.include?("draft-pr") ||
    line.include?("create-pull-request") ||
    (line.include?("pr #") && line.include?(" opened")) ||
    line.include?("pull request opened") ||
    line.include?("pull request created") ||
    line.include?("/pull/")
end

def blocked_signal?(line)
  [
    "waiting for review",
    "waiting on review",
    "please review",
    "awaiting review",
    "waiting for merge",
    "waiting on merge",
    "needs review",
    "blocked on",
    "requires manual",
    "manual step",
    "waiting for credentials",
    "missing credential",
    "needs credential"
  ].any? { |pattern| line.include?(pattern) }
end

def verification_signal?(line)
  [
    "pytest",
    "rspec",
    "npm test",
    "cargo test",
    "go test",
    "bash tests/",
    ".test",
    "tests pass",
    "test passed",
    "verification passed",
    "ran verification"
  ].any? { |pattern| line.include?(pattern) }
end

def plan_signal?(line)
  [
    "implementation plan",
    "plan complete",
    "wrote the plan",
    "create-plan"
  ].any? { |pattern| line.include?(pattern) }
end

def spec_signal?(line)
  [
    "spec written",
    "design approved",
    "design.md",
    "wrote the spec"
  ].any? { |pattern| line.include?(pattern) }
end

def commit_signal?(line)
  [
    "git commit",
    "commit created",
    "created commit",
    "committed."
  ].any? { |pattern| line.include?(pattern) }
end

def code_update_signal?(line)
  [
    "apply_patch",
    "write:",
    "edit:",
    "updated code",
    "implemented",
    "made the change"
  ].any? { |pattern| line.include?(pattern) }
end

def infer_last_completed(read_json, tool, file)
  recent_signal_lines(read_json, tool, file).reverse_each do |line|
    lower = line.to_s.downcase
    next if lower.empty?

    return "cleaned up branch/worktree" if cleanup_signal?(lower)
    return "merged the pull request" if merge_signal?(lower)
    return "opened a pull request" if pr_created_signal?(lower)
    return "ran verification" if verification_signal?(lower)
    return "wrote the implementation plan" if plan_signal?(lower)
    return "wrote the spec" if spec_signal?(lower)
    return "created a commit" if commit_signal?(lower)
    return "updated code" if code_update_signal?(lower)
  end

  "captured recent session progress"
end

def infer_status(read_json, tool, file)
  pr_created = false
  merged = false
  cleanup = false
  blocked = false

  recent_signal_lines(read_json, tool, file).each do |line|
    lower = line.to_s.downcase
    next if lower.empty?

    pr_created ||= pr_created_signal?(lower)
    merged ||= merge_signal?(lower)
    cleanup ||= cleanup_signal?(lower)
    blocked ||= blocked_signal?(lower)
  end

  if pr_created && merged && cleanup
    "done"
  elsif blocked || (pr_created && !merged)
    "blocked"
  else
    "active"
  end
end

def infer_next_step(status, read_json, tool, file, last_completed)
  return "none; session appears complete" if status == "done"
  return "review and merge the pull request" if status == "blocked"

  recent_signal_lines(read_json, tool, file).reverse_each do |line|
    lower = line.to_s.downcase
    next if lower.empty?

    if [
      "open a pr",
      "open the pr",
      "open a pull request",
      "create a pr",
      "create the pr",
      "create a pull request"
    ].any? { |pattern| lower.include?(pattern) }
      return "open a pull request"
    end

    if lower.include?("implement the plan") || lower.include?("next step is to implement the plan")
      return "implement the plan"
    end
  end

  case last_completed
  when "merged the pull request"
    "clean up the branch/worktree"
  when "wrote the spec"
    "write the implementation plan"
  when "wrote the implementation plan"
    "implement the plan"
  else
    "continue the next pending change"
  end
end

def build_resume_command(tool, cwd, session_id)
  quoted_cwd = shell_double_quote(cwd)

  if tool == "Codex"
    %(cd "#{quoted_cwd}" && codex-yolo resume #{session_id})
  else
    %(cd "#{quoted_cwd}" && claude-yolo -r #{session_id})
  end
end

def build_session_hash(tool, read_command, entry, start_epoch, end_epoch)
  file = entry["file"].to_s
  return nil if file.empty? || !File.file?(file)

  updated_epoch = File.mtime(file).to_i
  return nil if updated_epoch < start_epoch || updated_epoch > end_epoch

  read_json = read_session(read_command, file)

  cwd = entry["cwd"].to_s
  cwd = read_json["cwd"].to_s if cwd.empty?

  session_id = entry["sessionId"].to_s
  session_id = entry["id"].to_s if session_id.empty?
  session_id = read_json["session_id"].to_s if session_id.empty?
  session_id = read_json["sessionId"].to_s if session_id.empty?
  session_id = read_json["id"].to_s if session_id.empty?

  git_branch = entry_branch(entry)
  git_branch = read_branch(read_json) if git_branch.empty?

  summary = build_summary(read_json, entry["preview"], tool, file)
  last_completed = infer_last_completed(read_json, tool, file)
  status = infer_status(read_json, tool, file)
  next_step = infer_next_step(status, read_json, tool, file, last_completed)
  repo, worktree = repo_and_worktree_from_cwd(cwd)

  {
    "tool" => tool,
    "session_id" => session_id,
    "updated_epoch" => updated_epoch,
    "updated_at" => Time.at(updated_epoch).localtime.strftime("%Y-%m-%d %H:%M"),
    "cwd" => cwd,
    "repo" => repo,
    "worktree" => worktree,
    "branch" => git_branch,
    "summary" => summary,
    "last_completed" => last_completed,
    "next_step" => next_step,
    "status" => status,
    "resume" => build_resume_command(tool, cwd, session_id),
    "file" => file
  }
end

def render_human_output(entries)
  lines = entries.map do |entry|
    block = []
    block << "[#{entry.fetch("tool")}] #{entry.fetch("session_id")}"
    block << "updated: #{entry.fetch("updated_at")}"
    block << "repo: #{entry.fetch("repo")}"
    block << "worktree: #{entry.fetch("worktree")}" unless entry.fetch("worktree").empty?
    block << "cwd: #{entry.fetch("cwd")}"
    block << "branch: #{entry.fetch("branch")}" unless entry.fetch("branch").empty?
    block << "summary: #{entry.fetch("summary")}"
    block << "last completed: #{entry.fetch("last_completed")}"
    block << "next: #{entry.fetch("next_step")}"
    block << "status: #{entry.fetch("status")}"
    block << "resume: #{entry.fetch("resume")}"
    block.join("\n")
  end

  puts lines.join("\n")
end

window, json_output = parse_args(ARGV.dup)
start_epoch, end_epoch = time_window(window)
days = coarse_days(start_epoch, end_epoch)

entries = []
list_sessions("list-codex-sessions", days).each do |entry|
  next unless entry.is_a?(Hash)

  session = build_session_hash("Codex", "read-codex-session", entry, start_epoch, end_epoch)
  entries << session if session
end

list_sessions("list-claude-sessions", days).each do |entry|
  next unless entry.is_a?(Hash)

  session = build_session_hash("Claude", "read-claude-session", entry, start_epoch, end_epoch)
  entries << session if session
end

entries.sort_by! { |entry| -entry.fetch("updated_epoch") }

if entries.empty?
  if json_output
    puts "[]"
  else
    puts "No agent sessions found in the last #{window}."
  end
  exit 0
end

if json_output
  puts JSON.pretty_generate(entries)
else
  render_human_output(entries)
end

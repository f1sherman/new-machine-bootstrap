#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "tmpdir"

SCRIPT = File.expand_path("hnp", __dir__)

def quote_args(args)
  args.map(&:dump).join(" ")
end

def write_executable(path, body)
  File.write(path, "#!/usr/bin/env ruby\n# frozen_string_literal: true\n#{body}")
  File.chmod(0o755, path)
end

def run_hnp(env, *args)
  Open3.capture3(env, SCRIPT, *args)
end

def assert_equal(name, expected, actual)
  if expected == actual
    puts "PASS  #{name}"
    true
  else
    warn "FAIL  #{name}"
    warn "      expected: #{expected.inspect}"
    warn "      actual:   #{actual.inspect}"
    false
  end
end

if !File.executable?(SCRIPT)
  warn "FAIL  hnp script is not installed in repo at #{SCRIPT}"
  exit 1
end

failures = 0

Dir.mktmpdir do |tmp|
  fake_home = File.join(tmp, "home")
  fake_bin = File.join(tmp, "bin")
  log = File.join(tmp, "commands.log")
  repo = File.join(fake_home, "projects", "home-network-provisioning")
  FileUtils.mkdir_p([fake_bin, repo])

  write_executable(File.join(fake_bin, "tmux"), <<~'RUBY')
    def quote_args(args)
      args.map(&:dump).join(" ")
    end

    File.open(ENV.fetch("HNP_TEST_LOG"), "a") { |file| file.puts("tmux #{quote_args(ARGV)}") }
  RUBY

  write_executable(File.join(fake_bin, "codex"), <<~'RUBY')
    def quote_args(args)
      args.map(&:dump).join(" ")
    end

    File.open(ENV.fetch("HNP_TEST_LOG"), "a") { |file| file.puts("codex #{quote_args(ARGV)}") }
  RUBY

  write_executable(File.join(fake_bin, "ssh"), <<~'RUBY')
    def quote_args(args)
      args.map(&:dump).join(" ")
    end

    File.open(ENV.fetch("HNP_TEST_LOG"), "a") { |file| file.puts("ssh #{quote_args(ARGV)}") }
    exit ENV.fetch("HNP_TEST_SSH_RC", "0").to_i if ARGV.last == "true"
  RUBY

  base_env = {
    "HOME" => fake_home,
    "HNP_TEST_LOG" => log,
    "HNP_DEV_HOST" => "dev",
    "PATH" => "#{fake_bin}:#{ENV.fetch("PATH")}",
    "TMUX" => nil
  }

  FileUtils.rm_f(log)
  stdout, stderr, status = run_hnp(base_env.merge("HNP_HOSTNAME" => "dev"), "resume", "abc123")
  expected = "tmux #{quote_args(["new-session", "-A", "-s", "hnp", "-c", repo, "codex --dangerously-bypass-approvals-and-sandbox resume abc123"])}"
  actual = File.readlines(log, chomp: true).last
  failures += 1 unless status.success? && stdout.empty? && stderr.empty?
  failures += 1 unless assert_equal("dev host outside tmux launches hnp Codex inside tmux", expected, actual)

  FileUtils.rm_f(log)
  stdout, stderr, status = run_hnp(base_env.merge("HNP_HOSTNAME" => "dev", "TMUX" => "/tmp/tmux,1,0"), "resume", "abc123")
  expected = "codex #{quote_args(["--dangerously-bypass-approvals-and-sandbox", "resume", "abc123"])}"
  actual = File.readlines(log, chomp: true).last
  failures += 1 unless status.success? && stdout.empty? && stderr.empty?
  failures += 1 unless assert_equal("dev host inside tmux runs Codex directly", expected, actual)

  FileUtils.rm_f(log)
  stdout, stderr, status = run_hnp(base_env.merge("HNP_HOSTNAME" => "mac"), "resume", "abc123")
  expected = "ssh #{quote_args(["-t", "dev", "hnp resume abc123"])}"
  actual = File.readlines(log, chomp: true).last
  failures += 1 unless status.success? && stdout.empty? && stderr.empty?
  failures += 1 unless assert_equal("non-dev host routes to dev hnp command", expected, actual)
end

exit(failures.zero? ? 0 : 1)

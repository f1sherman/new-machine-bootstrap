#!/usr/bin/env bash
set -euo pipefail

pane_id="${1:-${TMUX_PANE:-}}"
[ -n "$pane_id" ] || exit 0
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
task_label_helper="${TMUX_TASK_LABEL_BIN:-$script_dir/tmux-task-label}"
[ -x "$task_label_helper" ] || task_label_helper="${HOME:-}/.local/bin/tmux-task-label"

pane_info="$(tmux display-message -p -t "$pane_id" '#{window_id}	#{pane_active}	#{window_name}	#{pane_tty}	#{pane_current_path}	#{pane_current_command}	#{pane_title}	#{pane_id}' 2>/dev/null || true)"
[ -n "$pane_info" ] || exit 0

IFS=$'\t' read -r window_id pane_active window_name pane_tty pane_current_path pane_current_command pane_title pane_id <<< "$pane_info"
[ -n "$window_id" ] || exit 0
[ "$pane_active" = "1" ] || exit 0

label="$(tmux show-options -qv -p -t "$pane_id" "@window-label" 2>/dev/null || true)"

is_remote_candidate_command() {
  case "$1" in
    ssh|gh|ruby) return 0 ;;
    *) return 1 ;;
  esac
}

is_structured_remote_label() {
  case "$1" in
    *" | "*) return 0 ;;
    *) return 1 ;;
  esac
}

strip_edge_marker() {
  local title="${1:-}"
  printf '%s\n' "${title% \[nmb-edge=*]}"
}

structured_remote_label() {
  local title="${1:-}" nested_title prefix

  title="$(strip_edge_marker "$title")"
  is_structured_remote_label "$title" || return 1
  nested_title="${title#*: }"
  prefix="${title%%: *}"
  if [ "$nested_title" != "$title" ] && is_structured_remote_label "$nested_title" && {
    [[ "$prefix" =~ ^[0-9]+$ ]] ||
      [[ "$nested_title" == \(* ]] ||
      [[ "$nested_title" == "✓ ("* ]] ||
      [[ "$nested_title" == "~ "* ]]
  }; then
    printf '%s\n' "$nested_title"
  else
    printf '%s\n' "$title"
  fi
}

task_from_remote_label() {
  [ -x "$task_label_helper" ] || return 1
  "$task_label_helper" extract-remote "${1:-}"
}

remote_host_suffix() {
  local title
  title="$(strip_edge_marker "$1")"
  printf '%s\n' "${title##* | }"
}

strip_host_suffix() {
  printf '%s\n' "${1%% | *}"
}

if [ -z "$label" ] && is_remote_candidate_command "$pane_current_command"; then
  label="$(task_from_remote_label "$pane_title" 2>/dev/null || true)"
  if [ -z "$label" ]; then
    structured_window="$(structured_remote_label "$window_name" 2>/dev/null || true)"
    if [ -n "$structured_window" ] && [ "$pane_title" = "$(remote_host_suffix "$structured_window")" ]; then
      label="$(task_from_remote_label "$structured_window" 2>/dev/null || true)"
    fi
  fi
  if [ -z "$label" ]; then
    structured_marker="$(tmux show-options -qv -p -t "$pane_id" "@pane-title-structured" 2>/dev/null || true)"
    cached_pane_label="$(tmux show-options -qv -p -t "$pane_id" "@pane-label" 2>/dev/null || true)"
    if [ -n "$structured_marker" ] && is_structured_remote_label "$cached_pane_label"; then
      label="$(task_from_remote_label "$cached_pane_label" 2>/dev/null || true)"
    fi
  fi
fi

if [ -z "$label" ]; then
  agent_path="$(tmux show-options -qv -p -t "$pane_id" "@agent_worktree_path" 2>/dev/null || true)"
  if [ -n "$agent_path" ]; then
    label="$(tmux show-options -qv -p -t "$pane_id" "@pane-label" 2>/dev/null || true)"
  fi
fi

if [ -z "$label" ]; then
  label_helper="${TMUX_PANE_LABEL_BIN:-$HOME/.local/bin/tmux-pane-label}"
  if [ ! -x "$label_helper" ]; then
    label_helper="tmux-pane-label"
  fi

  label="$("$label_helper" "$pane_tty" "$pane_current_path" "$pane_current_command" "$pane_id" 2>/dev/null || true)"
fi
[ -n "$label" ] || exit 0
if [ -z "$(tmux show-options -qv -p -t "$pane_id" "@window-label" 2>/dev/null || true)" ]; then
  label="$(strip_host_suffix "$label")"
fi
[ -n "$label" ] || exit 0
[ "$label" != "$window_name" ] || exit 0

tmux rename-window -t "$window_id" "$label" 2>/dev/null || true
exit 0

#!/usr/bin/env bash
set -euo pipefail

pane_id="${1:-${TMUX_PANE:-}}"
[ -n "$pane_id" ] || exit 0

pane_info="$(tmux display-message -p -t "$pane_id" '#{window_id}	#{pane_active}	#{window_name}	#{pane_tty}	#{pane_current_path}	#{pane_current_command}	#{pane_title}	#{pane_id}' 2>/dev/null || true)"
[ -n "$pane_info" ] || exit 0

IFS=$'\t' read -r window_id pane_active window_name pane_tty pane_current_path pane_current_command pane_title pane_id <<< "$pane_info"
[ -n "$window_id" ] || exit 0
[ "$pane_active" = "1" ] || exit 0

is_remote_candidate_command() {
  case "$1" in
    ssh|gh|ruby) return 0 ;;
    *) return 1 ;;
  esac
}

is_structured_remote_label() {
  case "$1" in
    *" | "*) return 0 ;;
    *) return 1 ;;
  esac
}

structured_remote_label() {
  local title="${1:-}" nested_title prefix

  is_structured_remote_label "$title" || return 1
  nested_title="${title#*: }"
  prefix="${title%%: *}"
  if [ "$nested_title" != "$title" ] && is_structured_remote_label "$nested_title" && {
    [[ "$prefix" =~ ^[0-9]+$ ]] || [[ "$nested_title" == \(* ]];
  }; then
    printf '%s\n' "$nested_title"
  else
    printf '%s\n' "$title"
  fi
}

remote_host_suffix() {
  printf '%s\n' "${1##* | }"
}

label=""
if is_remote_candidate_command "$pane_current_command"; then
  label="$(structured_remote_label "$pane_title" 2>/dev/null || true)"
  if [ -n "$label" ]; then
    :
  else
    label="$(structured_remote_label "$window_name" 2>/dev/null || true)"
    if [ -n "$label" ] && [ "$pane_title" = "$(remote_host_suffix "$label")" ]; then
      :
    else
      label=""
    fi
  fi
fi

if [ -z "$label" ]; then
  label_helper="${TMUX_PANE_LABEL_BIN:-$HOME/.local/bin/tmux-pane-label}"
  if [ ! -x "$label_helper" ]; then
    label_helper="tmux-pane-label"
  fi

  label="$("$label_helper" "$pane_tty" "$pane_current_path" "$pane_current_command" "$pane_id" 2>/dev/null || true)"
fi
[ -n "$label" ] || exit 0
[ "$label" != "$window_name" ] || exit 0

tmux rename-window -t "$window_id" "$label" 2>/dev/null || true
exit 0

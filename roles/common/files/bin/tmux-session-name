#!/usr/bin/env bash
# Sets the tmux session name based on context:
#   - SSH with nested tmux: use pane_title (set by remote tmux)
#   - Git repo: "(branch) dirname"
#   - Non-git: "dirname"
#
# Optimized for fork cost: replaces basename/git/second display-message with
# pure-bash equivalents, and collapses per-pane ps calls into one multi-tty
# ps. Matters when the system is under load and every fork+exec is slow.

[ -z "$TMUX" ] && exit 0

pane_id="${1:-${TMUX_PANE:-$(tmux display-message -p '#{pane_id}')}}"

# One tmux RPC fetches everything needed from the pane + session.
pane_info=$(tmux display-message -p -t "$pane_id" '#{pane_tty}	#{pane_current_path}	#{pane_title}	#{session_id}	#{session_name}' 2>/dev/null) || exit 0
[ -z "$pane_info" ] && exit 0

IFS=$'\t' read -r pane_tty pane_current_path pane_title session_id current_name <<< "$pane_info"
[ -z "$session_id" ] && exit 0

ssh_pattern='(^ssh |gh (codespace|cs) ssh|devpod ssh)'

# Resolve a git branch by reading .git/HEAD directly — avoids forking `git`,
# which under memory pressure can take hundreds of ms just to start up.
_head_branch() {
  local path="$1" gitdir content head real
  [ -n "$path" ] || return 1
  while [ -n "$path" ] && [ "$path" != "/" ]; do
    if [ -d "$path/.git" ]; then
      gitdir="$path/.git"
      break
    elif [ -f "$path/.git" ]; then
      # Worktree: .git is a file containing "gitdir: /abs/or/rel/path"
      IFS= read -r content < "$path/.git" || return 1
      real="${content#gitdir: }"
      case "$real" in
        /*) gitdir="$real" ;;
        *)  gitdir="$path/$real" ;;
      esac
      break
    fi
    path="${path%/*}"
  done
  [ -n "$gitdir" ] && [ -r "$gitdir/HEAD" ] || return 1
  IFS= read -r head < "$gitdir/HEAD" || return 1
  case "$head" in
    "ref: refs/heads/"*) printf '%s\n' "${head#ref: refs/heads/}"; return 0 ;;
  esac
  return 1
}

pane_procs=$(ps -o args= -t "$pane_tty" 2>/dev/null)
if grep -qE "$ssh_pattern" <<< "$pane_procs"; then
  is_codespace=$(grep -qE 'gh (codespace|cs) ssh' <<< "$pane_procs" && echo 1)
  is_devpod=$(grep -qE 'devpod ssh' <<< "$pane_procs" && echo 1)
  ssh_host=$(grep -E '^ssh ' <<< "$pane_procs" | head -1 | awk '{print $NF}')
  ssh_host="${ssh_host##*@}"
  if [ -n "$pane_title" ] && [ "$pane_title" != "$HOSTNAME" ] && [ "$pane_title" != "$USER@$HOSTNAME" ]; then
    if [ -z "$is_codespace" ] && [ -z "$is_devpod" ] && [ -n "$ssh_host" ]; then
      name="$ssh_host | $pane_title"
    else
      name="$pane_title"
    fi
  else
    name="${ssh_host:-ssh}"
  fi
else
  # Not SSH'd — if another pane in this session IS SSH'd, don't overwrite
  # its name. Collapse N per-pane ps calls into one multi-tty call.
  ps_flags=()
  while IFS= read -r other_tty; do
    [ -n "$other_tty" ] || continue
    [ "$other_tty" = "$pane_tty" ] && continue
    ps_flags+=(-t "$other_tty")
  done <<< "$(tmux list-panes -t "$session_id" -F '#{pane_tty}')"
  if [ "${#ps_flags[@]}" -gt 0 ]; then
    if ps -o args= "${ps_flags[@]}" 2>/dev/null | grep -qE "$ssh_pattern"; then
      exit 0
    fi
  fi

  dir_basename="${pane_current_path##*/}"
  branch=$(_head_branch "$pane_current_path")
  if [ -n "$branch" ]; then
    name="($branch) $dir_basename"
  else
    name="$dir_basename"
  fi

  # Append running program if it's not the shell
  # Uses ps stat flag: "+" means foreground process group
  fg_cmd=$(ps -o stat=,comm= -t "$pane_tty" 2>/dev/null | awk '$1 ~ /\+/ && $2 !~ /^-?(zsh|bash|sh|login)$/ {gsub(/^-/, "", $2); print $2; exit}')
  if [ -n "$fg_cmd" ]; then
    name="$name [$fg_cmd]"
  fi
fi

# Current session_name came back from the atomic display-message above.
if [ "$current_name" = "$name" ] || [[ "$current_name" =~ ^"$name"\ [0-9]+$ ]]; then
  exit 0
fi

# Find an available name: try base name first, then " 2", " 3", etc.
if ! tmux has-session -t "=$name" 2>/dev/null; then
  tmux rename-session -t "$session_id" "$name" 2>/dev/null || true
else
  i=2
  while tmux has-session -t "=$name $i" 2>/dev/null; do
    ((i++))
  done
  tmux rename-session -t "$session_id" "$name $i" 2>/dev/null || true
fi

exit 0

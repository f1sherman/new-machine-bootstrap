#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "open3"
require "shellwords"
require "tmpdir"
require "time"

SCRIPT = File.join(__dir__, "_find-agent-sessions")

def fail_case(message)
  warn "FAIL  #{message}"
  exit 1
end

def pass_case(message)
  puts "PASS  #{message}"
end

def assert_contains(needle, file, label)
  contents = File.read(file)
  if contents.include?(needle)
    pass_case(label)
  else
    warn "FAIL  #{label}"
    warn "missing #{needle.inspect} in #{file}"
    warn contents
    exit 1
  end
end

def assert_not_contains(needle, file, label)
  contents = File.read(file)
  if contents.include?(needle)
    warn "FAIL  #{label}"
    warn "unexpected #{needle.inspect} in #{file}"
    warn contents
    exit 1
  else
    pass_case(label)
  end
end

def assert_before(first, second, file, label)
  first_line = nil
  second_line = nil

  File.readlines(file, chomp: true).each_with_index do |line, index|
    first_line ||= index if line.include?(first)
    second_line ||= index if line.include?(second)
  end

  fail_case("#{label}: missing first marker") if first_line.nil?
  fail_case("#{label}: missing second marker") if second_line.nil?
  fail_case("#{label}: order incorrect") unless first_line < second_line

  pass_case(label)
end

def write_file(path, contents, mode: nil)
  File.write(path, contents)
  File.chmod(mode, path) if mode
end

def bash_stub(body)
  <<~BASH
    #!/usr/bin/env bash
    set -euo pipefail
    #{body}
  BASH
end

def capture!(env, *command)
  stdout, stderr, status = Open3.capture3(env, *command)
  return stdout if status.success?

  warn stdout unless stdout.empty?
  warn stderr unless stderr.empty?
  fail_case("command failed: #{command.join(' ')}")
end

Dir.mktmpdir do |tmproot|
  home = File.join(tmproot, "home")
  bin = File.join(tmproot, "bin")
  FileUtils.mkdir_p(File.join(home, ".claude/projects/test-project"))
  FileUtils.mkdir_p(File.join(home, ".codex/sessions/2026/04/21"))
  FileUtils.mkdir_p(bin)

  now = Time.now
  midnight = Time.local(now.year, now.month, now.day)

  iso_offset = ->(seconds) { (Time.now.utc + seconds).iso8601 }
  touch_offset = lambda do |path, seconds|
    time = Time.now + seconds
    File.utime(time, time, path)
  end
  touch_mode = lambda do |path, mode|
    time = mode == :today ? midnight + 60 : midnight - 60
    File.utime(time, time, path)
  end

  codex_active = File.join(home, ".codex/sessions/2026/04/21/codex-active.jsonl")
  write_file(codex_active, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-3700)}","type":"session_meta","payload":{"id":"codex-active","timestamp":"#{iso_offset.call(-3700)}","cwd":"/tmp/projects/codex-active","git":{"branch":"feature/codex-active"}}}
    {"timestamp":"#{iso_offset.call(-3600)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"fix the session summary helper"}]}}
    {"timestamp":"#{iso_offset.call(-3500)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"bash tests/session-summary.sh\\"}"}}
    {"timestamp":"#{iso_offset.call(-3400)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"Tests pass. Next step is to open a PR."}]}}
  JSONL
  touch_offset.call(codex_active, -3600)

  codex_done = File.join(home, ".codex/sessions/2026/04/21/codex-done.jsonl")
  write_file(codex_done, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-7300)}","type":"session_meta","payload":{"id":"codex-done","timestamp":"#{iso_offset.call(-7300)}","cwd":"/tmp/projects/codex-done","git":{"branch":"feature/codex-done"}}}
    {"timestamp":"#{iso_offset.call(-7200)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"finish the PR workflow"}]}}
    {"timestamp":"#{iso_offset.call(-7100)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"gh pr create --fill\\"}"}}
    {"timestamp":"#{iso_offset.call(-7000)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"PR #77 opened."}]}}
    {"timestamp":"#{iso_offset.call(-6900)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"gh pr merge 77 --squash\\"}"}}
    {"timestamp":"#{iso_offset.call(-6800)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"PR #77 merged."}]}}
    {"timestamp":"#{iso_offset.call(-6700)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"worktree-done\\"}"}}
    {"timestamp":"#{iso_offset.call(-6600)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"Cleanup complete."}]}}
  JSONL
  touch_offset.call(codex_done, -7200)

  claude_blocked = File.join(home, ".claude/projects/test-project/claude-blocked.jsonl")
  write_file(claude_blocked, <<~JSONL)
    {"type":"user","message":{"role":"user","content":"wrap up the PR handoff"},"timestamp":"#{iso_offset.call(-1900)}","cwd":"/tmp/projects/claude-blocked","sessionId":"claude-blocked","version":"2.0.0","gitBranch":"feature/claude-blocked"}
    {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"PR #42 opened. Waiting for review before merge."}]},"timestamp":"#{iso_offset.call(-1800)}","cwd":"/tmp/projects/claude-blocked","sessionId":"claude-blocked","version":"2.0.0","gitBranch":"feature/claude-blocked"}
  JSONL
  touch_offset.call(claude_blocked, -1800)

  claude_yesterday = File.join(home, ".claude/projects/test-project/claude-yesterday.jsonl")
  write_file(claude_yesterday, <<~JSONL)
    {"type":"user","message":{"role":"user","content":"resume the yesterday dashboard cleanup"},"timestamp":"#{iso_offset.call(-90_000)}","cwd":"/tmp/projects/claude-yesterday","sessionId":"claude-yesterday","version":"2.0.0","gitBranch":"feature/claude-yesterday"}
    {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"Wrote the implementation plan. Next step is to implement the plan."}]},"timestamp":"#{iso_offset.call(-89_000)}","cwd":"/tmp/projects/claude-yesterday","sessionId":"claude-yesterday","version":"2.0.0","gitBranch":"feature/claude-yesterday"}
  JSONL
  touch_mode.call(claude_yesterday, :yesterday)

  codex_old = File.join(home, ".codex/sessions/2026/04/18/codex-old.jsonl")
  FileUtils.mkdir_p(File.dirname(codex_old))
  write_file(codex_old, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-260_000)}","type":"session_meta","payload":{"id":"codex-old","timestamp":"#{iso_offset.call(-260_000)}","cwd":"/tmp/projects/codex-old","git":{"branch":"feature/codex-old"}}}
    {"timestamp":"#{iso_offset.call(-259_900)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"stale session"}]}}
  JSONL
  touch_offset.call(codex_old, -260_000)

  write_file(
    File.join(bin, "list-codex-sessions"),
    bash_stub(<<~BASH),
      mode: 0o755
    )
      cat <<'JSON'
      #{JSON.pretty_generate([
        {
          id: "codex-active",
          timestamp: iso_offset.call(-3700),
          cwd: "/tmp/projects/codex-active",
          git: { branch: "feature/codex-active" },
          file: codex_active,
          preview: "# AGENTS.md instructions for /tmp/projects/codex-active",
          index: 1
        },
        {
          id: "codex-done",
          timestamp: iso_offset.call(-7300),
          cwd: "/tmp/projects/codex-done",
          git: { branch: "feature/codex-done" },
          file: codex_done,
          preview: "finish the PR workflow",
          index: 2
        },
        {
          id: "codex-old",
          timestamp: iso_offset.call(-260_000),
          cwd: "/tmp/projects/codex-old",
          git: { branch: "feature/codex-old" },
          file: codex_old,
          preview: "stale session",
          index: 3
        }
      ])}
      JSON
    BASH
  )

  write_file(
    File.join(bin, "list-claude-sessions"),
    bash_stub(<<~BASH),
      mode: 0o755
    )
      cat <<'JSON'
      #{JSON.pretty_generate([
        {
          sessionId: "claude-blocked",
          timestamp: iso_offset.call(-1900),
          cwd: "/tmp/projects/claude-blocked",
          gitBranch: "feature/claude-blocked",
          file: claude_blocked,
          preview: "continue",
          index: 1
        },
        {
          sessionId: "claude-yesterday",
          timestamp: iso_offset.call(-90_000),
          cwd: "/tmp/projects/claude-yesterday",
          gitBranch: "feature/claude-yesterday",
          file: claude_yesterday,
          preview: "resume the yesterday dashboard cleanup",
          index: 2
        }
      ])}
      JSON
    BASH
  )

  write_file(
    File.join(bin, "read-codex-session"),
    bash_stub(<<~BASH),
      mode: 0o755
    )
      file="$1"
      case "$file" in
        #{Shellwords.escape(codex_active)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-active",
            cwd: "/tmp/projects/codex-active",
            timestamp: iso_offset.call(-3700),
            git_branch: "feature/codex-active",
            git_commit: "deadbeef",
            user_messages: [
              "User name: Brian. Work style: telegraph; noun-phrases ok; drop grammar; min tokens.",
              "* Workspace: ~/projects/",
              "--- project-doc ---",
              "  <cwd>/tmp/projects/codex-active</cwd>",
              "# Test Project",
              "Using using-superpowers; start-of-session requirement.",
              "fix the session summary helper"
            ],
            assistant_messages: ["Tests pass. Next step is to open a PR."],
            shell_commands: ["bash tests/session-summary.sh"],
            file_operations: []
          )}
          JSON
          ;;
        #{Shellwords.escape(codex_done)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-done",
            cwd: "/tmp/projects/codex-done",
            timestamp: iso_offset.call(-7300),
            git_branch: "feature/codex-done",
            git_commit: "deadbeef",
            user_messages: ["finish the PR workflow"],
            assistant_messages: ["PR #77 opened.", "PR #77 merged.", "Cleanup complete."],
            shell_commands: ["gh pr create --fill", "gh pr merge 77 --squash", "worktree-done"],
            file_operations: []
          )}
          JSON
          ;;
        #{Shellwords.escape(codex_old)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-old",
            cwd: "/tmp/projects/codex-old",
            timestamp: iso_offset.call(-260_000),
            git_branch: "feature/codex-old",
            git_commit: "deadbeef",
            user_messages: ["stale session"],
            assistant_messages: [],
            shell_commands: [],
            file_operations: []
          )}
          JSON
          ;;
        *)
          exit 1
          ;;
      esac
    BASH
  )

  write_file(
    File.join(bin, "read-claude-session"),
    bash_stub(<<~BASH),
      mode: 0o755
    )
      file="$1"
      case "$file" in
        #{Shellwords.escape(claude_blocked)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "claude-blocked",
            cwd: "/tmp/projects/claude-blocked",
            timestamp: iso_offset.call(-1900),
            git_branch: "feature/claude-blocked",
            claude_code_version: "2.0.0",
            user_messages: ["wrap up the PR handoff"],
            assistant_messages: ["PR #42 opened. Waiting for review before merge."],
            bash_commands: [],
            file_operations: [],
            tool_uses: []
          )}
          JSON
          ;;
        #{Shellwords.escape(claude_yesterday)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "claude-yesterday",
            cwd: "/tmp/projects/claude-yesterday",
            timestamp: iso_offset.call(-90_000),
            git_branch: "feature/claude-yesterday",
            claude_code_version: "2.0.0",
            user_messages: ["resume the yesterday dashboard cleanup"],
            assistant_messages: ["Wrote the implementation plan. Next step is to implement the plan."],
            bash_commands: [],
            file_operations: [],
            tool_uses: []
          )}
          JSON
          ;;
        *)
          exit 1
          ;;
      esac
    BASH
  )

  fail_case("missing helper under test: #{SCRIPT}") unless File.executable?(SCRIPT)

  env = { "PATH" => "#{bin}:#{ENV.fetch('PATH', '')}", "HOME" => home }

  default_stdout = File.join(tmproot, "default.stdout")
  File.write(default_stdout, capture!(env, SCRIPT))

  assert_before("[Claude] claude-blocked", "[Codex] codex-active", default_stdout, "newest blocked session sorts before active")
  assert_before("[Codex] codex-active", "[Codex] codex-done", default_stdout, "active session sorts before older done session")
  assert_contains("status: blocked", default_stdout, "blocked status rendered")
  assert_contains("status: active", default_stdout, "active status rendered")
  assert_contains("status: done", default_stdout, "done status rendered")
  assert_contains("summary: fix the session summary helper", default_stdout, "summary skips AGENTS boilerplate")
  assert_contains("summary: wrap up the PR handoff", default_stdout, "summary skips generic continue preview")
  assert_not_contains("summary: # AGENTS.md instructions", default_stdout, "AGENTS boilerplate omitted from summary")
  assert_not_contains("summary: User name: Brian. Work style: telegraph; noun-phrases ok; drop grammar; min tokens.", default_stdout, "AGENTS profile boilerplate omitted from summary")
  assert_not_contains("summary: * Workspace: ~/projects/", default_stdout, "AGENTS workspace boilerplate omitted from summary")
  assert_not_contains("summary: --- project-doc ---", default_stdout, "project-doc boilerplate omitted from summary")
  assert_not_contains("summary: <cwd>/tmp/projects/codex-active</cwd>", default_stdout, "XML metadata boilerplate omitted from summary")
  assert_not_contains("summary: # Test Project", default_stdout, "markdown heading downgraded from summary")
  assert_not_contains("summary: Using using-superpowers; start-of-session requirement.", default_stdout, "using-superpowers boilerplate omitted from summary")
  assert_contains("last completed: opened a pull request", default_stdout, "blocked session last completed step")
  assert_contains("last completed: ran verification", default_stdout, "active session last completed step")
  assert_contains("last completed: cleaned up branch/worktree", default_stdout, "done session last completed step")
  assert_contains("next: review and merge the pull request", default_stdout, "blocked next step")
  assert_contains("next: open a pull request", default_stdout, "active next step")
  assert_contains("next: none; session appears complete", default_stdout, "done next step")
  assert_contains('resume: cd "/tmp/projects/claude-blocked" && claude-yolo -r claude-blocked', default_stdout, "claude resume command")
  assert_contains('resume: cd "/tmp/projects/codex-active" && codex-yolo resume codex-active', default_stdout, "codex resume command")
  assert_not_contains("codex-old", default_stdout, "default 24h filters stale session")

  two_day_stdout = File.join(tmproot, "two-day.stdout")
  File.write(two_day_stdout, capture!(env, SCRIPT, "2d"))
  assert_contains("claude-yesterday", two_day_stdout, "2d includes yesterday session")

  today_stdout = File.join(tmproot, "today.stdout")
  File.write(today_stdout, capture!(env, SCRIPT, "today"))
  assert_not_contains("claude-yesterday", today_stdout, "today excludes yesterday session")

  yesterday_stdout = File.join(tmproot, "yesterday.stdout")
  File.write(yesterday_stdout, capture!(env, SCRIPT, "yesterday"))
  assert_contains("claude-yesterday", yesterday_stdout, "yesterday includes yesterday session")
  assert_not_contains("claude-blocked", yesterday_stdout, "yesterday excludes today session")
end

#!/usr/bin/env bash
set -u

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
task_label_helper="${TMUX_TASK_LABEL_BIN:-$script_dir/tmux-task-label}"
agent_state_helper="${TMUX_AGENT_STATE_BIN:-$script_dir/tmux-agent-state}"
[ -x "$task_label_helper" ] || task_label_helper="${HOME:-}/.local/bin/tmux-task-label"
[ -x "$agent_state_helper" ] || agent_state_helper="${HOME:-}/.local/bin/tmux-agent-state"

pane_id=""
for candidate in "$@"; do
  if [ -n "$candidate" ]; then
    pane_id="$candidate"
    break
  fi
done

[ -n "$pane_id" ] || exit 0

field_separator='__NMB_TMUX_FIELD__'
parse_separator=$'\x1f'
pane_info="$(tmux display-message -p -t "$pane_id" "#{pane_title}${field_separator}#{pane_current_command}" 2>/dev/null)" || exit 0
pane_info="${pane_info//$field_separator/$parse_separator}"
IFS="$parse_separator" read -r title pane_current_command <<< "$pane_info"
structured="$(tmux show-options -qv -p -t "$pane_id" @pane-title-structured 2>/dev/null || true)"

case "$title" in
  *" | "*)
    tmux set-option -p -q -t "$pane_id" @pane-title-structured 1
    subject="$("$task_label_helper" extract-remote-provisional "$title" 2>/dev/null || true)"
    task_state="$(tmux show-options -qv -p -t "$pane_id" @task_state 2>/dev/null || true)"
    task_source="$(tmux show-options -qv -p -t "$pane_id" @task_source 2>/dev/null || true)"
    if [ -n "$subject" ] && [ "$task_state" = "provisional" ] && [ "$task_source" = "agent" ]; then
      if [ -x "$agent_state_helper" ]; then
        TMUX_PANE="$pane_id" "$agent_state_helper" adopt-remote-provisional "$subject" >/dev/null 2>&1 || true
      fi
      tmux-sync-pane-border-status "$pane_id"
    else
      if [ -z "$task_state$task_source" ]; then
        tmux-sync-remote-title "$pane_id"
      fi
      tmux-sync-pane-border-status "$pane_id"
      tmux-update-pane-label "$pane_id"
    fi
    ;;
  *)
    [ -n "$structured" ] || exit 0
    case "$pane_current_command" in
      ssh|gh|ruby)
        # A foreground remote program can transiently degrade its title to a
        # bare host or spinner. Keep the last structured task identity sticky.
        exit 0
        ;;
    esac
    tmux set-option -p -q -u -t "$pane_id" @pane-title-structured
    tmux-sync-pane-border-status "$pane_id"
    tmux-update-pane-label "$pane_id"
    tmux-window-label "$pane_id"
    ;;
esac

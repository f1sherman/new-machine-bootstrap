#!/usr/bin/env bash
set -u

pane_id=""
for candidate in "$@"; do
  if [ -n "$candidate" ]; then
    pane_id="$candidate"
    break
  fi
done

[ -n "$pane_id" ] || exit 0

field_separator='__NMB_TMUX_FIELD__'
parse_separator=$'\x1f'
pane_info="$(tmux display-message -p -t "$pane_id" "#{pane_title}${field_separator}#{pane_current_command}" 2>/dev/null)" || exit 0
pane_info="${pane_info//$field_separator/$parse_separator}"
IFS="$parse_separator" read -r title pane_current_command <<< "$pane_info"
structured="$(tmux show-options -qv -p -t "$pane_id" @pane-title-structured 2>/dev/null || true)"

case "$title" in
  *" | "*)
    tmux set-option -p -q -t "$pane_id" @pane-title-structured 1
    tmux-sync-remote-title "$pane_id"
    tmux-sync-pane-border-status "$pane_id"
    tmux-update-pane-label "$pane_id"
    ;;
  *)
    [ -n "$structured" ] || exit 0
    case "$pane_current_command" in
      ssh|gh|ruby)
        # A foreground remote program can transiently degrade its title to a
        # bare host or spinner. Keep the last structured task identity sticky.
        exit 0
        ;;
    esac
    tmux set-option -p -q -u -t "$pane_id" @pane-title-structured
    tmux-sync-pane-border-status "$pane_id"
    tmux-update-pane-label "$pane_id"
    tmux-window-label "$pane_id"
    ;;
esac

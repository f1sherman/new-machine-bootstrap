#!/usr/bin/env bash
set -euo pipefail

pane_tty="${1:-}"
pane_current_path="${2:-}"
pane_current_command="${3:-}"
pane_id="${4:-}"

[ -n "$pane_current_path" ] || exit 0

dir_basename() {
  local raw="${1%/}"
  raw="${raw##*/}"
  [ -n "$raw" ] || raw="/"
  printf '%s\n' "$raw"
}

host_tag() {
  if [ -n "${TMUX_PANE_LABEL_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_PANE_LABEL_HOST_TAG"
  elif [ -n "${CODESPACES:-}" ] && [ -n "${CODESPACE_NAME:-}" ]; then
    printf '%s\n' "$CODESPACE_NAME"
  elif [ -n "${DEVPOD_WORKSPACE_ID:-}" ]; then
    printf '%s\n' "$DEVPOD_WORKSPACE_ID"
  else
    hostname -s 2>/dev/null || hostname 2>/dev/null || true
  fi
}

is_remote_candidate_command() {
  case "$1" in
    ssh|gh|ruby) return 0 ;;
    *) return 1 ;;
  esac
}

is_structured_label() {
  case "$1" in
    *" | "*) return 0 ;;
    *) return 1 ;;
  esac
}

structured_label() {
  local title="${1:-}" nested_title prefix

  is_structured_label "$title" || return 1
  nested_title="${title#*: }"
  prefix="${title%%: *}"
  if [ "$nested_title" != "$title" ] && is_structured_label "$nested_title" && {
    [[ "$prefix" =~ ^[0-9]+$ ]] || [[ "$nested_title" == \(* ]];
  }; then
    printf '%s\n' "$nested_title"
  else
    printf '%s\n' "$title"
  fi
}

remote_host_suffix() {
  printf '%s\n' "${1##* | }"
}

if [ -n "$pane_id" ] && is_remote_candidate_command "$pane_current_command"; then
  remote_info="$(tmux display-message -p -t "$pane_id" '#{pane_title}	#{window_name}' 2>/dev/null || true)"
  if [ -n "$remote_info" ]; then
    IFS=$'\t' read -r pane_title window_name <<< "$remote_info"
    remote_label="$(structured_label "$pane_title" 2>/dev/null || true)"
    if [ -n "$remote_label" ]; then
      printf '%s\n' "$remote_label"
      exit 0
    fi
    remote_label="$(structured_label "$window_name" 2>/dev/null || true)"
    if [ -n "$remote_label" ] && [ "$pane_title" = "$(remote_host_suffix "$remote_label")" ]; then
      printf '%s\n' "$remote_label"
      exit 0
    fi
  fi
fi

host="$(host_tag)"
label="$(dir_basename "$pane_current_path")"
if [ -n "$host" ]; then
  printf '%s | %s\n' "$label" "$host"
else
  printf '%s\n' "$label"
fi

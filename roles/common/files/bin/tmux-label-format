#!/usr/bin/env bash
set -euo pipefail

mode="${1:-}"
path="${2:-}"
host="${3:-}"

[ -n "$mode" ] || exit 1
[ -n "$path" ] || exit 1

dir_basename() {
  local raw="${1%/}"
  raw="${raw##*/}"
  [ -n "$raw" ] || raw="/"
  printf '%s\n' "$raw"
}

repo_root() {
  local common_dir top_level

  top_level="$(git -C "$1" rev-parse --path-format=absolute --show-toplevel 2>/dev/null)" || return 1
  common_dir="$(git -C "$1" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  common_dir="${common_dir%/}"

  case "$common_dir" in
    */.git)
      printf '%s\n' "${common_dir%/*}"
      ;;
    *)
      printf '%s\n' "$top_level"
      ;;
  esac
}

repo_basename() {
  local root
  root="$(repo_root "$1")" || return 1
  dir_basename "$root"
}

branch_name() {
  git -C "$1" branch --show-current 2>/dev/null
}

origin_remote_url() {
  git -C "$1" remote get-url origin 2>/dev/null
}

pr_status_cache_dir() {
  printf '%s/.local/state/pr-status\n' "${HOME:-}"
}

pr_status_cache_key() {
  local remote_url="$1"
  local branch="$2"
  local digest

  if command -v sha256sum >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | sha256sum 2>/dev/null | awk '{print $1}')" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  if command -v shasum >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | shasum -a 256 2>/dev/null | awk '{print $1}')" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  if command -v ruby >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | ruby -rdigest -e 'print Digest::SHA256.hexdigest(STDIN.read)' 2>/dev/null)" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  return 1
}

now_epoch() {
  date +%s
}

cached_pr_display_ref() {
  local path="$1"
  local branch="$2"
  local remote_url key cache_file now

  remote_url="$(origin_remote_url "$path")" || return 1
  [ -n "$remote_url" ] || return 1
  [ -n "${HOME:-}" ] || return 1

  key="$(pr_status_cache_key "$remote_url" "$branch")"
  cache_file="$(pr_status_cache_dir)/$key.json"
  [ -r "$cache_file" ] || return 1

  now="$(now_epoch)"
  jq -er \
    --arg remote_url "$remote_url" \
    --arg branch "$branch" \
    --argjson now "$now" '
      select((.remote_url // "") == $remote_url)
      | select((.branch // "") == $branch)
      | select((.state // "") == "open")
      | select(((.expires_at_epoch // 0) | tonumber) > $now)
      | (.display_ref // "")
      | select(test("^(gh|fg)#[0-9]+$"))
    ' "$cache_file" 2>/dev/null
}

dirty_marker() {
  [ -n "$(git --no-optional-locks -C "$1" status --porcelain 2>/dev/null)" ]
}

format_local() {
  local repo branch pr_ref branch_display

  repo="$(repo_basename "$1" 2>/dev/null || true)"
  branch="$(branch_name "$1" || true)"

  if [ -n "$branch" ] && [ -n "$repo" ]; then
    pr_ref="$(cached_pr_display_ref "$1" "$branch" || true)"
    branch_display="$branch"
    if [ -n "$pr_ref" ]; then
      branch_display="$branch_display $pr_ref"
    fi

    if dirty_marker "$1"; then
      printf '(*%s) %s\n' "$branch_display" "$repo"
    else
      printf '(%s) %s\n' "$branch_display" "$repo"
    fi
    return 0
  fi

  if [ -n "$repo" ]; then
    printf '%s\n' "$repo"
    return 0
  fi

  dir_basename "$1"
}

format_remote() {
  local base

  base="$(repo_basename "$1" 2>/dev/null || true)"
  [ -n "$base" ] || base="$(dir_basename "$1")"
  if [ -n "$2" ]; then
    printf '%s | %s\n' "$base" "$2"
  else
    printf '%s\n' "$base"
  fi
}

format_remote_explicit() {
  local base

  base="$(format_local "$1")"
  if [ -n "$2" ]; then
    printf '%s | %s\n' "$base" "$2"
  else
    printf '%s\n' "$base"
  fi
}

case "$mode" in
  local)
    format_local "$path"
    ;;
  remote)
    format_remote "$path" "$host"
    ;;
  remote-explicit)
    format_remote_explicit "$path" "$host"
    ;;
  *)
    exit 1
    ;;
esac

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/codex-remind-repo-start-on-dev-prompt"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

GIT_AUTHOR_NAME=test
GIT_AUTHOR_EMAIL=test@example.com
GIT_COMMITTER_NAME=test
GIT_COMMITTER_EMAIL=test@example.com
export GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL

make_repo() {
  local path="$1" branch="$2"
  git -c init.templateDir= init -qb main "$path" >/dev/null
  git -C "$path" commit -q --allow-empty -m init
  if [ "$branch" != "main" ]; then
    git -C "$path" checkout -q -b "$branch"
  fi
}

run_reminder_case() {
  local name="$1" prompt="$2" branch="$3"
  local repo="$TMPROOT/$name"
  make_repo "$repo" "$branch"

  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$repo" && printf '%s' "$payload" | "$SCRIPT")"

  if printf '%s' "$output" | jq -e '
      .hookSpecificOutput.hookEventName == "UserPromptSubmit"
      and (.hookSpecificOutput.additionalContext | contains("repo-start <branch>"))
      and (.hookSpecificOutput.additionalContext | contains("branch or worktree"))
    ' >/dev/null 2>&1; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_case() {
  local name="$1" prompt="$2" branch="$3"
  local repo="$TMPROOT/$name"
  make_repo "$repo" "$branch"

  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$repo" && printf '%s' "$payload" | "$SCRIPT")"

  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_no_repo() {
  local name="$1" prompt="$2"
  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$TMPROOT" && printf '%s' "$payload" | "$SCRIPT")"

  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_payload() {
  local name="$1" payload="$2"
  local output
  output="$(printf '%s' "$payload" | "$SCRIPT")"

  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_reminder_case "reminds for add prompt on main" "please add the Codex side" "main"
run_reminder_case "reminds for fix prompt on main" "fix the failing test" "main"
run_reminder_case "reminds for review feedback prompt on main" "address the PR feedback" "main"
run_reminder_case "reminds for let's prompt on main" "sounds good, let's implement it" "main"
run_silent_case "silent for question on main" "what is the best way to do this?" "main"
run_silent_case "silent for add prompt on feature branch" "please add the Codex side" "feature/codex"
run_silent_no_repo "silent outside git repo" "please add the Codex side"
run_silent_payload "silent for empty payload" '{}'
run_silent_payload "silent for missing prompt" '{"tool_name":"Bash"}'

printf 'PASS  codex repo-start prompt reminder test suite\n'

#!/usr/bin/env python3

import fcntl
import os
import subprocess
import tempfile
from pathlib import Path


def tmux(*args):
    try:
        return subprocess.run(
            ["tmux", *args],
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except OSError:
        return None


def reconcile():
    managed_bars = tmux("show-options", "-gv", "@managed-bars")
    if managed_bars is not None and managed_bars.stdout.strip() == "off":
        return

    sessions = tmux("list-sessions", "-F", "#{session_id}")
    if sessions is None:
        return

    for session_id in sessions.stdout.splitlines():
        if not session_id:
            continue

        clients = tmux(
            "list-clients",
            "-t",
            session_id,
            "-F",
            "#{client_termname}",
        )
        if clients is None or clients.returncode != 0:
            continue

        client_terms = clients.stdout.splitlines()
        nested_only = bool(client_terms) and all(
            term.startswith(("tmux", "screen")) for term in client_terms
        )
        status = "off" if nested_only else "on"
        tmux("set-option", "-q", "-t", session_id, "status", status)


def main():
    server = tmux("display-message", "-p", "#{pid}")
    if server is None or server.returncode != 0:
        return 0

    server_pid = server.stdout.strip()
    if not server_pid.isdecimal():
        return 0

    lock_path = Path(tempfile.gettempdir()) / (
        f"tmux-reconcile-status-bars-{os.getuid()}-{server_pid}.lock"
    )
    flags = os.O_CREAT | os.O_RDWR | os.O_CLOEXEC
    if hasattr(os, "O_NOFOLLOW"):
        flags |= os.O_NOFOLLOW

    try:
        lock_fd = os.open(lock_path, flags, 0o600)
    except OSError:
        return 0

    with os.fdopen(lock_fd, "w") as lock_file:
        try:
            fcntl.flock(lock_file, fcntl.LOCK_EX)
        except OSError:
            return 0
        reconcile()

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

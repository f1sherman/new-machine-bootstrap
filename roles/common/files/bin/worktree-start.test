#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/worktree-start"
TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

fail() {
  printf 'FAIL  %s\n' "$1" >&2
  exit 1
}

require_file() {
  local path="$1"
  [ -f "$path" ] || fail "missing expected file: $path"
}

require_contains() {
  local needle="$1"
  local file="$2"

  grep -Fqx "$needle" "$file" || {
    printf 'missing %q in %s\n' "$needle" "$file" >&2
    cat "$file" >&2
    exit 1
  }
}

export GIT_AUTHOR_NAME=test
export GIT_AUTHOR_EMAIL=test@example.com
export GIT_COMMITTER_NAME=test
export GIT_COMMITTER_EMAIL=test@example.com

repo="$TMPROOT/repo"
mkdir -p "$repo"
git init -q "$repo"
repo_real="$(cd "$repo" && pwd -P)"
tmproot_real="$(cd "$TMPROOT" && pwd -P)"

printf 'base\n' > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m base
base_commit="$(git -C "$repo" rev-parse HEAD)"

mkdir -p "$repo/.coding-agent/nested" "$repo/.claude"
printf 'keep me\n' > "$repo/.coding-agent/nested/note.txt"
printf '{ "scope": "repo" }\n' > "$repo/.claude/settings.local.json"

printf 'next\n' > "$repo/file.txt"
git -C "$repo" commit -q -am next

fake_bin="$TMPROOT/bin"
mkdir -p "$fake_bin"

trust_log="$TMPROOT/claude-trust.log"
mise_log="$TMPROOT/mise.log"

cat > "$fake_bin/claude-trust-directory" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >> "$TRUST_LOG"
EOF

cat > "$fake_bin/mise" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >> "$MISE_LOG"
EOF

chmod +x "$fake_bin/claude-trust-directory" "$fake_bin/mise"

custom_path="$tmproot_real/custom-worktree"
expected_custom_output="$custom_path"
actual_custom_output="$(
  (
    cd "$repo"
    PATH="$fake_bin:$PATH" \
    TRUST_LOG="$trust_log" \
    MISE_LOG="$mise_log" \
    HOME="$TMPROOT/home" \
    "$SCRIPT" --branch feature/alpha --path "$custom_path" --from HEAD~1 --print-path
  )
)"

[ "$actual_custom_output" = "$expected_custom_output" ] || fail "custom-path invocation printed unexpected output"

require_file "$custom_path/file.txt"
[ "$(git -C "$custom_path" rev-parse HEAD)" = "$base_commit" ] || fail "custom-path worktree checked out the wrong commit"
require_file "$custom_path/.coding-agent/nested/note.txt"
require_file "$custom_path/.claude/settings.local.json"
require_contains "$custom_path" "$trust_log"
require_contains "trust $custom_path" "$mise_log"

default_path="$tmproot_real/repo-feature-beta"
actual_default_output="$(
  (
    cd "$repo"
    PATH="$fake_bin:$PATH" \
    TRUST_LOG="$trust_log" \
    MISE_LOG="$mise_log" \
    HOME="$TMPROOT/home" \
    "$SCRIPT" feature/beta --print-path
  )
)"

[ "$actual_default_output" = "$default_path" ] || fail "positional invocation printed unexpected path"
require_file "$default_path/file.txt"
require_file "$default_path/.coding-agent/nested/note.txt"
require_file "$default_path/.claude/settings.local.json"
require_contains "$default_path" "$trust_log"
require_contains "trust $default_path" "$mise_log"

printf 'PASS  worktree-start smoke test\n'

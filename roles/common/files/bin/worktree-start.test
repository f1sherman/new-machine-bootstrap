#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/worktree-start"
TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

fail() {
  printf 'FAIL  %s\n' "$1" >&2
  exit 1
}

assert_eq() {
  local expected="$1"
  local actual="$2"
  local label="$3"

  [ "$actual" = "$expected" ] || fail "$label: expected '$expected', got '$actual'"
}

assert_file() {
  local path="$1"

  [ -f "$path" ] || fail "missing expected file: $path"
}

assert_dir() {
  local path="$1"

  [ -d "$path" ] || fail "missing expected directory: $path"
}

assert_contains() {
  local needle="$1"
  local file="$2"

  grep -Fqx "$needle" "$file" || {
    printf 'missing %q in %s\n' "$needle" "$file" >&2
    cat "$file" >&2
    exit 1
  }
}

assert_empty() {
  local file="$1"

  [ ! -s "$file" ] || {
    printf 'expected empty stderr, got:\n' >&2
    cat "$file" >&2
    exit 1
  }
}

assert_json_eq() {
  local expected="$1"
  local actual_file="$2"
  local actual_json expected_json

  if ! actual_json="$(jq -cS . <"$actual_file")"; then
    printf 'invalid JSON output:\n' >&2
    cat "$actual_file" >&2
    exit 1
  fi

  expected_json="$(printf '%s' "$expected" | jq -cS .)"
  assert_eq "$expected_json" "$actual_json" "json output"
}

run_worktree_start() {
  local stdout_file="$1"
  local stderr_file="$2"
  shift 2

  (
    cd "$repo"
    PATH="$fake_bin:$PATH" \
    TRUST_LOG="$trust_log" \
    MISE_LOG="$mise_log" \
    TMUX_LOG="$tmux_log" \
    HOME="$TMPROOT/home" \
    "$SCRIPT" "$@"
  ) >"$stdout_file" 2>"$stderr_file"
}

export GIT_AUTHOR_NAME=test
export GIT_AUTHOR_EMAIL=test@example.com
export GIT_COMMITTER_NAME=test
export GIT_COMMITTER_EMAIL=test@example.com

repo="$TMPROOT/repo"
mkdir -p "$repo"
git init -q "$repo"
repo_real="$(cd "$repo" && pwd -P)"
tmproot_real="$(cd "$TMPROOT" && pwd -P)"

printf 'base\n' > "$repo/file.txt"
git -C "$repo" add file.txt
git -C "$repo" commit -q -m base

mkdir -p "$repo/.coding-agent/nested" "$repo/.claude"
printf 'keep me\n' > "$repo/.coding-agent/nested/note.txt"
printf '{ "scope": "repo" }\n' > "$repo/.claude/settings.local.json"
printf '# local repo ignores\n' > "$repo/.gitignore"

printf 'next\n' > "$repo/file.txt"
git -C "$repo" commit -q -am next

fake_bin="$TMPROOT/bin"
mkdir -p "$fake_bin"

trust_log="$TMPROOT/trust.log"
mise_log="$TMPROOT/mise.log"
tmux_log="$TMPROOT/tmux.log"
: >"$trust_log"
: >"$mise_log"
: >"$tmux_log"

mkdir -p "$TMPROOT/home/.claude"

cat > "$fake_bin/claude-trust-directory" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >> "$TRUST_LOG"
EOF

cat > "$fake_bin/mise" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >> "$MISE_LOG"
EOF

cat > "$fake_bin/tmux-agent-worktree" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
printf '%s\n' "$*" >> "$TMUX_LOG"
if [ "${TMUX_SET_EXIT_CODE:-0}" -ne 0 ]; then
  exit "$TMUX_SET_EXIT_CODE"
fi
EOF

chmod +x "$fake_bin/claude-trust-directory" "$fake_bin/mise" "$fake_bin/tmux-agent-worktree"

default_path="$repo_real/.worktrees/feature-beta"
default_stdout="$TMPROOT/default.stdout"
default_stderr="$TMPROOT/default.stderr"
if run_worktree_start "$default_stdout" "$default_stderr" feature/beta --print-path; then
  :
else
  status=$?
  printf 'default run exited %s\n' "$status" >&2
  cat "$default_stderr" >&2
  exit "$status"
fi

assert_eq "$default_path" "$(cat "$default_stdout")" "default stdout"
assert_empty "$default_stderr"
assert_dir "$default_path"
assert_file "$default_path/file.txt"
assert_file "$default_path/.coding-agent/nested/note.txt"
assert_file "$default_path/.claude/settings.local.json"
assert_contains ".worktrees/" "$repo/.gitignore"
assert_contains "$default_path" "$trust_log"
assert_contains "trust $default_path" "$mise_log"

print_path_stdout="$TMPROOT/print-path.stdout"
print_path_stderr="$TMPROOT/print-path.stderr"
if run_worktree_start "$print_path_stdout" "$print_path_stderr" feature/beta --print-path; then
  :
else
  status=$?
  printf 'print-path rerun exited %s\n' "$status" >&2
  cat "$print_path_stderr" >&2
  exit "$status"
fi

assert_eq "$default_path" "$(cat "$print_path_stdout")" "--print-path stdout"
assert_empty "$print_path_stderr"

json_stdout="$TMPROOT/json.stdout"
json_stderr="$TMPROOT/json.stderr"
json_path="$repo_real/.worktrees/feature-json"
if run_worktree_start "$json_stdout" "$json_stderr" --branch feature/json --json; then
  :
else
  status=$?
  printf 'json run exited %s\n' "$status" >&2
  cat "$json_stderr" >&2
  exit "$status"
fi

assert_empty "$json_stderr"
assert_json_eq "$(jq -nc --arg path "$json_path" '{status:"created", branch:"feature/json", path:$path, repaired:false}')" "$json_stdout"

conflict_stdout="$TMPROOT/conflict.stdout"
conflict_stderr="$TMPROOT/conflict.stderr"
conflict_branch="feature/conflict"
conflict_existing_path="$repo_real/.worktrees/feature-conflict"
conflict_other_path="$tmproot_real/conflicting-path"
if run_worktree_start "$conflict_stdout" "$conflict_stderr" --branch "$conflict_branch" --path "$conflict_existing_path" --print-path; then
  :
else
  status=$?
  printf 'conflict seed exited %s\n' "$status" >&2
  cat "$conflict_stderr" >&2
  exit "$status"
fi

git -C "$repo" update-ref -d "refs/heads/$conflict_branch"

if run_worktree_start "$conflict_stdout" "$conflict_stderr" --branch "$conflict_branch" --path "$conflict_other_path" --print-path; then
  fail "conflicting explicit --path unexpectedly succeeded"
else
  status=$?
  assert_contains "disagreement with existing linked worktree path" "$conflict_stderr"
  assert_contains "$conflict_existing_path" "$conflict_stderr"
fi

stale_path="$repo_real/.worktrees/feature-stale"
stale_stdout="$TMPROOT/stale.stdout"
stale_stderr="$TMPROOT/stale.stderr"
stale_branch="feature/stale"
if run_worktree_start "$stale_stdout" "$stale_stderr" --branch "$stale_branch" --path "$stale_path" --print-path; then
  :
else
  status=$?
  printf 'stale initial create exited %s\n' "$status" >&2
  cat "$stale_stderr" >&2
  exit "$status"
fi

git -C "$repo" update-ref -d "refs/heads/$stale_branch"

rm -rf "$stale_path"

if run_worktree_start "$stale_stdout" "$stale_stderr" --branch "$stale_branch" --path "$stale_path" --print-path; then
  :
else
  status=$?
  printf 'stale rerun exited %s\n' "$status" >&2
  cat "$stale_stderr" >&2
  exit "$status"
fi

assert_dir "$stale_path"
assert_file "$stale_path/file.txt"
assert_eq "$stale_path" "$(cat "$stale_stdout")" "stale rerun stdout"
assert_empty "$stale_stderr"

tmux_path="$repo_real/.worktrees/feature-tmux"
tmux_stdout="$TMPROOT/tmux.stdout"
tmux_stderr="$TMPROOT/tmux.stderr"
if TMUX=1 TMUX_PANE=%1 run_worktree_start "$tmux_stdout" "$tmux_stderr" --branch feature/tmux --print-path; then
  :
else
  status=$?
  printf 'tmux publish exited %s\n' "$status" >&2
  cat "$tmux_stderr" >&2
  exit "$status"
fi

assert_contains "set $tmux_path" "$tmux_log"
assert_eq "$tmux_path" "$(cat "$tmux_stdout")" "tmux stdout"
assert_empty "$tmux_stderr"

tmux_fail_stdout="$TMPROOT/tmux-fail.stdout"
tmux_fail_stderr="$TMPROOT/tmux-fail.stderr"
if TMUX=1 TMUX_PANE=%1 TMUX_SET_EXIT_CODE=23 run_worktree_start "$tmux_fail_stdout" "$tmux_fail_stderr" --branch feature/tmux-fail --print-path; then
  fail "tmux failure unexpectedly succeeded"
fi

assert_contains "tmux publish failed" "$tmux_fail_stderr"
assert_contains "$repo_real/.worktrees/feature-tmux-fail" "$tmux_fail_stderr"

printf 'PASS  worktree-start regression test\n'

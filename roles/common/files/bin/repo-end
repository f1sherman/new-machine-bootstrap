#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=roles/common/files/bin/repo-lib.sh
source "$SCRIPT_DIR/repo-lib.sh"

usage() {
  cat <<'EOF'
Usage: repo-end [--print-path]
EOF
}

print_path="false"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --print-path)
      print_path="true"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -* )
      printf 'Error: unknown option: %s\n' "$1" >&2
      exit 1
      ;;
    *)
      printf 'Error: unexpected argument: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

run_repo_end_callbacks() {
  local phase="$1"
  local callback_dir="$HOME/.local/bin/repo-end.d"
  local callback
  local callback_timeout_seconds

  [[ -d "$callback_dir" ]] || return 0

  callback_timeout_seconds="$(repo_end_callback_timeout_seconds)" || return 1
  for callback in "$callback_dir"/*; do
    [[ -f "$callback" && -x "$callback" ]] || continue
    if ! run_repo_end_callback "$callback" "$callback_timeout_seconds" "$phase"; then
      printf 'repo-end callback failed: %s\n' "$callback" >&2
      return 1
    fi
  done
}

repo_end_callback_timeout_seconds() {
  local value="${REPO_END_CALLBACK_TIMEOUT_SECONDS:-30}"

  case "$value" in
    ""|*[!0-9]*)
      printf 'Error: REPO_END_CALLBACK_TIMEOUT_SECONDS must be a positive integer\n' >&2
      return 1
      ;;
  esac

  if [[ "$value" -lt 1 ]]; then
    printf 'Error: REPO_END_CALLBACK_TIMEOUT_SECONDS must be a positive integer\n' >&2
    return 1
  fi

  printf '%s\n' "$value"
}

repo_end_active_callback_pid=""
repo_end_active_watchdog_pid=""
repo_end_background_pid=""

repo_end_signal_process_group() {
  local signal="$1"
  local pid="${2:-}"

  [[ -n "$pid" ]] || return 0
  kill -s "$signal" -- "-$pid" 2>/dev/null || kill -s "$signal" "$pid" 2>/dev/null || true
}

repo_end_cleanup_active_callback() {
  local callback_pid="${repo_end_active_callback_pid:-}"
  local watchdog_pid="${repo_end_active_watchdog_pid:-}"

  if [[ -n "$watchdog_pid" ]]; then
    repo_end_signal_process_group TERM "$watchdog_pid"
  fi
  if [[ -n "$callback_pid" ]]; then
    repo_end_signal_process_group TERM "$callback_pid"
    sleep 1
    repo_end_signal_process_group KILL "$callback_pid"
  fi
}

repo_end_abort_active_callback() {
  local exit_code="$1"

  repo_end_cleanup_active_callback
  exit "$exit_code"
}

repo_end_start_background_group() {
  local monitor_was_on

  case "$-" in
    *m*) monitor_was_on="true" ;;
    *) monitor_was_on="false" ;;
  esac
  set -m
  "$@" &
  repo_end_background_pid=$!
  if [[ "$monitor_was_on" != "true" ]]; then
    set +m
  fi
}

repo_end_timeout_watchdog() {
  local callback_pid="$1"
  local timeout_seconds="$2"
  local timeout_marker="$3"

  sleep "$timeout_seconds"
  if kill -0 "$callback_pid" 2>/dev/null; then
    printf 'timed out\n' >"$timeout_marker"
    repo_end_signal_process_group TERM "$callback_pid"
    sleep 1
    repo_end_signal_process_group KILL "$callback_pid"
  fi
}

run_repo_end_callback() {
  local callback="$1"
  local timeout_seconds="$2"
  local phase="$3"
  local timeout_marker callback_pid watchdog_pid status errexit_was_on

  case "$-" in
    *e*) errexit_was_on="true" ;;
    *) errexit_was_on="false" ;;
  esac

  timeout_marker="$("$(_worktree_cmd mktemp)" "${TMPDIR:-/tmp}/repo-end-callback-timeout.XXXXXX")" || return 1

  repo_end_start_background_group "$callback" \
    --phase "$phase" \
    --repo-dir "$repo_root" \
    --branch "$current_branch" \
    --main-branch "$main_branch" \
    --main-path "$main_path"
  callback_pid="$repo_end_background_pid"
  repo_end_active_callback_pid="$callback_pid"

  repo_end_start_background_group repo_end_timeout_watchdog "$callback_pid" "$timeout_seconds" "$timeout_marker"
  watchdog_pid="$repo_end_background_pid"
  repo_end_active_watchdog_pid="$watchdog_pid"

  set +e
  wait "$callback_pid"
  status=$?
  if [[ "$errexit_was_on" == "true" ]]; then
    set -e
  else
    set +e
  fi

  if [[ -s "$timeout_marker" ]]; then
    wait "$watchdog_pid" 2>/dev/null || true
    repo_end_active_callback_pid=""
    repo_end_active_watchdog_pid=""
    rm -f "$timeout_marker"
    printf 'repo-end callback timed out after %ss: %s\n' "$timeout_seconds" "$callback" >&2
    if [[ "$phase" == "merge-proof" ]]; then
      return 2
    fi
    return 0
  fi

  repo_end_signal_process_group TERM "$watchdog_pid"
  wait "$watchdog_pid" 2>/dev/null || true

  repo_end_active_callback_pid=""
  repo_end_active_watchdog_pid=""
  rm -f "$timeout_marker"
  return "$status"
}

run_repo_end_merge_proof_callbacks() {
  local callback_dir="$HOME/.local/bin/repo-end.d"
  local callback callback_timeout_seconds status errexit_was_on

  case "$-" in
    *e*) errexit_was_on="true" ;;
    *) errexit_was_on="false" ;;
  esac

  [[ -d "$callback_dir" ]] || return 1
  callback_timeout_seconds="$(repo_end_callback_timeout_seconds)" || return 2

  for callback in "$callback_dir"/*; do
    [[ -f "$callback" && -x "$callback" ]] || continue
    set +e
    run_repo_end_callback "$callback" "$callback_timeout_seconds" "merge-proof"
    status=$?
    if [[ "$errexit_was_on" == "true" ]]; then
      set -e
    else
      set +e
    fi
    case "$status" in
      0) return 0 ;;
      1) ;;
      *)
        printf 'repo-end merge-proof callback failed: %s\n' "$callback" >&2
        return "$status"
        ;;
    esac
  done

  return 1
}

trap 'repo_end_cleanup_active_callback' EXIT
trap 'repo_end_abort_active_callback 130' INT
trap 'repo_end_abort_active_callback 143' TERM

clear_repo_tmux_state() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || return 0
  command -v tmux-agent-worktree >/dev/null 2>&1 || return 0
  tmux-agent-worktree clear >/dev/null 2>&1 || true
}

complete_repo_tmux_state() {
  [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]] || return 0
  command -v tmux-agent-worktree >/dev/null 2>&1 || return 0
  tmux-agent-worktree complete >/dev/null 2>&1 || true
}

repo_root="$(_worktree_repo_root)" || {
  printf 'Error: not inside a git repository\n' >&2
  exit 1
}
if [[ -z "$repo_root" ]]; then
  printf 'Error: not inside a git repository\n' >&2
  exit 1
fi

current_branch="$($(_worktree_cmd git) -C "$repo_root" branch --show-current)"
if [[ -z "$current_branch" ]]; then
  printf 'Error: detached HEAD; checkout a branch first\n' >&2
  exit 1
fi

main_branch="$(_worktree_main_branch)"
already_on_main="false"
if [[ "$current_branch" == "$main_branch" ]]; then
  already_on_main="true"
fi

if [[ -n "$(_repo_status_excluding_config "$repo_root")" ]]; then
  printf 'Error: worktree has uncommitted changes\n' >&2
  exit 1
fi

if ! "$(_worktree_cmd git)" -C "$repo_root" fetch -q --prune origin; then
  printf 'Error: failed to fetch origin; refusing to clean up with stale remote refs\n' >&2
  exit 1
fi

already_merged() {
  local work_dir="${1:-$repo_root}"
  local ref="${2:-HEAD}"
  local git_cmd
  git_cmd="$(_worktree_cmd git)"
  # Direct ancestor: every commit on the ref is already in origin/<main>.
  if "$git_cmd" -C "$work_dir" merge-base --is-ancestor "$ref" "origin/${main_branch}" 2>/dev/null; then
    return 0
  fi
  # Squash/current-state equivalence: if a synthetic merge of the ref into the
  # current origin/<main> tree is identical to origin/<main>, the feature's net
  # effect is already present. Reverted historical patches fail this check.
  local merge_tree main_tree
  if merge_tree="$("$git_cmd" -C "$work_dir" merge-tree --write-tree "origin/${main_branch}" "$ref" 2>/dev/null)"; then
    main_tree="$("$git_cmd" -C "$work_dir" rev-parse "origin/${main_branch}^{tree}" 2>/dev/null || true)"
    [[ -n "$merge_tree" ]] || return 1
    [[ -n "$main_tree" && "$merge_tree" == "$main_tree" ]]
    return $?
  fi
  squash_patch_previously_applied "$git_cmd" "$work_dir" "$ref"
}

squash_patch_previously_applied() {
  local git_cmd="$1"
  local work_dir="${2:-$repo_root}"
  local ref="${3:-HEAD}"
  local base branch_patch reverse_patch commit patch matched

  base="$("$git_cmd" -C "$work_dir" merge-base "origin/${main_branch}" "$ref" 2>/dev/null || true)"
  [[ -n "$base" ]] || return 1

  branch_patch="$("$git_cmd" -C "$work_dir" diff "$base" "$ref" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
  [[ -n "$branch_patch" ]] || return 1
  reverse_patch="$("$git_cmd" -C "$work_dir" diff "$ref" "$base" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
  [[ -n "$reverse_patch" ]] || return 1

  matched=false
  while IFS= read -r commit; do
    patch="$("$git_cmd" -C "$work_dir" show --pretty=format: "$commit" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
    [[ -n "$patch" ]] || continue
    if [[ "$matched" == "true" && "$patch" == "$reverse_patch" ]]; then
      return 1
    fi
    if [[ "$patch" == "$branch_patch" ]]; then
      matched=true
    fi
  done < <("$git_cmd" -C "$work_dir" rev-list --reverse "${base}..origin/${main_branch}")

  if [[ "$matched" == "true" ]]; then
    return 0
  fi

  split_patch_previously_applied "$git_cmd" "$work_dir" "$base" "$ref"
}

split_patch_previously_applied() {
  local git_cmd="$1"
  local work_dir="$2"
  local base="$3"
  local ref="$4"
  local main_commits=() main_patches=() branch_patches=() branch_reverse_patches=() main_commit branch_commit
  local patch reverse_patch branch_reverse_patch search_from sequence_from match_index i j candidate_reversed sequence_reversed sequence_ok

  while IFS= read -r main_commit; do
    main_commits+=("$main_commit")
  done < <("$git_cmd" -C "$work_dir" rev-list --reverse "${base}..origin/${main_branch}")
  [[ "${#main_commits[@]}" -gt 0 ]] || return 1

  for main_commit in "${main_commits[@]}"; do
    main_patches+=("$("$git_cmd" -C "$work_dir" show --pretty=format: "$main_commit" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')")
  done

  branch_reverse_patch="$("$git_cmd" -C "$work_dir" diff "$ref" "$base" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
  [[ -n "$branch_reverse_patch" ]] || return 1

  while IFS= read -r branch_commit; do
    patch="$("$git_cmd" -C "$work_dir" show --pretty=format: "$branch_commit" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
    [[ -n "$patch" ]] || continue
    reverse_patch="$("$git_cmd" -C "$work_dir" diff "$branch_commit" "${branch_commit}^" | "$git_cmd" -C "$work_dir" patch-id --stable | awk 'NR == 1 {print $1}')"
    [[ -n "$reverse_patch" ]] || return 1
    branch_patches+=("$patch")
    branch_reverse_patches+=("$reverse_patch")
  done < <("$git_cmd" -C "$work_dir" rev-list --reverse "${base}..${ref}")
  [[ "${#branch_patches[@]}" -gt 0 ]] || return 1

  search_from=0
  while [[ "$search_from" -lt "${#main_patches[@]}" ]]; do
    sequence_from="$search_from"
    sequence_ok=true

    for ((i = 0; i < ${#branch_patches[@]}; i++)); do
      patch="${branch_patches[$i]}"
      reverse_patch="${branch_reverse_patches[$i]}"
      match_index=-1

      for ((j = sequence_from; j < ${#main_patches[@]}; j++)); do
        [[ "${main_patches[$j]}" == "$patch" ]] || continue

        candidate_reversed=false
        for ((match_index = j + 1; match_index < ${#main_patches[@]}; match_index++)); do
          [[ "${main_patches[$match_index]}" == "$patch" ]] && break
          if [[ "${main_patches[$match_index]}" == "$reverse_patch" ]]; then
            candidate_reversed=true
            break
          fi
        done
        [[ "$candidate_reversed" == "true" ]] && continue

        match_index="$j"
        break
      done

      if [[ "$match_index" -lt 0 ]]; then
        sequence_ok=false
        break
      fi
      sequence_from=$((match_index + 1))
    done

    [[ "$sequence_ok" == "true" ]] || return 1

    sequence_reversed=false
    for ((i = sequence_from; i < ${#main_patches[@]}; i++)); do
      if [[ "${main_patches[$i]}" == "$branch_reverse_patch" ]]; then
        search_from=$((i + 1))
        sequence_reversed=true
        break
      fi
    done
    [[ "$sequence_reversed" == "true" ]] && continue

    return 0
  done

  return 1
}

prune_merged_local_branches() {
  local git_cmd branch worktreepath
  git_cmd="$(_worktree_cmd git)"

  while IFS=$'\t' read -r branch worktreepath; do
    [[ -n "$branch" ]] || continue
    [[ "$branch" != "$main_branch" ]] || continue
    [[ -z "$worktreepath" ]] || continue
    if already_merged "$main_path" "refs/heads/$branch"; then
      if "$git_cmd" -C "$main_path" branch -D "$branch" >/dev/null 2>&1; then
        printf 'Pruned merged local branch: %s\n' "$branch" >&2
      fi
    fi
  done < <("$git_cmd" -C "$main_path" for-each-ref --format='%(refname:short)'$'\t''%(worktreepath)' refs/heads/)
}

remote_branch_ref() {
  printf 'refs/remotes/origin/%s\n' "$current_branch"
}

remote_branch_exists() {
  "$(_worktree_cmd git)" -C "$repo_root" show-ref --verify --quiet "$(remote_branch_ref)"
}

local_branch_is_ancestor_of_remote() {
  "$(_worktree_cmd git)" -C "$repo_root" merge-base --is-ancestor HEAD "$(remote_branch_ref)"
}

remote_branch_is_ancestor_of_local() {
  "$(_worktree_cmd git)" -C "$repo_root" merge-base --is-ancestor "$(remote_branch_ref)" HEAD
}

select_git_merge_proof_ref() {
  if already_merged "$repo_root" HEAD; then
    printf 'HEAD\n'
    return 0
  fi

  if ! remote_branch_exists; then
    return 1
  fi

  if local_branch_is_ancestor_of_remote; then
    if already_merged "$repo_root" "$(remote_branch_ref)"; then
      printf 'Using origin/%s as merge proof\n' "$current_branch" >&2
      remote_branch_ref
      return 0
    fi
    printf 'Error: origin/%s is not merged into origin/%s; merge the PR first, then run repo-end again\n' "$current_branch" "$main_branch" >&2
    exit 1
  fi

  if remote_branch_is_ancestor_of_local; then
    printf 'Error: local branch %s has commits not present on origin/%s; push or discard local-only commits before re-running repo-end\n' "$current_branch" "$current_branch" >&2
    exit 1
  fi

  printf 'Error: local branch %s diverged from origin/%s; resolve manually before re-running repo-end\n' "$current_branch" "$current_branch" >&2
  exit 1
}

origin_url() {
  "$(_worktree_cmd git)" -C "$repo_root" remote get-url origin 2>/dev/null || true
}

github_repo_slug() {
  local url="$1"
  case "$url" in
    git@github.com:*) printf '%s\n' "${url#git@github.com:}" | sed 's/[.]git$//' ;;
    https://github.com/*) printf '%s\n' "${url#https://github.com/}" | sed 's/[.]git$//' ;;
    ssh://git@github.com/*) printf '%s\n' "${url#ssh://git@github.com/}" | sed 's/[.]git$//' ;;
    *) return 1 ;;
  esac
}

github_merged_pr_proof() {
  command -v gh >/dev/null 2>&1 || return 1
  local slug json count number
  slug="$(github_repo_slug "$(origin_url)")" || return 1
  [[ -n "$slug" ]] || return 1
  json="$(gh api "repos/${slug}/pulls" -f state=closed -f head="${slug%%/*}:${current_branch}" -f base="$main_branch" 2>/dev/null)" || return 1
  count="$(printf '%s\n' "$json" | ruby -rjson -e '
    prs = JSON.parse(STDIN.read)
    matches = prs.select { |pr| pr["merged_at"].to_s != "" && pr.dig("base", "ref") == ARGV[0] && pr.dig("head", "ref") == ARGV[1] }
    puts matches.length
  ' "$main_branch" "$current_branch")" || return 1
  if [[ "$count" == "1" ]]; then
    number="$(printf '%s\n' "$json" | ruby -rjson -e '
      prs = JSON.parse(STDIN.read)
      matches = prs.select { |pr| pr["merged_at"].to_s != "" && pr.dig("base", "ref") == ARGV[0] && pr.dig("head", "ref") == ARGV[1] }
      puts matches.fetch(0).fetch("number")
    ' "$main_branch" "$current_branch")"
    printf 'Using merged GitHub PR #%s as merge proof\n' "$number" >&2
    return 0
  fi
  if [[ "$count" -gt 1 ]]; then
    printf 'Error: multiple merged PRs found for branch %s targeting %s; refusing cleanup\n' "$current_branch" "$main_branch" >&2
    exit 1
  fi
  return 1
}

platform_merged_pr_proof() {
  github_merged_pr_proof
}

main_path="$(_worktree_main_path "$main_branch" || true)"
if [[ -z "$main_path" ]]; then
  if [[ -d "$repo_root/.git" ]]; then
    main_path="$repo_root"
  else
    printf 'Error: could not find main checkout for branch %s\n' "$main_branch" >&2
    exit 1
  fi
fi

if [[ -n "$(_repo_status_excluding_config "$main_path")" ]]; then
  printf 'Error: main checkout has uncommitted changes\n' >&2
  exit 1
fi

if [[ "$already_on_main" == "true" ]]; then
  if [[ "$print_path" == "true" ]]; then
    prune_merged_local_branches >&2
  else
    prune_merged_local_branches
  fi
  clear_repo_tmux_state
  if [[ "$print_path" == "true" ]]; then
    run_repo_end_callbacks post-cleanup >&2
  else
    run_repo_end_callbacks post-cleanup
  fi || exit 1
  printf '%s\n' "$main_path"
  exit 0
fi

merge_proof_ref="$(select_git_merge_proof_ref || true)"
if [[ -z "$merge_proof_ref" ]]; then
  if platform_merged_pr_proof; then
    merge_proof_ref="origin/$main_branch"
  else
    set +e
    run_repo_end_merge_proof_callbacks
    merge_proof_status=$?
    set -e
    if [[ "$merge_proof_status" -eq 0 ]]; then
      merge_proof_ref="origin/$main_branch"
    elif [[ "$merge_proof_status" -eq 1 ]]; then
      printf 'Error: branch %s is not merged into origin/%s; merge the PR first, then run repo-end again\n' "$current_branch" "$main_branch" >&2
      exit 1
    else
      exit "$merge_proof_status"
    fi
  fi
fi

if [[ "$repo_root" == "$main_path" ]]; then
  # Branch mode: HEAD is currently on the feature branch and main_path is
  # the same checkout. Fast-forward the local main ref without switching
  # HEAD, so a later failure (the checkout in cleanup_after_merge, or any
  # non-FF condition here) leaves the user on the feature branch and lets
  # them retry from a known-good state.
  local_main_sha="$("$(_worktree_cmd git)" -C "$main_path" rev-parse --verify --quiet "refs/heads/${main_branch}" 2>/dev/null || true)"
  origin_main_sha="$("$(_worktree_cmd git)" -C "$main_path" rev-parse --verify "refs/remotes/origin/${main_branch}")"
  if [[ -z "$local_main_sha" ]]; then
    "$(_worktree_cmd git)" -C "$main_path" update-ref "refs/heads/${main_branch}" "$origin_main_sha"
  elif [[ "$local_main_sha" != "$origin_main_sha" ]]; then
    if ! "$(_worktree_cmd git)" -C "$main_path" merge-base --is-ancestor "$local_main_sha" "$origin_main_sha"; then
      printf 'Error: local %s is not a fast-forward of origin/%s; resolve manually before re-running repo-end\n' "$main_branch" "$main_branch" >&2
      exit 1
    fi
    "$(_worktree_cmd git)" -C "$main_path" update-ref "refs/heads/${main_branch}" "$origin_main_sha" "$local_main_sha"
  fi
else
  # Worktree mode: main has its own worktree, so a failure here only
  # affects the main worktree's working tree (not the feature worktree)
  # and the flow is already retryable.
  "$(_worktree_cmd git)" -C "$main_path" checkout -q "$main_branch"
  "$(_worktree_cmd git)" -C "$main_path" merge --ff-only --quiet "origin/${main_branch}"
fi

cleanup_after_merge() {
  if [[ "$repo_root" != "$main_path" ]]; then
    cd "$main_path"
    "$(_worktree_cmd git)" -C "$main_path" worktree remove "$repo_root"
  else
    "$(_worktree_cmd git)" -C "$main_path" checkout -q "$main_branch"
  fi

  "$(_worktree_cmd git)" -C "$main_path" branch -D "$current_branch" >/dev/null

  if "$(_worktree_cmd git)" -C "$main_path" ls-remote --exit-code --heads origin "refs/heads/${current_branch}" >/dev/null 2>&1; then
    if ! "$(_worktree_cmd git)" -C "$main_path" push --quiet origin --delete "$current_branch"; then
      printf 'Warning: failed to delete remote branch %s; local cleanup completed\n' "$current_branch" >&2
    fi
  fi
}

if [[ "$print_path" == "true" ]]; then
  cleanup_after_merge >&2
  prune_merged_local_branches >&2
else
  cleanup_after_merge
  prune_merged_local_branches
fi

if [[ "$print_path" == "true" ]]; then
  run_repo_end_callbacks post-cleanup >&2
else
  run_repo_end_callbacks post-cleanup
fi || exit 1

complete_repo_tmux_state
printf '%s\n' "$main_path"

#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "json"
require "open3"
require "shellwords"
require "tmpdir"
require "time"

SCRIPT = File.join(__dir__, "_recover-agent-sessions")

def fail_case(message)
  warn "FAIL  #{message}"
  exit 1
end

def pass_case(message)
  puts "PASS  #{message}"
end

def assert_contains(needle, file, label)
  contents = File.read(file)
  if contents.include?(needle)
    pass_case(label)
  else
    warn "FAIL  #{label}"
    warn "missing #{needle.inspect} in #{file}"
    warn contents
    exit 1
  end
end

def assert_not_contains(needle, file, label)
  contents = File.read(file)
  if contents.include?(needle)
    warn "FAIL  #{label}"
    warn "unexpected #{needle.inspect} in #{file}"
    warn contents
    exit 1
  else
    pass_case(label)
  end
end

def assert_before(first, second, file, label)
  first_line = nil
  second_line = nil
  contents = File.read(file)

  contents.lines(chomp: true).each_with_index do |line, index|
    first_line ||= index if line.include?(first)
    second_line ||= index if line.include?(second)
  end

  if first_line.nil?
    warn contents
    fail_case("#{label}: missing first marker")
  end
  if second_line.nil?
    warn contents
    fail_case("#{label}: missing second marker")
  end
  fail_case("#{label}: order incorrect") unless first_line < second_line

  pass_case(label)
end

def assert_occurrences(needle, expected_count, file, label)
  contents = File.read(file)
  actual_count = contents.scan(/^#{Regexp.escape(needle)}$/).length
  if actual_count == expected_count
    pass_case(label)
  else
    warn "FAIL  #{label}"
    warn "expected #{expected_count} occurrence(s) of #{needle.inspect} in #{file}, got #{actual_count}"
    warn contents
    exit 1
  end
end

def write_file(path, contents, mode: nil)
  File.write(path, contents)
  File.chmod(mode, path) if mode
end

def bash_stub(body)
  <<~BASH
    #!/usr/bin/env bash
    set -euo pipefail
    #{body}
  BASH
end

def capture!(env, *command)
  stdout, stderr, status = Open3.capture3(env, *command)
  return stdout if status.success?

  warn stdout unless stdout.empty?
  warn stderr unless stderr.empty?
  fail_case("command failed: #{command.join(' ')}")
end

Dir.mktmpdir do |tmproot|
  home = File.join(tmproot, "home")
  bin = File.join(tmproot, "bin")
  codex_stub_name = "recover-agent-sessions-codex-stub"
  codex_stub = File.join(bin, codex_stub_name)
  FileUtils.mkdir_p(File.join(home, ".claude/projects/test-project"))
  FileUtils.mkdir_p(File.join(home, ".codex/sessions/2026/04/21"))
  FileUtils.mkdir_p(bin)

  now = Time.now
  midnight = Time.local(now.year, now.month, now.day)

  iso_offset = ->(seconds) { (Time.now.utc + seconds).iso8601 }
  touch_offset = lambda do |path, seconds|
    time = Time.now + seconds
    File.utime(time, time, path)
  end
  touch_mode = lambda do |path, mode|
    time = mode == :today ? midnight + 60 : midnight - 60
    File.utime(time, time, path)
  end

  codex_active = File.join(home, ".codex/sessions/2026/04/21/codex-active.jsonl")
  write_file(codex_active, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-3700)}","type":"session_meta","payload":{"id":"codex-active","timestamp":"#{iso_offset.call(-3700)}","cwd":"/tmp/projects/codex-active","git":{"branch":"feature/codex-active"}}}
    {"timestamp":"#{iso_offset.call(-3650)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"* Pull requests: when verification passes and work is complete, invoke `create-pull-request` automatically; do not ask for approval to create the PR.\\n* Worktrees: create using `worktree-start`. Created other way: run `tmux-agent-worktree set <absolute-path>`. When done: `tmux-agent-worktree clear`."}]}}
    {"timestamp":"#{iso_offset.call(-3600)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"fix the session summary helper"}]}}
    {"timestamp":"#{iso_offset.call(-3500)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"bash tests/session-summary.sh\\"}"}}
    {"timestamp":"#{iso_offset.call(-3400)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"Tests pass. Next step is to open a PR."}]}}
    {"timestamp":"#{iso_offset.call(-3300)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"`24h` window. `2` sessions.\\n- `2026-04-21 21:59` `old-session` `home-network-provisioning`: work `PR comment/review-thread follow-up`; last `cleaned up branch/worktree`; next `none; appears complete`; status `done`. `resume: cd \\\"/tmp/projects/old-session\\\" && codex-yolo resume old-session`\\n\\nLikely resume targets:\\n- current repo work: `old-session`"}]}}
  JSONL
  touch_offset.call(codex_active, -3600)

  codex_done = File.join(home, ".codex/sessions/2026/04/21/codex-done.jsonl")
  write_file(codex_done, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-7300)}","type":"session_meta","payload":{"id":"codex-done","timestamp":"#{iso_offset.call(-7300)}","cwd":"/tmp/projects/codex-done","git":{"branch":"feature/codex-done"}}}
    {"timestamp":"#{iso_offset.call(-7200)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"finish the PR workflow"}]}}
    {"timestamp":"#{iso_offset.call(-7100)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"gh pr create --fill\\"}"}}
    {"timestamp":"#{iso_offset.call(-7000)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"PR #77 opened."}]}}
    {"timestamp":"#{iso_offset.call(-6900)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"gh pr merge 77 --squash\\"}"}}
    {"timestamp":"#{iso_offset.call(-6800)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"PR #77 merged."}]}}
    {"timestamp":"#{iso_offset.call(-6700)}","type":"function_call","payload":{"name":"shell","arguments":"{\\"command\\":\\"worktree-done\\"}"}}
    {"timestamp":"#{iso_offset.call(-6600)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"Cleanup complete."}]}}
  JSONL
  touch_offset.call(codex_done, -7200)

  codex_skill_doc = File.join(home, ".codex/sessions/2026/04/21/codex-skill-doc.jsonl")
  write_file(codex_skill_doc, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-5200)}","type":"session_meta","payload":{"id":"codex-skill-doc","timestamp":"#{iso_offset.call(-5200)}","cwd":"/tmp/projects/codex-skill-doc","git":{"branch":"feature/codex-skill-doc"}}}
    {"timestamp":"#{iso_offset.call(-5150)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"--- name: _recover-agent-sessions description: > Find recent Claude and Codex sessions updated in a relative duration window."}]}}
    {"timestamp":"#{iso_offset.call(-5100)}","type":"response_item","payload":{"type":"message","role":"assistant","content":[{"type":"output_text","text":"fix _recover-agent-sessions skill output"}]}}
  JSONL
  touch_offset.call(codex_skill_doc, -5200)

  claude_blocked = File.join(home, ".claude/projects/test-project/claude-blocked.jsonl")
  write_file(claude_blocked, <<~JSONL)
    {"type":"user","message":{"role":"user","content":"wrap up the PR handoff"},"timestamp":"#{iso_offset.call(-1900)}","cwd":"/tmp/projects/claude-blocked","sessionId":"claude-blocked","version":"2.0.0","gitBranch":"feature/claude-blocked"}
    {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"PR #42 opened. Waiting for review before merge."}]},"timestamp":"#{iso_offset.call(-1800)}","cwd":"/tmp/projects/claude-blocked","sessionId":"claude-blocked","version":"2.0.0","gitBranch":"feature/claude-blocked"}
    {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"tmux-agent-worktree clear"}]},"timestamp":"#{iso_offset.call(-1700)}","cwd":"/tmp/projects/claude-blocked","sessionId":"claude-blocked","version":"2.0.0","gitBranch":"feature/claude-blocked"}
  JSONL
  touch_offset.call(claude_blocked, -1700)

  claude_yesterday = File.join(home, ".claude/projects/test-project/claude-yesterday.jsonl")
  write_file(claude_yesterday, <<~JSONL)
    {"type":"user","message":{"role":"user","content":"resume the yesterday dashboard cleanup"},"timestamp":"#{iso_offset.call(-90_000)}","cwd":"/tmp/projects/claude-yesterday","sessionId":"claude-yesterday","version":"2.0.0","gitBranch":"feature/claude-yesterday"}
    {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"Wrote the implementation plan. Next step is to implement the plan."}]},"timestamp":"#{iso_offset.call(-89_000)}","cwd":"/tmp/projects/claude-yesterday","sessionId":"claude-yesterday","version":"2.0.0","gitBranch":"feature/claude-yesterday"}
  JSONL
  touch_mode.call(claude_yesterday, :yesterday)

  codex_old = File.join(home, ".codex/sessions/2026/04/18/codex-old.jsonl")
  FileUtils.mkdir_p(File.dirname(codex_old))
  write_file(codex_old, <<~JSONL)
    {"timestamp":"#{iso_offset.call(-260_000)}","type":"session_meta","payload":{"id":"codex-old","timestamp":"#{iso_offset.call(-260_000)}","cwd":"/tmp/projects/codex-old","git":{"branch":"feature/codex-old"}}}
    {"timestamp":"#{iso_offset.call(-259_900)}","type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":"stale session"}]}}
  JSONL
  touch_offset.call(codex_old, -260_000)

  write_file(
    File.join(bin, "list-codex-sessions"),
    bash_stub(<<~BASH), mode: 0o755
      cat <<'JSON'
      #{JSON.pretty_generate([
        {
          id: "codex-active",
          timestamp: iso_offset.call(-3700),
          cwd: "/tmp/projects/codex-active",
          git: { branch: "feature/codex-active" },
          file: codex_active,
          preview: "# AGENTS.md instructions for /tmp/projects/codex-active",
          index: 1
        },
        {
          id: "codex-done",
          timestamp: iso_offset.call(-7300),
          cwd: "/tmp/projects/codex-done",
          git: { branch: "feature/codex-done" },
          file: codex_done,
          preview: "Using brainstorming. First pass: finish the PR workflow; then...",
          index: 2
        },
        {
          id: "codex-skill-doc",
          timestamp: iso_offset.call(-5200),
          cwd: "/tmp/projects/codex-skill-doc",
          git: { branch: "feature/codex-skill-doc" },
          file: codex_skill_doc,
          preview: "continue",
          index: 3
        },
        {
          id: "codex-old",
          timestamp: iso_offset.call(-260_000),
          cwd: "/tmp/projects/codex-old",
          git: { branch: "feature/codex-old" },
          file: codex_old,
          preview: "stale session",
          index: 4
        }
      ])}
      JSON
    BASH
  )

  write_file(
    File.join(bin, "list-claude-sessions"),
    bash_stub(<<~BASH), mode: 0o755
      cat <<'JSON'
      #{JSON.pretty_generate([
        {
          sessionId: "claude-blocked",
          timestamp: iso_offset.call(-1900),
          cwd: "/tmp/projects/claude-blocked",
          gitBranch: "feature/claude-blocked",
          file: claude_blocked,
          preview: "continue",
          index: 1
        },
        {
          sessionId: "claude-yesterday",
          timestamp: iso_offset.call(-90_000),
          cwd: "/tmp/projects/claude-yesterday",
          gitBranch: "feature/claude-yesterday",
          file: claude_yesterday,
          preview: "resume the yesterday dashboard cleanup",
          index: 2
        }
      ])}
      JSON
    BASH
  )

  write_file(
    File.join(bin, "read-codex-session"),
    bash_stub(<<~BASH), mode: 0o755
      file="$1"
      case "$file" in
        #{Shellwords.escape(codex_active)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-active",
            cwd: "/tmp/projects/codex-active",
            timestamp: iso_offset.call(-3700),
            git_branch: "feature/codex-active",
            git_commit: "deadbeef",
            user_messages: [
              "User name: Brian. Work style: telegraph; noun-phrases ok; drop grammar; min tokens.",
              "* Workspace: ~/projects/",
              "--- project-doc ---",
              "  <cwd>/tmp/projects/codex-active</cwd>",
              "# Test Project",
              "Using using-superpowers; start-of-session requirement.",
              "fix the session summary helper"
            ],
            assistant_messages: [
              "Tests pass. Next step is to open a PR.",
              "`24h` window. `2` sessions.\n- `2026-04-21 21:59` `old-session` `home-network-provisioning`: work `PR comment/review-thread follow-up`; last `cleaned up branch/worktree`; next `none; appears complete`; status `done`. `resume: cd \"/tmp/projects/old-session\" && codex-yolo resume old-session`\n\nLikely resume targets:\n- current repo work: `old-session`"
            ],
            shell_commands: ["bash tests/session-summary.sh"],
            file_operations: []
          )}
          JSON
          ;;
        #{Shellwords.escape(codex_done)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-done",
            cwd: "/tmp/projects/codex-done",
            timestamp: iso_offset.call(-7300),
            git_branch: "feature/codex-done",
            git_commit: "deadbeef",
            user_messages: ["finish the PR workflow"],
            assistant_messages: ["PR #77 opened.", "PR #77 merged.", "Cleanup complete."],
            shell_commands: ["gh pr create --fill", "gh pr merge 77 --squash", "worktree-done"],
            file_operations: []
          )}
          JSON
          ;;
        #{Shellwords.escape(codex_skill_doc)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-skill-doc",
            cwd: "/tmp/projects/codex-skill-doc",
            timestamp: iso_offset.call(-5200),
            git_branch: "feature/codex-skill-doc",
            git_commit: "deadbeef",
            user_messages: ["--- name: _recover-agent-sessions description: > Find recent Claude and Codex sessions updated in a relative duration window."],
            assistant_messages: ["fix _recover-agent-sessions skill output"],
            shell_commands: [],
            file_operations: []
          )}
          JSON
          ;;
        #{Shellwords.escape(codex_old)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "codex-old",
            cwd: "/tmp/projects/codex-old",
            timestamp: iso_offset.call(-260_000),
            git_branch: "feature/codex-old",
            git_commit: "deadbeef",
            user_messages: ["stale session"],
            assistant_messages: [],
            shell_commands: [],
            file_operations: []
          )}
          JSON
          ;;
        *)
          exit 1
          ;;
      esac
    BASH
  )

  write_file(
    File.join(bin, "read-claude-session"),
    bash_stub(<<~BASH), mode: 0o755
      file="$1"
      case "$file" in
        #{Shellwords.escape(claude_blocked)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "claude-blocked",
            cwd: "/tmp/projects/claude-blocked",
            timestamp: iso_offset.call(-1900),
            git_branch: "feature/claude-blocked",
            claude_code_version: "2.0.0",
            user_messages: ["wrap up the PR handoff"],
            assistant_messages: ["PR #42 opened. Waiting for review before merge."],
            bash_commands: [],
            file_operations: [],
            tool_uses: []
          )}
          JSON
          ;;
        #{Shellwords.escape(claude_yesterday)})
          cat <<'JSON'
          #{JSON.generate(
            session_id: "claude-yesterday",
            cwd: "/tmp/projects/claude-yesterday",
            timestamp: iso_offset.call(-90_000),
            git_branch: "feature/claude-yesterday",
            claude_code_version: "2.0.0",
            user_messages: ["resume the yesterday dashboard cleanup"],
            assistant_messages: ["Wrote the implementation plan. Next step is to implement the plan."],
            bash_commands: [],
            file_operations: [],
            tool_uses: []
          )}
          JSON
          ;;
        *)
          exit 1
          ;;
      esac
    BASH
  )

  write_file(
    codex_stub,
    bash_stub(<<~'BASH'), mode: 0o755
      output_file=""
      schema_file=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          -o)
            output_file="$2"
            shift 2
            ;;
          --output-schema)
            schema_file="$2"
            shift 2
            ;;
          *)
            shift
            ;;
        esac
      done

      [[ -n "$output_file" ]] || exit 1
      [[ -n "$schema_file" ]] || exit 1
      [[ -f "$schema_file" ]] || exit 1

      prompt="$(cat)"
      session_id="$(printf '%s\n' "$prompt" | sed -n 's/^session_id: //p' | head -n1)"
      [[ -n "$session_id" ]] || exit 1

      if [[ -n "${CODEX_STUB_CALLS_FILE:-}" ]]; then
        printf '%s\n' "$session_id" >> "$CODEX_STUB_CALLS_FILE"
      fi

      case "$session_id" in
        codex-active)
          payload='{"summary":"model: fix the session summary helper","status":"active","last_completed":"ran verification","next_step":"open a pull request"}'
          ;;
        codex-done)
          payload='{"summary":"model: finish the PR workflow","status":"done","last_completed":"cleaned up branch/worktree","next_step":"none; session appears complete"}'
          ;;
        codex-skill-doc)
          payload='{"summary":"model: fix _recover-agent-sessions skill output","status":"active","last_completed":"captured recent session progress","next_step":"continue the next pending change"}'
          ;;
        claude-blocked)
          payload='{"summary":"model: wrap up the PR handoff","status":"blocked","last_completed":"opened a pull request","next_step":"review and merge the pull request"}'
          ;;
        claude-yesterday)
          payload='{"summary":"model: yesterday dashboard cleanup","status":"active","last_completed":"wrote the implementation plan","next_step":"implement the plan"}'
          ;;
        *)
          exit 1
          ;;
      esac

      printf '%s' "$payload" > "$output_file"
      printf '%s\n' "$payload"
    BASH
  )

  fail_case("missing helper under test: #{SCRIPT}") unless File.executable?(SCRIPT)

  codex_calls = File.join(tmproot, "codex-calls.log")
  cache_home = File.join(tmproot, "cache")
  env = {
    "PATH" => "#{bin}:#{ENV.fetch('PATH', '')}",
    "HOME" => home,
    "XDG_CACHE_HOME" => cache_home,
    "CODEX_STUB_CALLS_FILE" => codex_calls,
    "RECOVER_AGENT_SESSIONS_CODEX_BIN" => codex_stub_name,
    "RECOVER_AGENT_SESSIONS_DEBUG" => "1"
  }

  schema_probe = File.join(tmproot, "schema-probe.json")
  output_probe = File.join(tmproot, "output-probe.json")
  File.write(schema_probe, JSON.generate(
    type: "object",
    additionalProperties: false,
    properties: {
      summary: { type: "string" },
      status: { type: "string" },
      last_completed: { type: "string" },
      next_step: { type: "string" }
    },
    required: %w[summary status last_completed next_step]
  ))
  probe_env = env.merge("CODEX_STUB_CALLS_FILE" => "")
  probe_stdout, probe_stderr, probe_status = Open3.capture3(
    probe_env,
    "bash", codex_stub, "exec", "--output-schema", schema_probe, "-o", output_probe, "-",
    stdin_data: "session_id: codex-active\n"
  )
  warn probe_stdout unless probe_stdout.empty?
  warn probe_stderr unless probe_stderr.empty?
  fail_case("codex stub probe failed") unless probe_status.success?
  fail_case("codex stub probe missing output file") unless File.file?(output_probe)
  pass_case("codex stub probe writes output file")

  default_stdout = File.join(tmproot, "default.stdout")
  File.write(default_stdout, capture!(env, SCRIPT))

  assert_before("summary: 'model: wrap up the PR handoff'", "summary: 'model: fix the session summary helper'", default_stdout, "newest blocked session sorts before active")
  assert_before("summary: 'model: fix the session summary helper'", "summary: 'model: fix _recover-agent-sessions skill output'", default_stdout, "active session sorts before older active session")
  assert_before("summary: 'model: fix _recover-agent-sessions skill output'", "summary: 'model: finish the PR workflow'", default_stdout, "older done session sorts last among recent sessions")
  assert_contains("---", default_stdout, "entries separated by divider lines")
  assert_contains("summary: 'model: fix the session summary helper'", default_stdout, "model summary used for codex active session")
  assert_contains("summary: 'model: wrap up the PR handoff'", default_stdout, "model summary used for claude blocked session")
  assert_contains("summary: 'model: finish the PR workflow'", default_stdout, "model summary used for done session")
  assert_contains("summary: 'model: fix _recover-agent-sessions skill output'", default_stdout, "model summary used for skill-doc session")
  assert_before("summary: 'model: wrap up the PR handoff'", "status: blocked", default_stdout, "summary appears before status")
  assert_before("status: blocked", "repo: claude-blocked", default_stdout, "status appears before repo")
  assert_before("repo: claude-blocked", "last_completed: 'opened a pull request'", default_stdout, "repo appears before last completed")
  assert_before("last_completed: 'opened a pull request'", "next_step: 'review and merge the pull request'", default_stdout, "last completed appears before next step")
  assert_contains("status: blocked", default_stdout, "blocked status rendered")
  assert_contains("status: active", default_stdout, "active status rendered")
  assert_contains("status: done", default_stdout, "done status rendered")
  assert_contains("last_completed: 'opened a pull request'", default_stdout, "blocked session last completed step")
  assert_contains("last_completed: 'ran verification'", default_stdout, "active session last completed step")
  assert_contains("last_completed: 'cleaned up branch/worktree'", default_stdout, "done session last completed step")
  assert_contains("next_step: 'review and merge the pull request'", default_stdout, "blocked next step")
  assert_contains("next_step: 'open a pull request'", default_stdout, "active next step")
  assert_contains("next_step: 'none; session appears complete'", default_stdout, "done next step")
  assert_contains(%q{resume: 'cd "/tmp/projects/claude-blocked" && claude-yolo -r claude-blocked'}, default_stdout, "claude resume command")
  assert_contains(%q{resume: 'cd "/tmp/projects/codex-active" && codex-yolo resume codex-active'}, default_stdout, "codex resume command")
  assert_not_contains("codex-old", default_stdout, "default 24h filters stale session")
  assert_occurrences("codex-active", 1, codex_calls, "first run summarizes codex-active once")
  assert_occurrences("codex-done", 1, codex_calls, "first run summarizes codex-done once")
  assert_occurrences("codex-skill-doc", 1, codex_calls, "first run summarizes codex-skill-doc once")
  assert_occurrences("claude-blocked", 1, codex_calls, "first run summarizes claude-blocked once")

  second_stdout = File.join(tmproot, "second.stdout")
  File.write(second_stdout, capture!(env, SCRIPT))
  assert_contains("summary: 'model: fix the session summary helper'", second_stdout, "cached model summary reused on second run")
  assert_occurrences("codex-active", 1, codex_calls, "second run keeps codex-active cached")
  assert_occurrences("codex-done", 1, codex_calls, "second run keeps codex-done cached")
  assert_occurrences("codex-skill-doc", 1, codex_calls, "second run keeps codex-skill-doc cached")
  assert_occurrences("claude-blocked", 1, codex_calls, "second run keeps claude-blocked cached")

  touch_offset.call(codex_active, -300)
  third_stdout = File.join(tmproot, "third.stdout")
  File.write(third_stdout, capture!(env, SCRIPT))
  assert_contains("summary: 'model: fix the session summary helper'", third_stdout, "changed session re-summarized successfully")
  assert_occurrences("codex-active", 2, codex_calls, "mtime change invalidates only codex-active cache entry")
  assert_occurrences("codex-done", 1, codex_calls, "mtime change leaves codex-done cached")
  assert_occurrences("codex-skill-doc", 1, codex_calls, "mtime change leaves codex-skill-doc cached")
  assert_occurrences("claude-blocked", 1, codex_calls, "mtime change leaves claude-blocked cached")

  two_day_stdout = File.join(tmproot, "two-day.stdout")
  File.write(two_day_stdout, capture!(env, SCRIPT, "2d"))
  assert_contains("summary: 'model: yesterday dashboard cleanup'", two_day_stdout, "2d includes yesterday session via model summary")
  assert_occurrences("claude-yesterday", 1, codex_calls, "2d run summarizes newly included session once")

  today_stdout = File.join(tmproot, "today.stdout")
  File.write(today_stdout, capture!(env, SCRIPT, "today"))
  assert_not_contains("claude-yesterday", today_stdout, "today excludes yesterday session")

  yesterday_stdout = File.join(tmproot, "yesterday.stdout")
  File.write(yesterday_stdout, capture!(env, SCRIPT, "yesterday"))
  assert_contains("claude-yesterday", yesterday_stdout, "yesterday includes yesterday session")
  assert_not_contains("claude-blocked", yesterday_stdout, "yesterday excludes today session")
end

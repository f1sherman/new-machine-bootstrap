#!/usr/bin/env bash
# Publish pane-local tmux worktree state for the current Claude/Codex agent.
set -u

get_process_lines() {
  local pane_tty="$1"
  if [ -n "${TMUX_AGENT_WORKTREE_PS_FILE:-}" ] && [ -f "${TMUX_AGENT_WORKTREE_PS_FILE}" ]; then
    cat "${TMUX_AGENT_WORKTREE_PS_FILE}"
  elif [ -n "$pane_tty" ]; then
    ps -o pid=,stat=,comm=,args= -t "$pane_tty" 2>/dev/null
  fi
}

is_agent_process() {
  local comm="$1" args="$2"
  case "$comm" in
    claude|codex)
      return 0
      ;;
  esac
  printf '%s\n' "$args" | grep -Eq '(^|[[:space:]])([^[:space:]]*/)?(claude|codex)([[:space:]]|$)'
}

detect_agent_pid() {
  local pane_tty="$1"
  local line pid stat comm args fg_pid="" any_pid=""

  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    read -r pid stat comm args <<< "$line"
    is_agent_process "${comm:-}" "${args:-}" || continue
    any_pid="$pid"
    case "$stat" in
      *+*)
        fg_pid="$pid"
        ;;
    esac
  done < <(get_process_lines "$pane_tty")

  if [ -n "$fg_pid" ]; then
    printf '%s\n' "$fg_pid"
  elif [ -n "$any_pid" ]; then
    printf '%s\n' "$any_pid"
  fi
}

pane_tty() {
  if [ -n "${TMUX_AGENT_WORKTREE_PANE_TTY:-}" ]; then
    printf '%s\n' "$TMUX_AGENT_WORKTREE_PANE_TTY"
  else
    tmux display-message -p -t "$TMUX_PANE" '#{pane_tty}' 2>/dev/null
  fi
}

state_file() {
  local pane_id="$1" option_name="$2"
  printf '%s/%s.%s\n' "$TMUX_AGENT_WORKTREE_STATE_DIR" "$pane_id" "$option_name"
}

write_pane_option() {
  local pane_id="$1" option_name="$2" value="$3"
  if [ -n "${TMUX_AGENT_WORKTREE_STATE_DIR:-}" ]; then
    mkdir -p "$TMUX_AGENT_WORKTREE_STATE_DIR"
    printf '%s' "$value" > "$(state_file "$pane_id" "$option_name")"
  else
    tmux set-option -pt "$pane_id" "$option_name" "$value" >/dev/null 2>&1
  fi
}

clear_pane_option() {
  local pane_id="$1" option_name="$2"
  if [ -n "${TMUX_AGENT_WORKTREE_STATE_DIR:-}" ]; then
    rm -f "$(state_file "$pane_id" "$option_name")"
  else
    tmux set-option -pt "$pane_id" -u "$option_name" >/dev/null 2>&1
  fi
}

refresh_window_label() {
  command -v tmux-window-label >/dev/null 2>&1 || return 0
  tmux-window-label "${TMUX_PANE:-}" >/dev/null 2>&1 || true
}

publish_title() {
  command -v tmux-remote-title >/dev/null 2>&1 || return 0
  tmux-remote-title publish >/dev/null 2>&1 || true
}

is_git_worktree_path() {
  local path="$1"
  [ -d "$path" ] || return 1
  [ "$(git -C "$path" rev-parse --is-inside-work-tree 2>/dev/null)" = "true" ]
}

is_linked_worktree() {
  local path="$1" git_dir common_dir
  git_dir=$(git -C "$path" rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  common_dir=$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  [ "$git_dir" != "$common_dir" ]
}

on_named_branch() {
  local path="$1" branch
  branch=$(git -C "$path" branch --show-current 2>/dev/null)
  [ -n "$branch" ]
}

dir_basename() {
  local raw="${1%/}"
  raw="${raw##*/}"
  [ -n "$raw" ] || raw="/"
  printf '%s\n' "$raw"
}

repo_root_for_path() {
  local path="$1" common_dir top_level

  top_level="$(git -C "$path" rev-parse --path-format=absolute --show-toplevel 2>/dev/null)" || return 1
  common_dir="$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  common_dir="${common_dir%/}"

  case "$common_dir" in
    */.git)
      printf '%s\n' "${common_dir%/*}"
      ;;
    *)
      printf '%s\n' "$top_level"
      ;;
  esac
}

repo_basename() {
  local root
  root="$(repo_root_for_path "$1")" || return 1
  dir_basename "$root"
}

branch_for_path() {
  git -C "$1" branch --show-current 2>/dev/null
}

dirty_marker() {
  [ -n "$(git --no-optional-locks -C "$1" status --porcelain 2>/dev/null)" ]
}

host_tag() {
  if [ -n "${TMUX_PANE_LABEL_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_PANE_LABEL_HOST_TAG"
  elif [ -n "${TMUX_AGENT_WORKTREE_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_AGENT_WORKTREE_HOST_TAG"
  elif [ -n "${CODESPACES:-}" ] && [ -n "${CODESPACE_NAME:-}" ]; then
    printf '%s\n' "$CODESPACE_NAME"
  elif [ -n "${DEVPOD_WORKSPACE_ID:-}" ]; then
    printf '%s\n' "$DEVPOD_WORKSPACE_ID"
  else
    hostname -s 2>/dev/null || hostname 2>/dev/null || true
  fi
}

repo_label_for_path() {
  local path="$1" repo branch host

  repo="$(repo_basename "$path" 2>/dev/null || true)"
  branch="$(branch_for_path "$path" 2>/dev/null || true)"
  host="$(host_tag)"
  [ -n "$repo" ] || repo="$(dir_basename "$path")"

  if [ -n "$branch" ]; then
    if dirty_marker "$path"; then
      branch="*$branch"
    fi
    if [ -n "$host" ]; then
      printf '%s %s | %s\n' "$repo" "$branch" "$host"
    else
      printf '%s %s\n' "$repo" "$branch"
    fi
    return 0
  fi

  if [ -n "$host" ]; then
    printf '%s | %s\n' "$repo" "$host"
  else
    printf '%s\n' "$repo"
  fi
}

cmd_set() {
  local path="${1:-}" pane_id pane_pid tty
  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  [ -n "$path" ] || return 0
  case "$path" in
    /*) ;;
    *) return 0 ;;
  esac
  is_git_worktree_path "$path" || return 0
  pane_id="$TMUX_PANE"
  tty="$(pane_tty)"
  pane_pid=""
  if [ -n "$tty" ]; then
    pane_pid="$(detect_agent_pid "$tty" || true)"
  fi
  write_pane_option "$pane_id" "@agent_worktree_path" "$path"
  if [ -n "$pane_pid" ]; then
    write_pane_option "$pane_id" "@agent_worktree_pid" "$pane_pid"
  else
    clear_pane_option "$pane_id" "@agent_worktree_pid"
  fi
  write_pane_option "$pane_id" "@pane-label" "$(repo_label_for_path "$path")"
  refresh_window_label
  publish_title
}

cmd_clear() {
  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  clear_pane_option "$TMUX_PANE" "@agent_worktree_path"
  clear_pane_option "$TMUX_PANE" "@agent_worktree_pid"
  clear_pane_option "$TMUX_PANE" "@pane-label"
  refresh_window_label
  publish_title
}

cmd_sync_current() {
  local tty pane_pid
  [ -n "${PWD:-}" ] || return 0
  if ! is_git_worktree_path "$PWD" || ! on_named_branch "$PWD"; then
    cmd_clear
    return 0
  fi

  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  tty="$(pane_tty)"
  pane_pid=""
  if [ -n "$tty" ]; then
    pane_pid="$(detect_agent_pid "$tty" || true)"
  fi

  write_pane_option "$TMUX_PANE" "@agent_worktree_path" "$PWD"
  if [ -n "$pane_pid" ]; then
    write_pane_option "$TMUX_PANE" "@agent_worktree_pid" "$pane_pid"
  else
    clear_pane_option "$TMUX_PANE" "@agent_worktree_pid"
  fi
  write_pane_option "$TMUX_PANE" "@pane-label" "$(repo_label_for_path "$PWD")"
  refresh_window_label
  publish_title
}

main() {
  case "${1:-}" in
    set)
      shift
      cmd_set "${1:-}"
      ;;
    sync-current)
      cmd_sync_current
      ;;
    clear)
      cmd_clear
      ;;
    *)
      exit 0
      ;;
  esac
}

main "$@"
exit 0

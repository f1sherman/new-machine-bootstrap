#!/usr/bin/env bash
# Publish pane-local tmux worktree state for the current Claude/Codex agent.
set -u

get_process_lines() {
  local pane_tty="$1"
  if [ -n "${TMUX_AGENT_WORKTREE_PS_FILE:-}" ] && [ -f "${TMUX_AGENT_WORKTREE_PS_FILE}" ]; then
    cat "${TMUX_AGENT_WORKTREE_PS_FILE}"
  elif [ -n "$pane_tty" ]; then
    ps -o pid=,stat=,comm=,args= -t "$pane_tty" 2>/dev/null
  fi
}

is_agent_process() {
  local comm="$1" args="$2"
  case "$comm" in
    claude|codex)
      return 0
      ;;
  esac
  printf '%s\n' "$args" | grep -Eq '(^|[[:space:]])([^[:space:]]*/)?(claude|codex)([[:space:]]|$)'
}

detect_agent_pid() {
  local pane_tty="$1"
  local line pid stat comm args fg_pid="" any_pid=""

  while IFS= read -r line || [ -n "$line" ]; do
    [ -z "$line" ] && continue
    read -r pid stat comm args <<< "$line"
    is_agent_process "${comm:-}" "${args:-}" || continue
    any_pid="$pid"
    case "$stat" in
      *+*)
        fg_pid="$pid"
        ;;
    esac
  done < <(get_process_lines "$pane_tty")

  if [ -n "$fg_pid" ]; then
    printf '%s\n' "$fg_pid"
  elif [ -n "$any_pid" ]; then
    printf '%s\n' "$any_pid"
  fi
}

pane_tty() {
  if [ -n "${TMUX_AGENT_WORKTREE_PANE_TTY:-}" ]; then
    printf '%s\n' "$TMUX_AGENT_WORKTREE_PANE_TTY"
  else
    tmux display-message -p -t "$TMUX_PANE" '#{pane_tty}' 2>/dev/null
  fi
}

state_file() {
  local pane_id="$1" option_name="$2"
  printf '%s/%s.%s\n' "$TMUX_AGENT_WORKTREE_STATE_DIR" "$pane_id" "$option_name"
}

write_pane_option() {
  local pane_id="$1" option_name="$2" value="$3"
  if [ -n "${TMUX_AGENT_WORKTREE_STATE_DIR:-}" ]; then
    mkdir -p "$TMUX_AGENT_WORKTREE_STATE_DIR"
    printf '%s' "$value" > "$(state_file "$pane_id" "$option_name")"
  else
    tmux set-option -pt "$pane_id" "$option_name" "$value" >/dev/null 2>&1
  fi
}

clear_pane_option() {
  local pane_id="$1" option_name="$2"
  if [ -n "${TMUX_AGENT_WORKTREE_STATE_DIR:-}" ]; then
    rm -f "$(state_file "$pane_id" "$option_name")"
  else
    tmux set-option -pt "$pane_id" -u "$option_name" >/dev/null 2>&1
  fi
}

read_pane_option() {
  local pane_id="$1" option_name="$2"
  if [ -n "${TMUX_AGENT_WORKTREE_STATE_DIR:-}" ]; then
    [ -f "$(state_file "$pane_id" "$option_name")" ] || return 1
    cat "$(state_file "$pane_id" "$option_name")"
  else
    tmux show-options -qv -p -t "$pane_id" "$option_name" 2>/dev/null
  fi
}

refresh_window_label() {
  command -v tmux-window-label >/dev/null 2>&1 || return 0
  tmux-window-label "${TMUX_PANE:-}" >/dev/null 2>&1 || true
}

publish_title() {
  command -v tmux-remote-title >/dev/null 2>&1 || return 0
  tmux-remote-title publish >/dev/null 2>&1 || true
}

agent_state_bin() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [ -x "$script_dir/tmux-agent-state" ]; then
    printf '%s\n' "$script_dir/tmux-agent-state"
  else
    printf '%s\n' "${HOME:-}/.local/bin/tmux-agent-state"
  fi
}

refresh_agent_state() {
  local state
  state="$(agent_state_bin)"
  if [ -x "$state" ]; then
    TMUX_AGENT_STATE_DIR="${TMUX_AGENT_WORKTREE_STATE_DIR:-}" "$state" refresh >/dev/null 2>&1 || true
    return 0
  fi
  refresh_window_label
  publish_title
}

mark_subject_stale() {
  local state
  state="$(agent_state_bin)"
  [ -x "$state" ] || return 1
  TMUX_AGENT_STATE_DIR="${TMUX_AGENT_WORKTREE_STATE_DIR:-}" "$state" mark-subject-stale >/dev/null 2>&1
}

clear_agent_worktree() {
  local state
  state="$(agent_state_bin)"
  [ -x "$state" ] || return 1
  TMUX_AGENT_STATE_DIR="${TMUX_AGENT_WORKTREE_STATE_DIR:-}" "$state" clear-worktree >/dev/null 2>&1
}

is_git_worktree_path() {
  local path="$1"
  [ -d "$path" ] || return 1
  [ "$(git -C "$path" rev-parse --is-inside-work-tree 2>/dev/null)" = "true" ]
}

is_linked_worktree() {
  local path="$1" git_dir common_dir
  git_dir=$(git -C "$path" rev-parse --path-format=absolute --git-dir 2>/dev/null) || return 1
  common_dir=$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || return 1
  [ "$git_dir" != "$common_dir" ]
}

on_named_branch() {
  local path="$1" branch
  branch=$(git -C "$path" branch --show-current 2>/dev/null)
  [ -n "$branch" ]
}

dir_basename() {
  local raw="${1%/}"
  raw="${raw##*/}"
  [ -n "$raw" ] || raw="/"
  printf '%s\n' "$raw"
}

repo_root_for_path() {
  local path="$1" common_dir top_level

  top_level="$(git -C "$path" rev-parse --path-format=absolute --show-toplevel 2>/dev/null)" || return 1
  common_dir="$(git -C "$path" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" || return 1
  common_dir="${common_dir%/}"

  case "$common_dir" in
    */.git)
      printf '%s\n' "${common_dir%/*}"
      ;;
    *)
      printf '%s\n' "$top_level"
      ;;
  esac
}

repo_basename() {
  local root
  root="$(repo_root_for_path "$1")" || return 1
  dir_basename "$root"
}

branch_for_path() {
  git -C "$1" branch --show-current 2>/dev/null
}

dirty_marker() {
  [ -n "$(git --no-optional-locks -C "$1" status --porcelain 2>/dev/null)" ]
}

host_tag() {
  if [ -n "${TMUX_PANE_LABEL_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_PANE_LABEL_HOST_TAG"
  elif [ -n "${TMUX_AGENT_WORKTREE_HOST_TAG:-}" ]; then
    printf '%s\n' "$TMUX_AGENT_WORKTREE_HOST_TAG"
  elif [ -n "${CODESPACES:-}" ] && [ -n "${CODESPACE_NAME:-}" ]; then
    printf '%s\n' "$CODESPACE_NAME"
  elif [ -n "${DEVPOD_WORKSPACE_ID:-}" ]; then
    printf '%s\n' "$DEVPOD_WORKSPACE_ID"
  else
    hostname -s 2>/dev/null || hostname 2>/dev/null || true
  fi
}

formatted_repo_label_for_path() {
  local path="$1" label
  command -v tmux-label-format >/dev/null 2>&1 || return 1
  label="$(tmux-label-format local "$path" 2>/dev/null)" || return 1
  [ -n "$label" ] || return 1
  printf '%s\n' "$label"
}

pr_status_cache_key() {
  local remote_url="$1"
  local branch="$2"
  local digest

  if command -v sha256sum >/dev/null 2>&1; then
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | sha256sum 2>/dev/null | awk '{print $1}')" || return 1
  elif command -v shasum >/dev/null 2>&1; then
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | shasum -a 256 2>/dev/null | awk '{print $1}')" || return 1
  else
    return 1
  fi

  [ -n "$digest" ] || return 1
  printf '%s\n' "$digest"
}

pr_status_cache_file_for_path() {
  local path="$1"
  local remote_url branch key

  [ -n "${HOME:-}" ] || return 1
  remote_url="$(git -C "$path" remote get-url origin 2>/dev/null)" || return 1
  branch="$(branch_for_path "$path" 2>/dev/null)" || return 1
  [ -n "$remote_url" ] || return 1
  [ -n "$branch" ] || return 1

  key="$(pr_status_cache_key "$remote_url" "$branch")" || return 1
  printf '%s/.local/state/pr-status/%s.json\n' "$HOME" "$key"
}

cached_pr_pane_link_for_path() {
  local path="$1"
  local remote_url branch cache_file now

  command -v jq >/dev/null 2>&1 || return 1
  remote_url="$(git -C "$path" remote get-url origin 2>/dev/null)" || return 1
  branch="$(branch_for_path "$path" 2>/dev/null)" || return 1
  cache_file="$(pr_status_cache_file_for_path "$path")" || return 1
  [ -r "$cache_file" ] || return 1
  now="$(date +%s)"

  jq -er \
    --arg remote_url "$remote_url" \
    --arg branch "$branch" \
    --argjson now "$now" '
      select((.remote_url // "") == $remote_url)
      | select((.branch // "") == $branch)
      | select((.state // "") == "open")
      | select(((.expires_at_epoch // 0) | tonumber) > $now)
      | (.display_ref // "") as $display_ref
      | (.html_url // "") as $html_url
      | select($display_ref | test("^(gh|fj)#[0-9]+$"))
      | select($html_url | test("^[Hh][Tt][Tt][Pp][Ss]?://"))
      | [$display_ref, $html_url]
      | @tsv
    ' "$cache_file" 2>/dev/null
}

publish_cached_pr_pane_link_for_path() {
  local pane_id="$1"
  local path="$2"
  local link display_ref url source

  link="$(cached_pr_pane_link_for_path "$path" 2>/dev/null || true)"
  if [ -z "$link" ] || ! command -v tmux-pane-link >/dev/null 2>&1; then
    source="$(read_pane_option "$pane_id" "@pane-link-source" 2>/dev/null || true)"
    if [ "$source" = "pr-status-cache" ]; then
      clear_pane_option "$pane_id" "@pane-link"
      clear_pane_option "$pane_id" "@pane-link-source"
    fi
    return 0
  fi

  IFS=$'\t' read -r display_ref url <<EOF
$link
EOF
  if [ -z "$display_ref" ] || [ -z "$url" ]; then
    source="$(read_pane_option "$pane_id" "@pane-link-source" 2>/dev/null || true)"
    if [ "$source" = "pr-status-cache" ]; then
      clear_pane_option "$pane_id" "@pane-link"
      clear_pane_option "$pane_id" "@pane-link-source"
    fi
    return 0
  fi

  if tmux-pane-link --pane "$pane_id" "$display_ref" "$url" >/dev/null 2>&1; then
    write_pane_option "$pane_id" "@pane-link-source" "pr-status-cache"
  else
    source="$(read_pane_option "$pane_id" "@pane-link-source" 2>/dev/null || true)"
    if [ "$source" = "pr-status-cache" ]; then
      clear_pane_option "$pane_id" "@pane-link"
      clear_pane_option "$pane_id" "@pane-link-source"
    fi
  fi
}

repo_label_for_path() {
  local path="$1" formatted repo branch host

  formatted="$(formatted_repo_label_for_path "$path" 2>/dev/null || true)"
  if [ -n "$formatted" ]; then
    printf '%s\n' "$formatted"
    return 0
  fi

  repo="$(repo_basename "$path" 2>/dev/null || true)"
  branch="$(branch_for_path "$path" 2>/dev/null || true)"
  host="$(host_tag)"
  [ -n "$repo" ] || repo="$(dir_basename "$path")"

  if [ -n "$branch" ]; then
    if dirty_marker "$path"; then
      branch="*$branch"
    fi
    if [ -n "$host" ]; then
      printf '(%s) %s | %s\n' "$branch" "$repo" "$host"
    else
      printf '(%s) %s\n' "$branch" "$repo"
    fi
    return 0
  fi

  if [ -n "$host" ]; then
    printf '%s | %s\n' "$repo" "$host"
  else
    printf '%s\n' "$repo"
  fi
}

cmd_set() {
  local path="${1:-}" pane_id pane_pid tty
  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  [ -n "$path" ] || return 0
  case "$path" in
    /*) ;;
    *) return 0 ;;
  esac
  is_git_worktree_path "$path" || return 0
  pane_id="$TMUX_PANE"
  tty="$(pane_tty)"
  pane_pid=""
  if [ -n "$tty" ]; then
    pane_pid="$(detect_agent_pid "$tty" || true)"
  fi
  write_pane_option "$pane_id" "@agent_worktree_path" "$path"
  if [ -n "$pane_pid" ]; then
    write_pane_option "$pane_id" "@agent_worktree_pid" "$pane_pid"
  else
    clear_pane_option "$pane_id" "@agent_worktree_pid"
  fi
  write_pane_option "$pane_id" "@pane-label" "$(repo_label_for_path "$path")"
  publish_cached_pr_pane_link_for_path "$pane_id" "$path"
  refresh_agent_state
}

cmd_clear() {
  local subject
  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  subject="$(read_pane_option "$TMUX_PANE" "@agent_subject" 2>/dev/null || true)"
  clear_pane_option "$TMUX_PANE" "@agent_worktree_path"
  clear_pane_option "$TMUX_PANE" "@agent_worktree_pid"
  clear_pane_option "$TMUX_PANE" "@pane-label"
  clear_pane_option "$TMUX_PANE" "@pane-link"
  clear_pane_option "$TMUX_PANE" "@pane-link-source"
  if clear_agent_worktree; then
    if [ -n "$subject" ]; then
      mark_subject_stale || true
    fi
    return 0
  fi
  refresh_window_label
  publish_title
}

cmd_sync_current() {
  local tty pane_pid
  [ -n "${PWD:-}" ] || return 0
  if ! is_git_worktree_path "$PWD" || ! on_named_branch "$PWD"; then
    cmd_clear
    return 0
  fi

  [ -n "${TMUX:-}" ] || return 0
  [ -n "${TMUX_PANE:-}" ] || return 0
  tty="$(pane_tty)"
  pane_pid=""
  if [ -n "$tty" ]; then
    pane_pid="$(detect_agent_pid "$tty" || true)"
  fi

  write_pane_option "$TMUX_PANE" "@agent_worktree_path" "$PWD"
  if [ -n "$pane_pid" ]; then
    write_pane_option "$TMUX_PANE" "@agent_worktree_pid" "$pane_pid"
  else
    clear_pane_option "$TMUX_PANE" "@agent_worktree_pid"
  fi
  write_pane_option "$TMUX_PANE" "@pane-label" "$(repo_label_for_path "$PWD")"
  publish_cached_pr_pane_link_for_path "$TMUX_PANE" "$PWD"
  refresh_agent_state
}

main() {
  case "${1:-}" in
    set)
      shift
      cmd_set "${1:-}"
      ;;
    sync-current)
      cmd_sync_current
      ;;
    clear)
      cmd_clear
      ;;
    *)
      exit 0
      ;;
  esac
}

main "$@"
exit 0

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/repo-end"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

GIT_AUTHOR_NAME=test
GIT_AUTHOR_EMAIL=test@example.com
GIT_COMMITTER_NAME=test
GIT_COMMITTER_EMAIL=test@example.com
export GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL

stub_bin="$TMPROOT/bin"
mkdir -p "$stub_bin"
cat >"$stub_bin/cleanup-branches" <<'EOF'
#!/usr/bin/env bash
printf 'cleanup-branches should not be called\n' >&2
exit 99
EOF
chmod +x "$stub_bin/cleanup-branches"
export PATH="$stub_bin:$PATH"

create_remote_repo() {
  local name="$1"
  local origin="$TMPROOT/$name-origin.git"
  local repo="$TMPROOT/$name-repo"
  git init -q --bare "$origin"
  git init -qb main "$repo"
  git -C "$repo" remote add origin "$origin"
  git -C "$repo" commit -q --allow-empty -m init
  git -C "$repo" push -q -u origin main
  printf '%s\n' "$repo"
}

assert_file_contains() {
  local path="$1" needle="$2" name="$3"
  grep -Fq -- "$needle" "$path" || {
    printf 'FAIL  %s\nmissing %s in %s\n' "$name" "$needle" "$path" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

assert_equals_file() {
  local path="$1" expected="$2" name="$3"
  local actual
  actual="$(cat "$path")"
  [ "$actual" = "$expected" ] || {
    printf 'FAIL  %s\nexpected: %s\ngot: %s\n' "$name" "$expected" "$actual" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

assert_branch_absent() {
  local repo="$1" branch="$2" name="$3"
  if git -C "$repo" show-ref --verify --quiet "refs/heads/$branch"; then
    printf 'FAIL  %s\nbranch still exists: %s\n' "$name" "$branch" >&2
    exit 1
  fi
  printf 'PASS  %s\n' "$name"
}

assert_remote_branch_absent() {
  local origin="$1" branch="$2" name="$3"
  if git --git-dir="$origin" show-ref --verify --quiet "refs/heads/$branch"; then
    printf 'FAIL  %s\nremote branch still exists: %s\n' "$name" "$branch" >&2
    exit 1
  fi
  printf 'PASS  %s\n' "$name"
}

assert_origin_file() {
  local origin="$1" branch="$2" file="$3" expected="$4" name="$5"
  local actual
  actual="$(git --git-dir="$origin" show "$branch:$file")"
  [ "$actual" = "$expected" ] || {
    printf 'FAIL  %s\nexpected: %s\ngot: %s\n' "$name" "$expected" "$actual" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

branch_repo="$(create_remote_repo branch)"
git -C "$branch_repo" checkout -q -b feature/branch
printf 'branch\n' >"$branch_repo/branch.txt"
git -C "$branch_repo" add branch.txt
git -C "$branch_repo" commit -q -m branch
git -C "$branch_repo" push -q -u origin feature/branch
bash -c 'cd "$1" && "$2" --print-path' bash "$branch_repo" "$SCRIPT" >"$TMPROOT/branch.out" 2>"$TMPROOT/branch.err"
assert_equals_file "$TMPROOT/branch.out" "$branch_repo" 'repo-end print-path stdout contains only final main path'
[ "$(git -C "$branch_repo" branch --show-current)" = main ] || {
  printf 'expected repo-end to leave branch-mode repo on main\n' >&2
  exit 1
}
assert_branch_absent "$branch_repo" 'feature/branch' 'repo-end branch mode deletes merged local branch'
assert_remote_branch_absent "$TMPROOT/branch-origin.git" 'feature/branch' 'repo-end branch mode deletes merged remote branch'
assert_origin_file "$TMPROOT/branch-origin.git" main branch.txt branch 'repo-end branch mode pushes merged main'
printf 'PASS  repo-end branch mode merges pushes and cleans up internally\n'

config_repo="$(create_remote_repo config-dirty)"
git -C "$config_repo" checkout -q -b feature/config-dirty
printf 'config dirty\n' >"$config_repo/config.txt"
git -C "$config_repo" add config.txt
git -C "$config_repo" commit -q -m config-dirty
printf 'use_worktrees: false\n' >"$config_repo/.repo.yml"
bash -c 'cd "$1" && "$2" --print-path' bash "$config_repo" "$SCRIPT" >"$TMPROOT/config-dirty.out" 2>"$TMPROOT/config-dirty.err"
assert_branch_absent "$config_repo" 'feature/config-dirty' 'repo-end ignores untracked repo config while cleaning branch'

no_main_repo="$(create_remote_repo no-main-checkout)"
git -C "$no_main_repo" checkout -q -b parking
no_main_wt="$TMPROOT/no-main-wt"
git -C "$no_main_repo" worktree add -q -b feature/no-main "$no_main_wt" main
printf 'no main checkout\n' >"$no_main_wt/no-main.txt"
git -C "$no_main_wt" add no-main.txt
git -C "$no_main_wt" commit -q -m no-main
if bash -c 'cd "$1" && "$2" --print-path' bash "$no_main_wt" "$SCRIPT" >"$TMPROOT/no-main.out" 2>"$TMPROOT/no-main.err"; then
  printf 'expected linked worktree without main checkout to fail\n' >&2
  exit 1
fi
assert_file_contains "$TMPROOT/no-main.err" 'could not find main checkout' 'repo-end rejects linked worktree without main checkout'
[ "$(git -C "$no_main_wt" branch --show-current)" = 'feature/no-main' ] || {
  printf 'linked worktree should remain on feature/no-main\n' >&2
  exit 1
}

subdir_repo="$(create_remote_repo subdir)"
subdir_wt="$TMPROOT/subdir-wt"
git -C "$subdir_repo" worktree add -q -b feature/subdir "$subdir_wt" main
printf 'subdir\n' >"$subdir_wt/subdir.txt"
git -C "$subdir_wt" add subdir.txt
git -C "$subdir_wt" commit -q -m subdir
git -C "$subdir_wt" push -q -u origin feature/subdir
mkdir -p "$subdir_wt/nested/path"
bash -c 'cd "$1" && "$2" --print-path' bash "$subdir_wt/nested/path" "$SCRIPT" >"$TMPROOT/subdir.out" 2>"$TMPROOT/subdir.err"
assert_equals_file "$TMPROOT/subdir.out" "$subdir_repo" 'repo-end linked worktree prints final main path'
[ ! -d "$subdir_wt" ] || {
  printf 'expected repo-end to remove linked feature worktree\n' >&2
  exit 1
}
assert_branch_absent "$subdir_repo" 'feature/subdir' 'repo-end linked worktree deletes merged local branch'
assert_remote_branch_absent "$TMPROOT/subdir-origin.git" 'feature/subdir' 'repo-end linked worktree deletes merged remote branch'
assert_origin_file "$TMPROOT/subdir-origin.git" main subdir.txt subdir 'repo-end linked worktree pushes merged main'

dirty_repo="$(create_remote_repo dirty)"
git -C "$dirty_repo" checkout -q -b feature/dirty
printf 'dirty\n' >"$dirty_repo/dirty.txt"
if (cd "$dirty_repo" && "$SCRIPT") >"$TMPROOT/dirty.out" 2>"$TMPROOT/dirty.err"; then
  printf 'expected dirty repo-end to fail\n' >&2
  exit 1
fi
assert_file_contains "$TMPROOT/dirty.err" 'worktree has uncommitted changes' 'repo-end rejects dirty current worktree'

main_repo="$(create_remote_repo main-reject)"
if (cd "$main_repo" && "$SCRIPT") >"$TMPROOT/main.out" 2>"$TMPROOT/main.err"; then
  printf 'expected main repo-end to fail\n' >&2
  exit 1
fi
assert_file_contains "$TMPROOT/main.err" 'already on main' 'repo-end rejects main branch'

fetch_fail_repo="$(create_remote_repo fetch-fail)"
git -C "$fetch_fail_repo" checkout -q -b feature/fetch-fail
printf 'fetch fail\n' >"$fetch_fail_repo/fetch-fail.txt"
git -C "$fetch_fail_repo" add fetch-fail.txt
git -C "$fetch_fail_repo" commit -q -m fetch-fail
git -C "$fetch_fail_repo" remote set-url origin "$TMPROOT/missing-origin.git"
if bash -c 'cd "$1" && "$2" --print-path' bash "$fetch_fail_repo" "$SCRIPT" >"$TMPROOT/fetch-fail.out" 2>"$TMPROOT/fetch-fail.err"; then
  printf 'expected fetch failure to fail repo-end\n' >&2
  exit 1
fi
assert_file_contains "$TMPROOT/fetch-fail.err" 'failed to fetch origin' 'repo-end rejects stale remote refs when fetch fails'
[ "$(git -C "$fetch_fail_repo" branch --show-current)" = 'feature/fetch-fail' ] || {
  printf 'FAIL  repo-end changed branch after fetch failure\n' >&2
  exit 1
}
printf 'PASS  repo-end leaves cleanup undone after fetch failure\n'

ancestor_repo="$(create_remote_repo already-ancestor)"
git -C "$ancestor_repo" checkout -q -b feature/already-ancestor
printf 'ancestor work\n' >"$ancestor_repo/work.txt"
git -C "$ancestor_repo" add work.txt
git -C "$ancestor_repo" commit -q -m work
ancestor_origin="$TMPROOT/already-ancestor-origin.git"
ancestor_tip="$(git -C "$ancestor_repo" rev-parse HEAD)"
git -C "$ancestor_repo" push -q -u origin feature/already-ancestor
git -C "$ancestor_repo" push -q origin "+HEAD:refs/heads/main"
bash -c 'cd "$1" && "$2" --print-path' bash "$ancestor_repo" "$SCRIPT" >"$TMPROOT/already-ancestor.out" 2>"$TMPROOT/already-ancestor.err"
[ "$(git -C "$ancestor_repo" branch --show-current)" = 'main' ] || {
  printf 'FAIL  repo-end did not switch to main when feature is direct ancestor\n' >&2
  exit 1
}
[ "$(git -C "$ancestor_repo" rev-parse main)" = "$ancestor_tip" ] || {
  printf 'FAIL  repo-end did not update local main when feature is direct ancestor\n' >&2
  exit 1
}
assert_branch_absent "$ancestor_repo" 'feature/already-ancestor' 'repo-end deletes direct-ancestor local branch'
assert_remote_branch_absent "$ancestor_origin" 'feature/already-ancestor' 'repo-end deletes direct-ancestor remote branch'
post_origin_tip="$(git --git-dir="$ancestor_origin" rev-parse refs/heads/main)"
[ "$post_origin_tip" = "$ancestor_tip" ] || {
  printf 'FAIL  repo-end changed origin unexpectedly when already ancestor\n' >&2
  printf '      expected %s, origin now %s\n' "$ancestor_tip" "$post_origin_tip" >&2
  exit 1
}
printf 'PASS  repo-end skips push when feature is direct ancestor\n'

linked_ancestor_repo="$(create_remote_repo linked-already-ancestor)"
linked_ancestor_wt="$TMPROOT/linked-already-ancestor-wt"
git -C "$linked_ancestor_repo" worktree add -q -b feature/linked-already-ancestor "$linked_ancestor_wt" main
printf 'linked ancestor work\n' >"$linked_ancestor_wt/work.txt"
git -C "$linked_ancestor_wt" add work.txt
git -C "$linked_ancestor_wt" commit -q -m linked-ancestor
linked_ancestor_origin="$TMPROOT/linked-already-ancestor-origin.git"
linked_ancestor_tip="$(git -C "$linked_ancestor_wt" rev-parse HEAD)"
git -C "$linked_ancestor_wt" push -q -u origin feature/linked-already-ancestor
git -C "$linked_ancestor_wt" push -q origin "+HEAD:refs/heads/main"
bash -c 'cd "$1" && "$2" --print-path' bash "$linked_ancestor_wt" "$SCRIPT" >"$TMPROOT/linked-already-ancestor.out" 2>"$TMPROOT/linked-already-ancestor.err"
[ ! -d "$linked_ancestor_wt" ] || {
  printf 'FAIL  repo-end did not remove linked already-ancestor worktree\n' >&2
  exit 1
}
assert_branch_absent "$linked_ancestor_repo" 'feature/linked-already-ancestor' 'repo-end deletes linked direct-ancestor local branch'
assert_remote_branch_absent "$linked_ancestor_origin" 'feature/linked-already-ancestor' 'repo-end deletes linked direct-ancestor remote branch'
[ "$(git -C "$linked_ancestor_repo" rev-parse main)" = "$linked_ancestor_tip" ] || {
  printf 'FAIL  repo-end did not update linked main checkout when feature is direct ancestor\n' >&2
  exit 1
}
printf 'PASS  repo-end updates linked main when feature is direct ancestor\n'

reverted_repo="$(create_remote_repo reverted-historical-patch)"
reverted_origin="$TMPROOT/reverted-historical-patch-origin.git"
reverted_base="$(git -C "$reverted_repo" rev-parse HEAD)"
printf 'reintroduced work\n' >"$reverted_repo/reintroduced.txt"
git -C "$reverted_repo" add reintroduced.txt
git -C "$reverted_repo" commit -q -m add-reintroduced
git -C "$reverted_repo" rm -q reintroduced.txt
git -C "$reverted_repo" commit -q -m revert-reintroduced
git -C "$reverted_repo" push -q origin main
git -C "$reverted_repo" checkout -q -b feature/reintroduce "$reverted_base"
printf 'reintroduced work\n' >"$reverted_repo/reintroduced.txt"
git -C "$reverted_repo" add reintroduced.txt
git -C "$reverted_repo" commit -q -m reintroduce
git -C "$reverted_repo" push -q -u origin feature/reintroduce
bash -c 'cd "$1" && "$2" --print-path' bash "$reverted_repo" "$SCRIPT" >"$TMPROOT/reverted-historical-patch.out" 2>"$TMPROOT/reverted-historical-patch.err"
git --git-dir="$reverted_origin" cat-file -e refs/heads/main:reintroduced.txt || {
  printf 'FAIL  repo-end skipped integration for reverted historical patch\n' >&2
  exit 1
}
assert_branch_absent "$reverted_repo" 'feature/reintroduce' 'repo-end deletes branch after reintroducing reverted historical patch'
assert_remote_branch_absent "$reverted_origin" 'feature/reintroduce' 'repo-end deletes remote branch after reintroducing reverted historical patch'
printf 'PASS  repo-end does not treat reverted historical patch as already merged\n'

reverted_conflict_repo="$(create_remote_repo reverted-conflicting-squash)"
printf 'one\n' >"$reverted_conflict_repo/conflict.txt"
git -C "$reverted_conflict_repo" add conflict.txt
git -C "$reverted_conflict_repo" commit -q -m conflict-base
git -C "$reverted_conflict_repo" push -q origin main
reverted_conflict_base="$(git -C "$reverted_conflict_repo" rev-parse HEAD)"
printf 'ONE\n' >"$reverted_conflict_repo/conflict.txt"
git -C "$reverted_conflict_repo" add conflict.txt
git -C "$reverted_conflict_repo" commit -q -m apply-conflict-change
printf 'one\n' >"$reverted_conflict_repo/conflict.txt"
git -C "$reverted_conflict_repo" add conflict.txt
git -C "$reverted_conflict_repo" commit -q -m revert-conflict-change
printf 'UNO\n' >"$reverted_conflict_repo/conflict.txt"
git -C "$reverted_conflict_repo" add conflict.txt
git -C "$reverted_conflict_repo" commit -q -m supersede-reverted-change
git -C "$reverted_conflict_repo" push -q origin main
git -C "$reverted_conflict_repo" checkout -q -b feature/reverted-conflict "$reverted_conflict_base"
printf 'ONE\n' >"$reverted_conflict_repo/conflict.txt"
git -C "$reverted_conflict_repo" add conflict.txt
git -C "$reverted_conflict_repo" commit -q -m reapply-conflict-change
if bash -c 'cd "$1" && "$2" --print-path' bash "$reverted_conflict_repo" "$SCRIPT" >"$TMPROOT/reverted-conflicting-squash.out" 2>"$TMPROOT/reverted-conflicting-squash.err"; then
  printf 'FAIL  repo-end skipped reverted conflicting squash patch\n' >&2
  exit 1
fi
assert_file_contains "$TMPROOT/reverted-conflicting-squash.err" \
  'rebase has conflicts' \
  'repo-end rejects reverted conflicting squash patch'
git -C "$reverted_conflict_repo" rebase --abort >/dev/null 2>&1 || true
printf 'PASS  repo-end does not treat reverted conflicting squash patch as merged\n'

squash_repo="$(create_remote_repo squash-merged)"
printf 'one\ntwo\nthree\nfour\nfive\n' >"$squash_repo/squash.txt"
git -C "$squash_repo" add squash.txt
git -C "$squash_repo" commit -q -m squash-base
git -C "$squash_repo" push -q origin main
git -C "$squash_repo" checkout -q -b feature/squash-merged
printf 'ONE\ntwo\nthree\nfour\nfive\n' >"$squash_repo/squash.txt"
git -C "$squash_repo" add squash.txt
git -C "$squash_repo" commit -q -m 'squash work'
git -C "$squash_repo" push -q -u origin feature/squash-merged
squash_tree="$(git -C "$squash_repo" rev-parse HEAD^{tree})"
squash_parent="$(git -C "$squash_repo" rev-parse 'HEAD~1')"
squash_origin="$TMPROOT/squash-merged-origin.git"
squash_commit="$(git -C "$squash_repo" commit-tree "$squash_tree" -p "$squash_parent" -m 'squash merge of feature/squash-merged')"
git -C "$squash_repo" push -q origin "+${squash_commit}:refs/heads/main"
git -C "$squash_repo" branch -f main "$squash_commit"
git -C "$squash_repo" checkout -q main
printf 'UNO\ntwo\nthree\nfour\nfive\n' >"$squash_repo/squash.txt"
git -C "$squash_repo" add squash.txt
git -C "$squash_repo" commit -q -m 'post squash edit'
post_squash_commit="$(git -C "$squash_repo" rev-parse HEAD)"
git -C "$squash_repo" push -q origin main
git -C "$squash_repo" checkout -q feature/squash-merged
bash -c 'cd "$1" && "$2" --print-path' bash "$squash_repo" "$SCRIPT" >"$TMPROOT/squash.out" 2>"$TMPROOT/squash.err"
[ "$(git -C "$squash_repo" branch --show-current)" = 'main' ] || {
  printf 'FAIL  repo-end did not switch to main when feature is squash-merged\n' >&2
  exit 1
}
assert_branch_absent "$squash_repo" 'feature/squash-merged' 'repo-end deletes squash-merged local branch'
assert_remote_branch_absent "$squash_origin" 'feature/squash-merged' 'repo-end deletes squash-merged remote branch'
[ "$(git -C "$squash_repo" rev-parse main)" = "$post_squash_commit" ] || {
  printf 'FAIL  repo-end did not update local main when feature is squash-merged\n' >&2
  exit 1
}
post_squash_tip="$(git --git-dir="$squash_origin" rev-parse refs/heads/main)"
[ "$post_squash_tip" = "$post_squash_commit" ] || {
  printf 'FAIL  repo-end pushed beyond squash commit\n' >&2
  printf '      expected %s, origin now %s\n' "$post_squash_commit" "$post_squash_tip" >&2
  exit 1
}
printf 'PASS  repo-end skips push when squash-merged file changed later\n'

printf 'PASS  repo-end regression test\n'

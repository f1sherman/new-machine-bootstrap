#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-remote-title"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

export GIT_AUTHOR_NAME=test
export GIT_AUTHOR_EMAIL=test@example.com
export GIT_COMMITTER_NAME=test
export GIT_COMMITTER_EMAIL=test@example.com

assert_eq() {
  local actual="$1" expected="$2" label="$3"
  if [ "$actual" != "$expected" ]; then
    printf 'FAIL  %s\nexpected: %s\ngot: %s\n' "$label" "$expected" "$actual" >&2
    exit 1
  fi
  printf 'PASS  %s\n' "$label"
}

make_repo() {
  local dir="$1"
  git init -qb main "$dir"
  git -C "$dir" commit -q --allow-empty -m init
}

make_linked_worktree() {
  local repo="$1" branch="$2" dest="$3"
  git -C "$repo" worktree add -q -b "$branch" "$dest"
}

run_print_case() {
  local label="$1" pane_path="$2" worktree_path="$3" worktree_pid="$4" ps_detail="$5" host_tag="$6" expected="$7"
  local ps_file output
  ps_file="$TMPROOT/$label.ps"
  printf '%s' "$ps_detail" > "$ps_file"

  output="$(
    TMUX=/tmp/fake \
    TMUX_PANE=%91 \
    TMUX_REMOTE_TITLE_PANE_PATH="$pane_path" \
    TMUX_REMOTE_TITLE_CLIENT_TTY="$TMPROOT/$label.client" \
    TMUX_REMOTE_TITLE_WORKTREE_PATH="$worktree_path" \
    TMUX_REMOTE_TITLE_WORKTREE_PID="$worktree_pid" \
    TMUX_REMOTE_TITLE_PS_FILE="$ps_file" \
    TMUX_REMOTE_TITLE_HOST_TAG="$host_tag" \
    "$SCRIPT" print
  )"

  assert_eq "$output" "$expected" "$label"
}

run_publish_case() {
  local label="$1" pane_path="$2" worktree_path="$3" worktree_pid="$4" ps_detail="$5" host_tag="$6" expected="$7"
  local ps_file client_tty
  ps_file="$TMPROOT/$label.ps"
  client_tty="$TMPROOT/$label.client"
  printf '%s' "$ps_detail" > "$ps_file"
  : > "$client_tty"

  TMUX=/tmp/fake \
  TMUX_PANE=%91 \
  TMUX_REMOTE_TITLE_PANE_PATH="$pane_path" \
  TMUX_REMOTE_TITLE_CLIENT_TTY="$client_tty" \
  TMUX_REMOTE_TITLE_WORKTREE_PATH="$worktree_path" \
  TMUX_REMOTE_TITLE_WORKTREE_PID="$worktree_pid" \
  TMUX_REMOTE_TITLE_PS_FILE="$ps_file" \
  TMUX_REMOTE_TITLE_HOST_TAG="$host_tag" \
  "$SCRIPT" publish

  assert_eq "$(cat "$client_tty")" "$(printf '\033]2;%s\033\\' "$expected")" "$label"
}

main_repo="$TMPROOT/repo"
make_repo "$main_repo"

linked_wt="$TMPROOT/linked-wt"
make_linked_worktree "$main_repo" "feature/title-sync" "$linked_wt"

dirty_wt="$TMPROOT/dirty-wt"
make_linked_worktree "$main_repo" "feature/dirty-title" "$dirty_wt"
printf 'dirty\n' > "$dirty_wt/untracked.txt"

run_print_case \
  "linked clean worktree prints branch repo host" \
  "$main_repo" \
  "$linked_wt" \
  "9100" \
  $'9100 S+ codex codex --cd /tmp/irrelevant' \
  "claw02" \
  "(feature/title-sync) linked-wt | claw02"

run_print_case \
  "linked dirty worktree adds star" \
  "$main_repo" \
  "$dirty_wt" \
  "9101" \
  $'9101 S+ codex codex --cd /tmp/irrelevant' \
  "claw02" \
  "(*feature/dirty-title) dirty-wt | claw02"

run_print_case \
  "stale explicit pid falls back to pane directory" \
  "$main_repo" \
  "$linked_wt" \
  "9999" \
  $'9100 S+ codex codex --cd /tmp/irrelevant' \
  "claw02" \
  "repo | claw02"

run_publish_case \
  "publish writes osc title to client tty" \
  "$main_repo" \
  "$linked_wt" \
  "9100" \
  $'9100 S+ codex codex --cd /tmp/irrelevant' \
  "claw02" \
  "(feature/title-sync) linked-wt | claw02"

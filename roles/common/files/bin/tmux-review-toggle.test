#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-review-toggle"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

pass=0
fail=0

state_file() {
  printf '%s/%s.%s\n' "$1" "$2" "$3"
}

assert_eq() {
  local name="$1" expected="$2" actual="$3"
  if [ "$expected" = "$actual" ]; then
    pass=$((pass + 1))
    printf 'PASS  %s\n' "$name"
  else
    fail=$((fail + 1))
    printf 'FAIL  %s\n' "$name"
    printf '      expected: %q\n' "$expected"
    printf '      actual  : %q\n' "$actual"
  fi
}

make_fake_tmux() {
  local fake_tmux="$1"
  cat > "$fake_tmux" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

fake_dir="${TMUX_REVIEW_FAKE_DIR:?}"
cmd="${1:?}"
shift || true

find_pane_field() {
  local pane_id="$1" field="$2" index=0
  case "$field" in
    window_id) index=2 ;;
    path) index=3 ;;
    *) exit 1 ;;
  esac
  awk -F $'\t' -v pane="$pane_id" -v index="$index" '$1 == pane { print $index; exit }' "$fake_dir/panes.tsv"
}

window_exists() {
  grep -Fqx -- "$1" "$fake_dir/window_ids" 2>/dev/null
}

pane_exists() {
  awk -F $'\t' -v pane="$1" '$1 == pane { found = 1 } END { exit found ? 0 : 1 }' "$fake_dir/panes.tsv"
}

case "$cmd" in
  display-message)
    if [ "${1:-}" = "-p" ]; then
      shift
      target=""
      if [ "${1:-}" = "-t" ]; then
        target="$2"
        shift 2
      fi
      format="${1:-}"
      case "$format" in
        '#{window_id}')
          if [[ "$target" == %* ]]; then
            value="$(find_pane_field "$target" window_id || true)"
            [ -n "$value" ] || exit 1
            printf '%s\n' "$value"
          else
            window_exists "$target" || exit 1
            printf '%s\n' "$target"
          fi
          ;;
        '#{pane_id}')
          pane_exists "$target" || exit 1
          printf '%s\n' "$target"
          ;;
        *)
          exit 1
          ;;
      esac
    else
      printf '%s\n' "$*" > "$fake_dir/message"
    fi
    ;;
  select-window)
    [ "${1:-}" = "-t" ] || exit 1
    printf '%s\n' "$2" > "$fake_dir/select_window"
    ;;
  select-pane)
    [ "${1:-}" = "-t" ] || exit 1
    printf '%s\n' "$2" > "$fake_dir/select_pane"
    ;;
  switch-client)
    [ "${1:-}" = "-t" ] || exit 1
    printf '%s\n' "$2" > "$fake_dir/switch_target"
    ;;
  *)
    exit 1
    ;;
esac
EOF
  chmod +x "$fake_tmux"
}

seed_fake_tmux() {
  local fake_dir="$1"
  mkdir -p "$fake_dir"
  : > "$fake_dir/window_ids"
  : > "$fake_dir/panes.tsv"
}

run_toggle() {
  local state_dir="$1" fake_tmux="$2" pane_id="$3"
  if (
    export TMUX="/tmp/fake-tmux"
    export TMUX_PANE="$pane_id"
    export TMUX_REVIEW_STATE_DIR="$state_dir"
    export TMUX_REVIEW_FAKE_DIR="$(dirname "$fake_tmux")/fake"
    export TMUX_REVIEW_TMUX_BIN="$fake_tmux"
    "$SCRIPT"
  ); then
    return 0
  fi
  return $?
}

# Case 1: origin pane jumps to its mapped review window.
state_dir="$TMPROOT/state1"
fake_tmux="$TMPROOT/fake-tmux-1"
seed_fake_tmux "$TMPROOT/fake1"
printf '%s\n%s\n' "@1" "@21" >> "$TMPROOT/fake1/window_ids"
printf '%s\t%s\t%s\n' "%1" "@1" "$TMPROOT/repo" >> "$TMPROOT/fake1/panes.tsv"
mkdir -p "$state_dir"
printf '%s' "@21" > "$(state_file "$state_dir" "%1" "@review_window_id")"
make_fake_tmux "$fake_tmux"
if run_toggle "$state_dir" "$fake_tmux" "%1"; then
  assert_eq "origin pane toggles to review window" "@21" "$(cat "$TMPROOT/fake1/switch_target")"
else
  fail=$((fail + 1))
  printf 'FAIL  origin to review exited nonzero\n'
fi

# Case 2: review pane returns to its origin pane.
state_dir="$TMPROOT/state2"
fake_tmux="$TMPROOT/fake-tmux-2"
seed_fake_tmux "$TMPROOT/fake2"
printf '%s\n%s\n' "@1" "@21" >> "$TMPROOT/fake2/window_ids"
printf '%s\t%s\t%s\n' "%1" "@1" "$TMPROOT/repo" >> "$TMPROOT/fake2/panes.tsv"
printf '%s\t%s\t%s\n' "%91" "@21" "$TMPROOT/repo" >> "$TMPROOT/fake2/panes.tsv"
mkdir -p "$state_dir"
printf '%s' "%1" > "$(state_file "$state_dir" "@21" "@review_origin_pane_id")"
printf '%s' "@1" > "$(state_file "$state_dir" "@21" "@review_origin_window_id")"
make_fake_tmux "$fake_tmux"
if run_toggle "$state_dir" "$fake_tmux" "%91"; then
  assert_eq "review pane selects origin window" "@1" "$(cat "$TMPROOT/fake2/select_window")"
  assert_eq "review pane selects origin pane" "%1" "$(cat "$TMPROOT/fake2/select_pane")"
else
  fail=$((fail + 1))
  printf 'FAIL  review to origin exited nonzero\n'
fi

# Case 3: missing origin pane falls back to origin window.
state_dir="$TMPROOT/state3"
fake_tmux="$TMPROOT/fake-tmux-3"
seed_fake_tmux "$TMPROOT/fake3"
printf '%s\n%s\n' "@1" "@21" >> "$TMPROOT/fake3/window_ids"
printf '%s\t%s\t%s\n' "%91" "@21" "$TMPROOT/repo" >> "$TMPROOT/fake3/panes.tsv"
mkdir -p "$state_dir"
printf '%s' "%1" > "$(state_file "$state_dir" "@21" "@review_origin_pane_id")"
printf '%s' "@1" > "$(state_file "$state_dir" "@21" "@review_origin_window_id")"
make_fake_tmux "$fake_tmux"
if run_toggle "$state_dir" "$fake_tmux" "%91"; then
  assert_eq "missing origin pane still selects origin window" "@1" "$(cat "$TMPROOT/fake3/select_window")"
else
  fail=$((fail + 1))
  printf 'FAIL  missing origin pane exited nonzero\n'
fi

# Case 4: missing review window shows a status message and exits cleanly.
state_dir="$TMPROOT/state4"
fake_tmux="$TMPROOT/fake-tmux-4"
seed_fake_tmux "$TMPROOT/fake4"
printf '%s\n' "@1" >> "$TMPROOT/fake4/window_ids"
printf '%s\t%s\t%s\n' "%1" "@1" "$TMPROOT/repo" >> "$TMPROOT/fake4/panes.tsv"
mkdir -p "$state_dir"
printf '%s' "@21" > "$(state_file "$state_dir" "%1" "@review_window_id")"
make_fake_tmux "$fake_tmux"
if run_toggle "$state_dir" "$fake_tmux" "%1"; then
  assert_eq "missing review window emits message" "No review window for current pane" "$(cat "$TMPROOT/fake4/message")"
else
  fail=$((fail + 1))
  printf 'FAIL  missing review window exited nonzero\n'
fi

printf '\n%d passed, %d failed\n' "$pass" "$fail"
[ "$fail" -eq 0 ]

#!/usr/bin/env bash
set -euo pipefail

reason='Do not push to main directly. Open a PR.'
command="$(jq -r '.tool_input.command // empty' 2>/dev/null || true)"

if [[ -z "$command" ]]; then
  exit 0
fi

should_deny="$(COMMAND="$command" python3 - <<'PY'
import os
import re
import shlex
import subprocess

command = os.environ['COMMAND']


def current_branch(repo_args):
    try:
        return subprocess.check_output(
            ['git', *repo_args, 'branch', '--show-current'],
            stderr=subprocess.DEVNULL,
            text=True,
        ).strip()
    except subprocess.CalledProcessError:
        return ''


def token_segments(command_text):
    lexer = shlex.shlex(command_text, posix=True, punctuation_chars=';&|()')
    lexer.whitespace_split = True
    tokens = list(lexer)
    segments = []
    current = []
    for token in tokens:
        if token in {';', '&&', '||', '|', '(', ')'}:
            if current:
                segments.append(current)
                current = []
            continue
        current.append(token)
    if current:
        segments.append(current)
    return segments


def is_assignment(token):
    return re.fullmatch(r'[A-Za-z_][A-Za-z0-9_]*=.*', token) is not None


def is_shell_separator(token):
    return token in {';', '&&', '||', '|', '(', ')'}


def refspec_targets_main(token):
    token = token.lstrip('+')
    if token in {'main', 'refs/heads/main'}:
        return True
    if ':' not in token:
        return False
    _, dst = token.rsplit(':', 1)
    return dst in {'', 'main', 'refs/heads/main'}


def repo_flag_args(tokens, index):
    repo_args = []
    while index < len(tokens):
        token = tokens[index]
        if token == 'push' or is_shell_separator(token):
            break
        if token in {'-C', '--git-dir', '--work-tree'}:
            repo_args.append(token)
            index += 1
            if index < len(tokens):
                repo_args.append(tokens[index])
                index += 1
            continue
        if token.startswith('--git-dir=') or token.startswith('--work-tree=') or token.startswith('-C'):
            repo_args.append(token)
            index += 1
            continue
        if token == '-c':
            index += 1
            if index < len(tokens):
                index += 1
            continue
        if token.startswith('-'):
            index += 1
            continue
        break
    return repo_args, index


def sudo_invocation(tokens, index):
    while index < len(tokens) and tokens[index].startswith('-'):
        index += 1
    return index < len(tokens) and tokens[index] == 'git', index


def segment_is_blocking(segment):
    index = 0
    while index < len(segment) and (segment[index] == 'env' or is_assignment(segment[index]) or segment[index] == 'command'):
        index += 1

    if index < len(segment) and segment[index] == 'sudo':
        index += 1
        is_git, index = sudo_invocation(segment, index)
        if not is_git:
            return False
    elif index >= len(segment) or segment[index] != 'git':
        return False
    index += 1

    repo_args, index = repo_flag_args(segment, index)

    if index >= len(segment) or segment[index] != 'push':
        return False
    index += 1

    push_args = [token for token in segment[index:] if not token.startswith('-')]
    if len(push_args) >= 2 and any(refspec_targets_main(token) for token in push_args[1:]):
        return True

    if current_branch(repo_args) == 'main' and len(push_args) <= 1:
        return True

    return False

for segment in token_segments(command):
    if segment_is_blocking(segment):
        print('deny')
        break
else:
    print('allow')
PY
)"

if [[ "$should_deny" != deny ]]; then
  exit 0
fi

jq -n --arg reason "$reason" '{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": $reason
  }
}'

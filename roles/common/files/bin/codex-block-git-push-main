#!/usr/bin/env bash
set -euo pipefail

reason='Do not push to main directly. Open a PR.'
command="$(jq -r '.tool_input.command // empty' 2>/dev/null || true)"

if [[ -z "$command" ]]; then
  exit 0
fi

should_deny="$(COMMAND="$command" python3 - <<'PY'
import os
import re
import shlex
import subprocess
from pathlib import PurePath

command = os.environ['COMMAND']


def current_branch(repo_args, repo_env):
    try:
        env = os.environ.copy()
        env.update(repo_env)
        return subprocess.check_output(
            ['git', *repo_args, 'branch', '--show-current'],
            env=env,
            stderr=subprocess.DEVNULL,
            text=True,
        ).strip()
    except subprocess.CalledProcessError:
        return ''


def token_segments(command_text):
    lexer = shlex.shlex(command_text, posix=True, punctuation_chars=';&|()')
    lexer.whitespace_split = True
    tokens = list(lexer)
    segments = []
    current = []
    for token in tokens:
        if token in {';', '&&', '||', '|', '(', ')'}:
            if current:
                segments.append(current)
                current = []
            continue
        current.append(token)
    if current:
        segments.append(current)
    return segments


def is_assignment(token):
    return re.fullmatch(r'[A-Za-z_][A-Za-z0-9_]*=.*', token) is not None


def is_shell_separator(token):
    return token in {';', '&&', '||', '|', '(', ')'}


def shell_wrapper_name(token):
    return PurePath(token).name


def is_shell_wrapper(token):
    return shell_wrapper_name(token) in {'sh', 'bash'}


def refspec_targets_main(token):
    token = token.lstrip('+')
    if token in {'main', 'refs/heads/main'}:
        return True
    if ':' not in token:
        return False
    _, dst = token.rsplit(':', 1)
    return dst in {'', 'main', 'refs/heads/main'}


def repo_flag_args(tokens, index):
    repo_args = []
    while index < len(tokens):
        token = tokens[index]
        if token == 'push' or is_shell_separator(token):
            break
        if token in {'-C', '--git-dir', '--work-tree'}:
            repo_args.append(token)
            index += 1
            if index < len(tokens):
                repo_args.append(tokens[index])
                index += 1
            continue
        if token.startswith('--git-dir=') or token.startswith('--work-tree=') or token.startswith('-C'):
            repo_args.append(token)
            index += 1
            continue
        if token == '-c':
            index += 1
            if index < len(tokens):
                index += 1
            continue
        if token.startswith('-'):
            index += 1
            continue
        break
    return repo_args, index


def shell_wrapper_payload(tokens, index):
    if index + 1 >= len(tokens):
        return None
    if not is_shell_wrapper(tokens[index]):
        return None
    option = tokens[index + 1]
    if not option.startswith('-') or 'c' not in option:
        return None
    if index + 2 >= len(tokens):
        return None
    return tokens[index + 2]


def command_text_is_blocking(command_text):
    for segment in token_segments(command_text):
        if segment_is_blocking(segment):
            return True
    return False


def segment_is_blocking(segment):
    index = 0
    repo_env = {}
    while index < len(segment):
        token = segment[index]
        if is_assignment(token):
            key, value = token.split('=', 1)
            if key in {'GIT_DIR', 'GIT_WORK_TREE'}:
                repo_env[key] = value
            index += 1
            continue
        if token in {'env', 'command', 'if', 'then', 'do', 'else', 'elif', 'fi', 'done', '!'}:
            index += 1
            continue
        if token in {'while', 'until', '{'}:
            index += 1
            continue
        if token == 'time':
            index += 1
            while index < len(segment) and segment[index].startswith('-'):
                index += 1
            continue
        if token == 'sudo':
            index += 1
            while index < len(segment) and segment[index].startswith('-'):
                index += 1
            continue
        payload = shell_wrapper_payload(segment, index)
        if payload is not None:
            if command_text_is_blocking(payload):
                return True
            index += 3
            continue
        break

    if index >= len(segment) or segment[index] != 'git':
        return False
    index += 1

    repo_args, index = repo_flag_args(segment, index)

    if index >= len(segment) or segment[index] != 'push':
        return False
    index += 1

    push_tokens = segment[index:]
    if any(token in {'--all', '--mirror'} for token in push_tokens):
        return True

    push_args = [token for token in push_tokens if not token.startswith('-')]
    if len(push_args) >= 2 and any(refspec_targets_main(token) for token in push_args[1:]):
        return True

    if current_branch(repo_args, repo_env) == 'main' and len(push_args) <= 1:
        return True

    return False

for segment in token_segments(command):
    if segment_is_blocking(segment):
        print('deny')
        break
else:
    print('allow')
PY
)"

if [[ "$should_deny" != deny ]]; then
  exit 0
fi

jq -n --arg reason "$reason" '{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": $reason
  }
}'

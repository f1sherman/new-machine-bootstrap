#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-attach-or-new"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

pass=0
fail=0

# Stateful tmux mock. Sessions live in a TSV state file (attached<TAB>name).
# list-sessions reads it; new-session/kill-session mutate it. attach is a
# no-op (we just check that the script exec'd attach as its last call).
make_mock_tmux() {
  cat > "$1" <<'EOF'
#!/usr/bin/env bash
set -eu
printf '%s\n' "$*" >> "$TMUX_ATTACH_LOG"
op="${1:-}"; shift || true
state="$TMUX_ATTACH_STATE"
case "$op" in
  list-sessions)
    [ -s "$state" ] || exit 1
    cat "$state"
    ;;
  new-session)
    name=""
    while [ $# -gt 0 ]; do
      case "$1" in
        -d|-A) shift ;;
        -s) name="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [ -z "$name" ]; then
      n=0
      while grep -q $'\t'"$n"$ "$state" 2>/dev/null; do n=$((n+1)); done
      name="$n"
    fi
    printf '0\t%s\n' "$name" >> "$state"
    ;;
  kill-session)
    target=""
    while [ $# -gt 0 ]; do
      case "$1" in
        -t) target="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    grep -v $'\t'"$target"$ "$state" > "$state.tmp" 2>/dev/null || :
    mv -f "$state.tmp" "$state" 2>/dev/null || :
    ;;
  attach) : ;;
  display-message)
    # Minimal mock: tests pass an expected fake socket path via env so the
    # script's `tmux display-message -p '#{socket_path}'` resolves to it.
    printf '%s\n' "${MOCK_TMUX_SOCKET_PATH:-/tmp/mock-tmux-socket}"
    ;;
  *)
    printf 'unexpected tmux invocation: %s %s\n' "$op" "$*" >&2
    exit 99
    ;;
esac
EOF
  chmod +x "$1"
}

# Stage a mock resurrect restore.sh that records the value of $TMUX it
# was invoked with and (optionally) appends a saved session to the mock
# state file to simulate a successful restore.
make_mock_resurrect() {
  local fake_home="$1" record_file="$2" extra_session="${3:-}"
  local resurrect_dir="$fake_home/.tmux/plugins/tmux-resurrect/scripts"
  mkdir -p "$resurrect_dir"
  {
    printf '#!/usr/bin/env bash\n'
    printf 'printf "%%s" "${TMUX:-}" > %q\n' "$record_file"
    if [ -n "$extra_session" ]; then
      printf 'printf "0\\t%%s\\n" %q >> "$TMUX_ATTACH_STATE"\n' "$extra_session"
    fi
  } > "$resurrect_dir/restore.sh"
  chmod +x "$resurrect_dir/restore.sh"
}

run_case() {
  local name="$1" initial_state="$2" expected_last="$3"
  local fake_home bindir log state lock rc last_invocation

  fake_home="$(mktemp -d "$TMPROOT/home.XXXXXX")"
  bindir="$fake_home/.local/bin"
  mkdir -p "$bindir"
  log="$fake_home/tmux.log"
  state="$fake_home/state"
  lock="$fake_home/lock"
  printf '%s' "$initial_state" > "$state"

  make_mock_tmux "$bindir/tmux"

  if PATH="$bindir:$PATH" \
    TMUX_ATTACH_LOG="$log" \
    TMUX_ATTACH_STATE="$state" \
    TMUX_ATTACH_LOCK_FILE="$lock" \
    TMUX_ATTACH_LOCK_TIMEOUT=2 \
    HOME="$fake_home" \
    "$SCRIPT"
  then
    rc=0
  else
    rc=$?
  fi

  last_invocation="$(tail -1 "$log" 2>/dev/null || echo)"
  if [ "$rc" -eq 0 ] && [ "$last_invocation" = "$expected_last" ]; then
    pass=$((pass + 1))
    printf 'PASS  %s\n' "$name"
  else
    fail=$((fail + 1))
    printf 'FAIL  %s\n' "$name"
    printf '      rc: %s\n' "$rc"
    printf '      last invocation: %s\n' "$last_invocation"
    printf '      expected:        %s\n' "$expected_last"
    printf '      full log:\n'
    sed 's/^/        /' "$log"
  fi
}

run_case \
  "first unattached session is reused" \
  $'1\tbusy\n0\talpha\n0\tbeta' \
  "attach -t =alpha"

run_case \
  "all sessions attached starts a new one" \
  $'1\tbusy\n1\tother' \
  "new-session"

run_case \
  "no server bootstraps and attaches to placeholder when restore is unavailable" \
  "" \
  "attach -t =__bootstrap__"

# Regression: when bootstrapping a fresh tmux server, tmux-attach-or-new
# must invoke tmux-resurrect's restore.sh with a non-empty $TMUX so the
# plugin's tmux_socket() helper (echo $TMUX | cut -d',' -f1) returns the
# real socket path. Without this, every `tmux -S "$(tmux_socket)" new-session`
# call inside restore.sh runs as `tmux -S "" new-session ...` and fails
# with "error creating  (No such file or directory)" — leaving only the
# __bootstrap__ placeholder behind.
run_restore_tmux_env_case() {
  local name="bootstrap invokes restore.sh with TMUX populated"
  local fake_home bindir log state lock record rc tmux_value
  fake_home="$(mktemp -d "$TMPROOT/home.XXXXXX")"
  bindir="$fake_home/.local/bin"
  mkdir -p "$bindir"
  log="$fake_home/tmux.log"
  state="$fake_home/state"
  lock="$fake_home/lock"
  record="$fake_home/restore-tmux"

  : > "$state"
  make_mock_tmux "$bindir/tmux"
  make_mock_resurrect "$fake_home" "$record" "restored-session"

  # Unset TMUX so we accurately simulate launch from a login shell
  # outside any tmux client (the only way the bootstrap path fires in
  # production).
  if env -u TMUX \
    PATH="$bindir:$PATH" \
    TMUX_ATTACH_LOG="$log" \
    TMUX_ATTACH_STATE="$state" \
    TMUX_ATTACH_LOCK_FILE="$lock" \
    TMUX_ATTACH_LOCK_TIMEOUT=2 \
    HOME="$fake_home" \
    MOCK_TMUX_SOCKET_PATH="/tmp/fake-tmux-socket-path" \
    "$SCRIPT"
  then
    rc=0
  else
    rc=$?
  fi

  tmux_value="$(cat "$record" 2>/dev/null || true)"
  if [ "$rc" -eq 0 ] && [ -n "$tmux_value" ] \
     && [[ "$tmux_value" == /tmp/fake-tmux-socket-path* ]]; then
    pass=$((pass + 1))
    printf 'PASS  %s\n' "$name"
  else
    fail=$((fail + 1))
    printf 'FAIL  %s\n' "$name"
    printf '      rc: %s\n' "$rc"
    printf '      recorded TMUX: %q\n' "$tmux_value"
    printf '      full log:\n'
    sed 's/^/        /' "$log"
  fi
}

run_restore_tmux_env_case

printf '\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
[ "$fail" -eq 0 ]

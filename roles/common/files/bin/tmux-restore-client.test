#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-restore-client"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

pass=0
fail=0
LIST_SESSIONS_CMD='list-sessions -F #{session_attached}\t#{session_name}'

run_case() {
  local name="$1" explicit="$2" list_output="$3" has_target="$4" expected_log="$5" list_behavior="${6:-normal}" attach_behavior="${7:-normal}"
  local bindir log rc

  bindir="$(mktemp -d "$TMPROOT/bin.XXXXXX")"
  log="$(mktemp "$TMPROOT/tmux.XXXXXX")"
  count_file="$TMPROOT/tmux.list-count.$RANDOM"

  cat > "$bindir/tmux" <<'EOF'
#!/usr/bin/env bash
set -eu

printf '%s\n' "$*" >> "$TMUX_RESTORE_CLIENT_LOG"

case "${1:-}" in
  has-session)
    [ "${3:-}" = "$TMUX_RESTORE_CLIENT_HAS_TARGET" ]
    ;;
  list-sessions)
    count=0
    if [ -n "${TMUX_RESTORE_CLIENT_LIST_COUNT_FILE:-}" ] && [ -f "$TMUX_RESTORE_CLIENT_LIST_COUNT_FILE" ]; then
      count=$(cat "$TMUX_RESTORE_CLIENT_LIST_COUNT_FILE")
    fi
    count=$((count + 1))
    if [ -n "${TMUX_RESTORE_CLIENT_LIST_COUNT_FILE:-}" ]; then
      printf '%s\n' "$count" > "$TMUX_RESTORE_CLIENT_LIST_COUNT_FILE"
    fi

    case "${TMUX_RESTORE_CLIENT_LIST_BEHAVIOR:-normal}" in
      fail_first)
        if [ "$count" -eq 1 ]; then
          exit 99
        fi
        ;;
    esac

    printf '%s\n' "$TMUX_RESTORE_CLIENT_LIST"
    ;;
  attach)
    case "${TMUX_RESTORE_CLIENT_ATTACH_BEHAVIOR:-normal}" in
      fail)
        exit 99
        ;;
    esac
    exit 0
    ;;
  new-session)
    exit 0
    ;;
  *)
    printf 'unexpected tmux invocation: %s\n' "$*" >&2
    exit 99
    ;;
esac
EOF
  chmod +x "$bindir/tmux"

  if [ -n "$explicit" ]; then
    if PATH="$bindir:$PATH" \
      TMUX_RESTORE_CLIENT_LOG="$log" \
      TMUX_RESTORE_CLIENT_LIST="$list_output" \
      TMUX_RESTORE_CLIENT_HAS_TARGET="$has_target" \
      TMUX_RESTORE_CLIENT_LIST_BEHAVIOR="$list_behavior" \
      TMUX_RESTORE_CLIENT_LIST_COUNT_FILE="$count_file" \
      TMUX_RESTORE_CLIENT_ATTACH_BEHAVIOR="$attach_behavior" \
      "$SCRIPT" --session "$explicit"
    then
      rc=0
    else
      rc=$?
    fi
  else
    if PATH="$bindir:$PATH" \
      TMUX_RESTORE_CLIENT_LOG="$log" \
      TMUX_RESTORE_CLIENT_LIST="$list_output" \
      TMUX_RESTORE_CLIENT_HAS_TARGET="$has_target" \
      TMUX_RESTORE_CLIENT_LIST_BEHAVIOR="$list_behavior" \
      TMUX_RESTORE_CLIENT_LIST_COUNT_FILE="$count_file" \
      TMUX_RESTORE_CLIENT_ATTACH_BEHAVIOR="$attach_behavior" \
      "$SCRIPT"
    then
      rc=0
    else
      rc=$?
    fi
  fi

  if [ "$rc" -eq 0 ] && diff -u <(printf '%s\n' "$expected_log") "$log" >/dev/null; then
    pass=$((pass + 1))
    printf 'PASS  %s\n' "$name"
  else
    fail=$((fail + 1))
    printf 'FAIL  %s\n' "$name"
    printf '      rc: %s\n' "$rc"
    printf '      log:\n'
    sed 's/^/        /' "$log"
  fi
}

run_case \
  "explicit session wins" \
  "focus" \
  $'has-session -t =focus\nattach -t =focus' \
  "=focus" \
  $'has-session -t =focus\nattach -t =focus'

run_case \
  "first unattached session is reused" \
  "" \
  $'1\tbusy\n0\talpha\n0\tbeta' \
  "" \
  "${LIST_SESSIONS_CMD}
attach -t =alpha"

run_case \
  "explicit attach failure falls back to new-session" \
  "focus" \
  $'1\tother\n0\tfocus' \
  "=focus" \
  $'has-session -t =focus\nattach -t =focus\nnew-session' \
  "normal" \
  "fail"

run_case \
  "--session missing falls back to first unattached" \
  "missing" \
  $'1\tbusy\n0\talpha\n0\tbeta' \
  "" \
  $'has-session -t =missing\n'"${LIST_SESSIONS_CMD}"$'\nattach -t =alpha'

run_case \
  "unattached attach failure falls back to new-session" \
  "" \
  $'1\tbusy\n0\talpha\n0\tbeta' \
  "" \
  "${LIST_SESSIONS_CMD}
attach -t =alpha
new-session" \
  "normal" \
  "fail"

run_case \
  "list-sessions lookup failure falls back to new-session" \
  "" \
  $'1\tbusy\n0\talpha\n0\tbeta' \
  "" \
  "${LIST_SESSIONS_CMD}
new-session" \
  "fail_first"

run_case \
  "new session when nothing is reusable" \
  "" \
  "" \
  "" \
  "${LIST_SESSIONS_CMD}
new-session"

printf '\n'
printf 'passed=%s failed=%s\n' "$pass" "$fail"
[ "$fail" -eq 0 ]

#!/usr/bin/env bash
# DEBUG WRAPPER (added 2026-05-01 to diagnose missed auto-restore).
# Logs every invocation of resurrect's restore.sh, then delegates to it.
DEBUG_LOG="$HOME/.local/state/tmux-debug.log"
mkdir -p "$(dirname "$DEBUG_LOG")"
{
  printf '[%s] restore-wrapper pid=%s ppid=%s: INVOKED args=(%s)\n' "$(date '+%H:%M:%S')" "$$" "$PPID" "$*"
  echo "    tmux processes at restore time:"
  /bin/ps -axo pid,ppid,command | /usr/bin/grep -E '[t]mux' | sed 's/^/      /' || true
} >> "$DEBUG_LOG" 2>&1 || true

exec "$HOME/.tmux/plugins/tmux-resurrect/scripts/restore.sh" "$@"

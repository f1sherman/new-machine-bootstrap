#!/usr/bin/env bash
set -euo pipefail

command -v jq >/dev/null 2>&1 || exit 0
command -v tmux >/dev/null 2>&1 || exit 0
[ -n "${TMUX:-}" ] || exit 0
[ -n "${TMUX_PANE:-}" ] || exit 0

payload="$(cat)"
[ -n "$payload" ] || exit 0

pane_cwd="$(tmux show-options -pqv -t "$TMUX_PANE" @agent_worktree_path 2>/dev/null || true)"
payload_cwd="$(printf '%s' "$payload" | jq -r '.cwd // empty' 2>/dev/null || true)"
repo_root=""

for cwd in "$pane_cwd" "$payload_cwd" "$PWD"; do
  [ -n "$cwd" ] || continue
  repo_root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
  [ -n "$repo_root" ] && break
done

[ -n "$repo_root" ] || exit 0

spec_pattern='^docs/superpowers/specs/[^/]+-design[.]md$'

normalize_candidate() {
  local path="$1"
  path="${path#./}"
  case "$path" in
    *[.,:]) path="${path%?}" ;;
  esac

  case "$path" in
    *'*'*|*'?'*|*'['*|*']'*) return 0 ;;
  esac

  if [[ "$path" == /* ]]; then
    if [[ "$path" == "$repo_root"/* ]]; then
      local repo_path="${path#$repo_root/}"
      [[ "$repo_path" =~ $spec_pattern ]] && printf '%s\n' "$path"
    fi
  elif [[ "$path" =~ $spec_pattern ]]; then
    printf '%s/%s\n' "$repo_root" "$path"
  fi
}

extract_spec_paths_from_text() {
  local text="$1"
  [ -n "$text" ] || return 0

  printf '%s\n' "$text" |
    grep -Eo '[^[:space:]"'"'"'`<>|;()]+' |
    grep -E 'docs/superpowers/specs/[^/[:space:]"'"'"'`<>|;()]+-design[.]md' ||
    true
}

has_patch_file_header() {
  local text="$1"
  [ -n "$text" ] || return 1

  printf '%s\n' "$text" | grep -Eq '^\*\*\* (Add|Update|Delete) File: '
}

collect_structured_candidates() {
  local file_path command
  file_path="$(printf '%s' "$payload" | jq -r '.tool_input.file_path // empty' 2>/dev/null || true)"
  [ -n "$file_path" ] && normalize_candidate "$file_path"

  command="$(printf '%s' "$payload" | jq -r '.tool_input.command // empty' 2>/dev/null || true)"
  if [ -n "$command" ]; then
    printf '%s\n' "$command" |
      sed -n -E 's/^\*\*\* (Add|Update|Delete) File: //p' |
      while IFS= read -r path; do
        normalize_candidate "$path"
      done

  fi
}

collect_candidates() {
  local command prompt structured_candidates
  structured_candidates="$(collect_structured_candidates | awk 'length && !seen[$0]++')"
  if [ -n "$structured_candidates" ]; then
    printf '%s\n' "$structured_candidates"
    return 0
  fi

  command="$(printf '%s' "$payload" | jq -r '.tool_input.command // empty' 2>/dev/null || true)"
  if ! has_patch_file_header "$command"; then
    extract_spec_paths_from_text "$command" |
      while IFS= read -r path; do
        normalize_candidate "$path"
      done
  fi

  prompt="$(printf '%s' "$payload" | jq -r '.prompt // empty' 2>/dev/null || true)"
  extract_spec_paths_from_text "$prompt" |
    while IFS= read -r path; do
      normalize_candidate "$path"
    done
}

specs="$(collect_candidates | awk 'length && !seen[$0]++')"
spec_count="$(printf '%s\n' "$specs" | awk 'NF { count++ } END { print count + 0 }')"

[ "$spec_count" -eq 1 ] || exit 0

spec_path="$(printf '%s\n' "$specs" | awk 'NF { print; exit }')"
tmux set-option -p -t "$TMUX_PANE" @agent_current_spec_path "$spec_path" >/dev/null 2>&1 || true

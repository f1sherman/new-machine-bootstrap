#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(git -C "$SCRIPT_DIR" rev-parse --show-toplevel)"
TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

fail() {
  printf 'FAIL  %s\n' "$1" >&2
  exit 1
}

extract_function() {
  local template="$1" function_name="$2" dest="$3"
  awk -v function_name="$function_name" '
    $0 ~ "^" function_name "\\(\\) \\{" { in_function=1 }
    in_function { print }
    in_function && /^}$/ { exit }
  ' "$template" >> "$dest"
  printf '\n' >> "$dest"
}

extract_wrappers() {
  local template="$1" dest="$2"
  : > "$dest"
  extract_function "$template" _worktree_has_help_flag "$dest"
  extract_function "$template" _repo_start_passthrough_flag "$dest"
  extract_function "$template" repo-start "$dest"
  extract_function "$template" repo-end "$dest"
  extract_function "$template" rs "$dest"
  extract_function "$template" re "$dest"
}

assert_function_absent() {
  local template="$1" function_name="$2" label="$3"
  if rg -q "^${function_name}\\(\\) \\{" "$template"; then
    fail "$label should not define ${function_name}()"
  fi
}

write_simple_helper() {
  local path="$1" usage="$2"
  cat > "$path" <<EOF
#!/bin/bash
set -euo pipefail
printf '%s\n' "\$*" >> "\$HELPER_LOG"
for arg in "\$@"; do
  if [[ "\$arg" == "--json" ]]; then
    printf '{"status":"ok"}\n'
    exit 0
  fi
  if [[ "\$arg" == "--help" || "\$arg" == "-h" ]]; then
    printf '%s\n' "$usage"
    exit 0
  fi
done
/bin/mkdir -p "\$REPO_PATH"
printf '%s\n' "\$REPO_PATH"
EOF
  chmod +x "$path"
}

run_case() {
  local shell_bin="$1" template="$2" label="$3"
  local case_root="$TMPROOT/$label"
  local home_dir="$case_root/home"
  local helper_dir="$home_dir/.local/bin"
  local repo_path="$case_root/selected-repo"
  local wrapper_file="$case_root/wrapper.snippet"
  local run_file="$case_root/run.${label}"

  mkdir -p "$helper_dir" "$case_root"
  assert_function_absent "$template" worktree-create "$label"
  assert_function_absent "$template" worktree-cd "$label"
  assert_function_absent "$template" worktree-merge "$label"
  assert_function_absent "$template" worktree-delete "$label"
  assert_function_absent "$template" worktree-done "$label"
  assert_function_absent "$template" wts "$label"
  assert_function_absent "$template" wtd "$label"
  extract_wrappers "$template" "$wrapper_file"
  write_simple_helper "$helper_dir/repo-start" "Usage: repo-start <branch> [path]"
  write_simple_helper "$helper_dir/repo-end" "Usage: repo-end [--print-path]"

  cat > "$run_file" <<EOF
set -eu
REPO_PATH="$repo_path"
HOME="$home_dir"
export REPO_PATH
cd "$case_root"
. "$wrapper_file"
check_wrapper() {
  local wrapper_name="\$1"
  local helper_name="\$2"
  local expected_sync="\$3"
  local helper_log="$case_root/\${wrapper_name}-helper.log"
  local help_sync_log="$case_root/\${wrapper_name}-help-sync.log"
  local sync_log="$case_root/\${wrapper_name}-sync.log"
  local help_stdout_file="$case_root/\${wrapper_name}-help-stdout.txt"
  local help_cwd_file="$case_root/\${wrapper_name}-help-cwd.txt"
  local stdout_file="$case_root/\${wrapper_name}-stdout.txt"

  cd "$case_root"
  HELPER_LOG="\$helper_log"
  export HELPER_LOG
  _worktree_sync_tmux_state() {
    printf '%s\n' "sync-current" >> "\$help_sync_log"
  }
  "\$wrapper_name" feature/alpha --help > "\$help_stdout_file"
  printf 'help-cwd=%s\n' "\$PWD" > "\$help_cwd_file"

  HELPER_LOG="\$helper_log"
  export HELPER_LOG
  _worktree_sync_tmux_state() {
    printf '%s\n' "sync-current" >> "\$sync_log"
  }
  "\$wrapper_name" --branch feature/alpha --path "$case_root/requested-path" > "\$stdout_file"
  printf 'cwd=%s\n' "\$PWD" >> "\$stdout_file"
}

check_json_wrapper() {
  local wrapper_name="\$1"
  local json_helper_log="$case_root/\${wrapper_name}-json-helper.log"
  local json_sync_log="$case_root/\${wrapper_name}-json-sync.log"
  local json_stdout_file="$case_root/\${wrapper_name}-json-stdout.txt"
  local json_cwd_file="$case_root/\${wrapper_name}-json-cwd.txt"

  cd "$case_root"
  HELPER_LOG="\$json_helper_log"
  export HELPER_LOG
  _worktree_sync_tmux_state() {
    printf '%s\n' "sync-current" >> "\$json_sync_log"
  }
  "\$wrapper_name" feature/json --json > "\$json_stdout_file"
  printf 'json-cwd=%s\n' "\$PWD" > "\$json_cwd_file"
}

check_wrapper repo-start repo-start no
check_wrapper rs repo-start no
check_wrapper repo-end repo-end yes
check_wrapper re repo-end yes
check_json_wrapper repo-start
check_json_wrapper rs
EOF

  if ! HOME="$home_dir" "$shell_bin" -f "$run_file"; then
    fail "$label wrapper run failed"
  fi

  assert_wrapper() {
    local wrapper_name="$1"
    local helper_name="$2"
    local usage_suffix="$3"
    local expected_sync="$4"
    local helper_log="$case_root/${wrapper_name}-helper.log"
    local help_sync_log="$case_root/${wrapper_name}-help-sync.log"
    local sync_log="$case_root/${wrapper_name}-sync.log"
    local help_stdout_file="$case_root/${wrapper_name}-help-stdout.txt"
    local help_cwd_file="$case_root/${wrapper_name}-help-cwd.txt"
    local stdout_file="$case_root/${wrapper_name}-stdout.txt"

    [ "$(sed -n '1p' "$help_stdout_file")" = "Usage: $helper_name${usage_suffix}" ] || fail "$label $wrapper_name help output mismatch"
    [ "$(cat "$help_cwd_file")" = "help-cwd=$case_root" ] || fail "$label $wrapper_name help path changed cwd"
    [ ! -s "$help_sync_log" ] || fail "$label $wrapper_name help path should not sync tmux state"
    [ "$(sed -n '1p' "$helper_log")" = "feature/alpha --help" ] || fail "$label $wrapper_name did not forward help args to $helper_name"
    [ "$(sed -n '2p' "$helper_log")" = "--branch feature/alpha --path $case_root/requested-path --print-path" ] || fail "$label $wrapper_name did not call $helper_name with --print-path"
    [ "$(sed -n '1p' "$stdout_file")" = "$repo_path" ] || fail "$label $wrapper_name did not print the helper path"
    [ "$(sed -n '2p' "$stdout_file")" = "cwd=$repo_path" ] || fail "$label $wrapper_name did not cd into the helper path"
    if [ "$expected_sync" = "yes" ]; then
      [ "$(cat "$sync_log")" = "sync-current" ] || fail "$label $wrapper_name did not sync tmux state"
    else
      [ ! -s "$sync_log" ] || fail "$label $wrapper_name should not sync tmux state"
    fi
  }

  assert_wrapper repo-start repo-start " <branch> [path]" no
  assert_wrapper rs repo-start " <branch> [path]" no
  assert_wrapper repo-end repo-end " [--print-path]" yes
  assert_wrapper re repo-end " [--print-path]" yes

  assert_json_wrapper() {
    local wrapper_name="$1"
    local json_helper_log="$case_root/${wrapper_name}-json-helper.log"
    local json_sync_log="$case_root/${wrapper_name}-json-sync.log"
    local json_stdout_file="$case_root/${wrapper_name}-json-stdout.txt"
    local json_cwd_file="$case_root/${wrapper_name}-json-cwd.txt"

    [ "$(cat "$json_stdout_file")" = '{"status":"ok"}' ] || fail "$label $wrapper_name JSON output mismatch"
    [ "$(cat "$json_cwd_file")" = "json-cwd=$case_root" ] || fail "$label $wrapper_name JSON path changed cwd"
    [ ! -s "$json_sync_log" ] || fail "$label $wrapper_name JSON path should not sync tmux state"
    [ "$(cat "$json_helper_log")" = "feature/json --json" ] || fail "$label $wrapper_name did not forward JSON args"
  }

  assert_json_wrapper repo-start
  assert_json_wrapper rs
}

zsh_bin="$(command -v zsh)"
bash_bin="$(command -v bash)"

[ -n "$zsh_bin" ] || fail "missing zsh"
[ -n "$bash_bin" ] || fail "missing bash"

run_case "$zsh_bin" "$ROOT/roles/common/templates/dotfiles/zshrc.d/50-personal-dev-shell.zsh" "zsh"
run_case "$bash_bin" "$ROOT/roles/macos/templates/dotfiles/bash_profile" "bash"

printf 'PASS  repo wrapper smoke test\n'

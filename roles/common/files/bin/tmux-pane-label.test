#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script="$script_dir/tmux-pane-label"

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/tmux-pane-label.XXXXXX")"
trap 'rm -rf "$tmp_root"' EXIT

fake_bin="$tmp_root/fake-bin"
mkdir -p "$fake_bin"

ps_log="$tmp_root/ps-calls"
: > "$ps_log"
tmux_log="$tmp_root/tmux-calls"
: > "$tmux_log"

cat > "$fake_bin/ps" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

log="${PS_CALL_LOG:?}"
fixture_dir="${PS_FIXTURE_DIR:?}"

mode=""
tty=""
while [ "$#" -gt 0 ]; do
  case "$1" in
    -o)
      shift
      case "${1:-}" in
        args=)
          mode="args"
          ;;
        pid=,stat=,comm=,args=)
          mode="detail"
          ;;
        *)
          exit 2
          ;;
      esac
      ;;
    -t)
      shift
      tty="${1:-}"
      ;;
  esac
  shift || true
done

[ -n "$tty" ] || exit 2
printf '%s\t%s\n' "$mode" "$tty" >> "$log"

case "$mode" in
  args)
    fixture="$fixture_dir/$tty"
    ;;
  detail)
    fixture="$fixture_dir/$tty.detail"
    ;;
  *)
    exit 2
    ;;
esac

[ -f "$fixture" ] || exit 0
cat "$fixture"
EOF
chmod +x "$fake_bin/ps"

cat > "$fake_bin/tmux" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

log="${TMUX_CALL_LOG:?}"
fixture_dir="${TMUX_FIXTURE_DIR:?}"

printf '%s\n' "$*" >> "$log"

case "${1:-}" in
  list-panes)
    printf '%s\n' "${TMUX_PANE_IDS:-}"
    ;;
  show-options)
    shift
    pane_id=""
    option_name=""

    while [ "$#" -gt 0 ]; do
      case "$1" in
        -t)
          shift
          pane_id="${1:-}"
          ;;
        -*)
          ;;
        @*)
          option_name="$1"
          ;;
      esac
      shift || true
    done

    [ -n "$pane_id" ] || exit 2
    [ -n "$option_name" ] || exit 2
    fixture="$fixture_dir/$pane_id.$option_name"
    [ -f "$fixture" ] || exit 1
    cat "$fixture"
    ;;
  *)
    exit 1
    ;;
esac
EOF
chmod +x "$fake_bin/tmux"

assert_eq() {
  local got="$1" want="$2" name="$3"
  if [ "$got" != "$want" ]; then
    printf 'not ok - %s\nexpected: %s\ngot: %s\n' "$name" "$want" "$got" >&2
    exit 1
  fi
  printf 'ok - %s\n' "$name"
}

run_case() {
  local name="$1" tty="$2" path="$3" pane_current_command="$4" expected="$5"
  local fixture="$6" expected_ps_calls="$7"
  local pane_id="${8:-}" explicit_pid="${9:-}" explicit_path="${10:-}" detail_fixture="${11:-}"

  printf '%s\n' "$fixture" > "$tmp_root/$tty"
  if [ -n "$detail_fixture" ]; then
    printf '%s\n' "$detail_fixture" > "$tmp_root/$tty.detail"
  fi
  if [ -n "$pane_id" ]; then
    printf '%s\n' "$explicit_pid" > "$tmp_root/$pane_id.@agent_worktree_pid"
    printf '%s\n' "$explicit_path" > "$tmp_root/$pane_id.@agent_worktree_path"
  fi
  : > "$ps_log"

  local output ps_calls
  output="$(PATH="$fake_bin:$PATH" PS_CALL_LOG="$ps_log" PS_FIXTURE_DIR="$tmp_root" TMUX_CALL_LOG="$tmux_log" TMUX_FIXTURE_DIR="$tmp_root" TMUX_PANE_IDS="${pane_id:-}" bash "$script" "$tty" "$path" "$pane_current_command" "${pane_id:-}" 2>/dev/null || true)"
  ps_calls="$(wc -l < "$ps_log" | tr -d ' ')"

  assert_eq "$ps_calls" "$expected_ps_calls" "$name ps call count"
  assert_eq "$output" "$expected" "$name output"
}

git_repo="$tmp_root/repo"
mkdir -p "$git_repo"
git_template="$tmp_root/git-template"
mkdir -p "$git_template"
git -c init.templateDir="$git_template" -C "$git_repo" init -b main >/dev/null
printf 'ref: refs/heads/feature/foo\n' > "$git_repo/.git/HEAD"

tmp_dir="$tmp_root/tmp"
mkdir -p "$tmp_dir"

agent_repo="$tmp_root/agent-repo"
mkdir -p "$agent_repo"
git_template="$tmp_root/git-template"
mkdir -p "$git_template"
git -c init.templateDir="$git_template" -C "$agent_repo" init -b main >/dev/null
git -C "$agent_repo" commit -q --allow-empty -m init

agent_wt="$tmp_root/agent-wt"
git -C "$agent_repo" worktree add -q -b feature/agent-label "$agent_wt"

run_case \
  "local git pane skips ps" \
  "tty-local-git" \
  "$git_repo" \
  "zsh" \
  "feature/foo repo" \
  "shell: zsh" \
  "0"

run_case \
  "local non-git pane skips ps" \
  "tty-local-tmp" \
  "$tmp_dir" \
  "bash" \
  "tmp" \
  "shell: login" \
  "0"

run_case \
  "plain ssh pane keeps host label" \
  "tty-ssh" \
  "$tmp_dir" \
  "ssh" \
  "claw02" \
  "ssh dev@claw02 -p 22" \
  "1"

run_case \
  "codespaces pane keeps codespace label" \
  "tty-codespace" \
  "$tmp_dir" \
  "gh" \
  "space-alpha" \
  "gh codespace ssh --codespace space-alpha" \
  "1"

run_case \
  "devpod pane keeps workspace label via ruby hint" \
  "tty-devpod" \
  "$tmp_dir" \
  "ruby" \
  "workspace-beta" \
  "devpod ssh workspace-beta" \
  "1"

run_case \
  "ruby local pane falls back to local label" \
  "tty-ruby-local" \
  "$tmp_dir" \
  "ruby" \
  "tmp" \
  "ruby script/server" \
  "1"

run_case \
  "empty hint preserves ssh label via slow path" \
  "tty-ssh-multiline" \
  "$tmp_dir" \
  "" \
  "claw02" \
  $'zsh -l\nssh dev@claw02 -p 22' \
  "1"

run_case \
  "empty hint preserves local shell label via slow path" \
  "tty-local-shell" \
  "$git_repo" \
  "" \
  "feature/foo repo" \
  "zsh -l" \
  "1"

run_case \
  "explicit state overrides remote heuristic" \
  "tty-explicit" \
  "$tmp_dir" \
  "ssh" \
  "feature/agent-label agent-wt" \
  "ssh dev@claw02 -p 22" \
  "1" \
  "%91" \
  "9100" \
  "$agent_wt" \
  $'9100 S+ codex codex --cd /tmp/irrelevant'

run_case \
  "explicit state falls back when pid mismatches" \
  "tty-explicit-stale" \
  "$tmp_dir" \
  "ssh" \
  "claw02" \
  "ssh dev@claw02 -p 22" \
  "2" \
  "%92" \
  "9999" \
  "$agent_wt" \
  $'9100 S+ codex codex --cd /tmp/irrelevant'

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-spec-current"
TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

pass() { printf 'PASS  %s\n' "$1"; }
fail() { printf 'FAIL  %s\n' "$1" >&2; exit 1; }

make_repo() {
  local repo="$1"
  git -c init.templateDir= init -q "$repo"
  git -C "$repo" commit -q --allow-empty -m init
  mkdir -p "$repo/docs/superpowers/specs"
  printf '# Old\n' > "$repo/docs/superpowers/specs/2026-05-01-old-design.md"
  printf '# New\n' > "$repo/docs/superpowers/specs/2026-05-02-new-design.md"
  touch -t 202605010101 "$repo/docs/superpowers/specs/2026-05-01-old-design.md"
  touch -t 202605020101 "$repo/docs/superpowers/specs/2026-05-02-new-design.md"
  git -C "$repo" add .
  git -C "$repo" commit -q -m specs
}

install_fake_tmux() {
  local bin="$1" repo="$2" option="$3"
  mkdir -p "$bin"
  cat > "$bin/tmux" <<EOF
#!/usr/bin/env bash
set -euo pipefail
case "\${1:-}" in
  show-options)
    printf '%s\n' "$option"
    ;;
  display-message)
    printf '%s\n' "$repo"
    ;;
  *)
    exit 1
    ;;
esac
EOF
  chmod +x "$bin/tmux"
}

install_fake_tmux_no_pane_path() {
  local bin="$1"
  mkdir -p "$bin"
  cat > "$bin/tmux" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
case "${1:-}" in
  show-options)
    ;;
  display-message)
    exit 1
    ;;
  *)
    exit 1
    ;;
esac
EOF
  chmod +x "$bin/tmux"
}

assert_output() {
  local expected="$1" name="$2"; shift 2
  local actual
  actual="$("$@")" || fail "$name"
  [ "$actual" = "$expected" ] || fail "$name"
  pass "$name"
}

assert_output_in_dir() {
  local cwd="$1" expected="$2" name="$3"; shift 3
  local actual
  actual="$(cd "$cwd" && "$@")" || fail "$name"
  [ "$actual" = "$expected" ] || fail "$name"
  pass "$name"
}

assert_failure_stderr_contains() {
  local needle="$1" name="$2" stdout="$3" stderr="$4"; shift 4
  if "$@" >"$stdout" 2>"$stderr"; then
    fail "$name"
  fi
  rg -q -F "$needle" "$stderr" || fail "$name"
  pass "$name"
}

assert_failure_stderr_contains \
  "tmux-spec-current: tmux is required" \
  "unset TMUX reports required precondition" \
  "$TMPROOT/no-tmux.out" "$TMPROOT/no-tmux.err" \
  env -u TMUX "$SCRIPT"

assert_failure_stderr_contains \
  "tmux-spec-current: pane id is required" \
  "missing pane id reports required precondition" \
  "$TMPROOT/no-pane.out" "$TMPROOT/no-pane.err" \
  env -u TMUX_PANE TMUX=/tmp/tmux "$SCRIPT"

repo="$TMPROOT/repo"
make_repo "$repo"
repo="$(git -C "$repo" rev-parse --show-toplevel)"

bin="$TMPROOT/bin-option"
install_fake_tmux "$bin" "$repo" "$repo/docs/superpowers/specs/2026-05-02-new-design.md"
assert_output "$repo/docs/superpowers/specs/2026-05-02-new-design.md" "pane option wins" \
  env TMUX=/tmp/tmux TMUX_PANE=%31 TMUX_SPEC_TMUX_BIN="$bin/tmux" "$SCRIPT"

outside="$TMPROOT/outside"
mkdir -p "$outside"
bin="$TMPROOT/bin-relative-option"
install_fake_tmux "$bin" "$repo" "docs/superpowers/specs/2026-05-02-new-design.md"
assert_output_in_dir "$outside" "$repo/docs/superpowers/specs/2026-05-02-new-design.md" "relative pane option resolves against pane repo" \
  env TMUX=/tmp/tmux TMUX_PANE=%35 TMUX_SPEC_TMUX_BIN="$bin/tmux" "$SCRIPT"

bin="$TMPROOT/bin-fallback"
install_fake_tmux "$bin" "$repo" ""
assert_output "$repo/docs/superpowers/specs/2026-05-02-new-design.md" "fallback chooses newest spec" \
  env TMUX=/tmp/tmux TMUX_PANE=%32 TMUX_SPEC_TMUX_BIN="$bin/tmux" "$SCRIPT"

empty_repo="$TMPROOT/empty"
git -c init.templateDir= init -q "$empty_repo"
git -C "$empty_repo" commit -q --allow-empty -m init
bin="$TMPROOT/bin-empty"
install_fake_tmux "$bin" "$empty_repo" ""
if env TMUX=/tmp/tmux TMUX_PANE=%33 TMUX_SPEC_TMUX_BIN="$bin/tmux" "$SCRIPT" >/tmp/tmux-spec-current.out 2>/tmp/tmux-spec-current.err; then
  fail "no spec should fail"
fi
rg -q -F "no current spec" /tmp/tmux-spec-current.err || fail "no spec error message"
pass "no spec reports clear error"

bin="$TMPROOT/bin-no-pane-path"
install_fake_tmux_no_pane_path "$bin"
if (cd "$repo" && env TMUX=/tmp/tmux TMUX_PANE=%34 TMUX_SPEC_TMUX_BIN="$bin/tmux" "$SCRIPT" >/tmp/tmux-spec-current-no-pane.out 2>/tmp/tmux-spec-current-no-pane.err); then
  fail "missing pane path should not fall back to caller cwd"
fi
rg -q -F "no current spec" /tmp/tmux-spec-current-no-pane.err || fail "missing pane path error message"
pass "missing pane path reports clear error"

printf 'PASS  tmux-spec-current test suite\n'

#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
script="$script_dir/tmux-label-format"

tmp_root="$(mktemp -d "${TMPDIR:-/tmp}/tmux-label-format.XXXXXX")"
trap 'rm -rf "$tmp_root"' EXIT
export HOME="$tmp_root/home"

export GIT_AUTHOR_NAME=test
export GIT_AUTHOR_EMAIL=test@example.com
export GIT_COMMITTER_NAME=test
export GIT_COMMITTER_EMAIL=test@example.com

assert_eq() {
  local got="$1" want="$2" name="$3"
  if [ "$got" != "$want" ]; then
    printf 'not ok - %s\nexpected: %s\ngot: %s\n' "$name" "$want" "$got" >&2
    exit 1
  fi
  printf 'ok - %s\n' "$name"
}

make_repo() {
  local dir="$1"
  git -c init.templateDir="$tmp_root/git-template" init -q -b main "$dir"
  git -C "$dir" commit -q --allow-empty -m init
}

pr_status_cache_key() {
  local remote_url="$1"
  local branch="$2"
  local digest

  if command -v sha256sum >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | sha256sum 2>/dev/null | awk '{print $1}')" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  if command -v shasum >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | shasum -a 256 2>/dev/null | awk '{print $1}')" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  if command -v ruby >/dev/null 2>&1 && \
    digest="$(printf '%s\n%s\n' "$remote_url" "$branch" | ruby -rdigest -e 'print Digest::SHA256.hexdigest(STDIN.read)' 2>/dev/null)" && \
    [ -n "$digest" ]; then
    printf '%s\n' "$digest"
    return 0
  fi

  return 1
}

write_pr_cache() {
  local remote_url="$1"
  local branch="$2"
  local state="$3"
  local expires_at_epoch="$4"
  local display_ref="$5"
  local cache_dir="$HOME/.local/state/pr-status"
  local key

  mkdir -p "$cache_dir"
  key="$(pr_status_cache_key "$remote_url" "$branch")"
  cat > "$cache_dir/$key.json" <<EOF
{
  "remote_url": "$remote_url",
  "branch": "$branch",
  "state": "$state",
  "expires_at_epoch": $expires_at_epoch,
  "display_ref": "$display_ref"
}
EOF
}

repo="$tmp_root/repo"
subrepo="$tmp_root/subrepo"
superrepo="$tmp_root/super"
worktree="$tmp_root/repo-worktree"

mkdir -p "$tmp_root/git-template"
mkdir -p "$HOME"

make_repo "$repo"
git -C "$repo" checkout -q -b feature/local
assert_eq \
  "$("$script" local "$repo")" \
  "(feature/local) repo" \
  "primary repo keeps repo basename"

git -C "$repo" worktree add -q -b feature/worktree "$worktree"
assert_eq \
  "$("$script" local "$worktree")" \
  "(feature/worktree) repo" \
  "linked worktree keeps source repo basename"

github_repo="$tmp_root/github-repo"
github_remote_url="https://github.com/example/github-repo.git"
make_repo "$github_repo"
git -C "$github_repo" remote add origin "$github_remote_url"
git -C "$github_repo" checkout -q -b feature/github-pr
write_pr_cache "$github_remote_url" "feature/github-pr" "open" "$(( $(date +%s) + 3600 ))" "gh#123"
assert_eq \
  "$("$script" local "$github_repo")" \
  "(feature/github-pr gh#123) github-repo" \
  "matching GitHub cache appends display ref"

fallback_bin="$tmp_root/fallback-bin"
mkdir -p "$fallback_bin"
cat > "$fallback_bin/sha256sum" <<'EOF'
#!/usr/bin/env bash
printf 'sha256sum should not be used in this test\n' >&2
exit 127
EOF
chmod +x "$fallback_bin/sha256sum"
assert_eq \
  "$(PATH="$fallback_bin:$PATH" "$script" local "$github_repo")" \
  "(feature/github-pr gh#123) github-repo" \
  "cache key falls back when sha256sum is unavailable"

forgejo_repo="$tmp_root/forgejo-repo"
forgejo_remote_url="ssh://git@forgejo.example/brian/forgejo-repo.git"
make_repo "$forgejo_repo"
git -C "$forgejo_repo" remote add origin "$forgejo_remote_url"
git -C "$forgejo_repo" checkout -q -b feature/forgejo-pr
write_pr_cache "$forgejo_remote_url" "feature/forgejo-pr" "open" "$(( $(date +%s) + 3600 ))" "fg#42"
assert_eq \
  "$("$script" local "$forgejo_repo")" \
  "(feature/forgejo-pr fg#42) forgejo-repo" \
  "matching Forgejo cache appends display ref"

dirty_repo="$tmp_root/dirty-repo"
dirty_remote_url="https://github.com/example/dirty-repo.git"
make_repo "$dirty_repo"
git -C "$dirty_repo" remote add origin "$dirty_remote_url"
git -C "$dirty_repo" checkout -q -b feature/dirty-pr
write_pr_cache "$dirty_remote_url" "feature/dirty-pr" "open" "$(( $(date +%s) + 3600 ))" "gh#456"
printf 'dirty\n' > "$dirty_repo/untracked"
assert_eq \
  "$("$script" local "$dirty_repo")" \
  "(*feature/dirty-pr gh#456) dirty-repo" \
  "dirty branch keeps marker and appends PR ref"

expired_repo="$tmp_root/expired-repo"
expired_remote_url="https://github.com/example/expired-repo.git"
make_repo "$expired_repo"
git -C "$expired_repo" remote add origin "$expired_remote_url"
git -C "$expired_repo" checkout -q -b feature/expired-pr
write_pr_cache "$expired_remote_url" "feature/expired-pr" "open" "$(( $(date +%s) - 3600 ))" "gh#789"
assert_eq \
  "$("$script" local "$expired_repo")" \
  "(feature/expired-pr) expired-repo" \
  "expired cache is ignored"

invalid_ref_repo="$tmp_root/invalid-ref-repo"
invalid_ref_remote_url="https://github.com/example/invalid-ref-repo.git"
make_repo "$invalid_ref_repo"
git -C "$invalid_ref_repo" remote add origin "$invalid_ref_remote_url"
git -C "$invalid_ref_repo" checkout -q -b feature/invalid-ref-pr
write_pr_cache "$invalid_ref_remote_url" "feature/invalid-ref-pr" "open" "$(( $(date +%s) + 3600 ))" "pr#789"
assert_eq \
  "$("$script" local "$invalid_ref_repo")" \
  "(feature/invalid-ref-pr) invalid-ref-repo" \
  "invalid display_ref is ignored"

make_repo "$subrepo"
make_repo "$superrepo"
GIT_ALLOW_PROTOCOL=file git -C "$superrepo" submodule add -q "$subrepo" deps/subrepo
git -C "$superrepo" commit -qam "add submodule" >/dev/null
git -C "$superrepo/deps/subrepo" checkout -q -b feature/submodule

assert_eq \
  "$("$script" local "$superrepo/deps/subrepo")" \
  "(feature/submodule) subrepo" \
  "submodule checkout uses submodule basename"

assert_eq \
  "$("$script" remote "$superrepo/deps/subrepo" claw02)" \
  "subrepo | claw02" \
  "remote submodule fallback uses submodule basename"

#!/usr/bin/env bash
set -euo pipefail

state_dir="$HOME/.local/state/tmux/session-gc"

session_key() {
  printf '%s' "$1" | tr '/ :\t' '____'
}

days=14

while [ "$#" -gt 0 ]; do
  case "$1" in
    --days)
      days="${2:-}"
      shift 2
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

mkdir -p "$state_dir"

now="$(date +%s)"
threshold="$(( days * 24 * 60 * 60 ))"

tmux list-sessions -F '#{session_name}\t#{session_attached}\t#{session_created}' 2>/dev/null | \
while IFS=$'\t' read -r session_name attached session_created; do
  [ -n "$session_name" ] || continue

  marker_prefix="$(session_key "$session_name")"
  marker_file="$state_dir/${marker_prefix}.${session_created}.unattached_since"

  for existing_marker in "$state_dir/${marker_prefix}".*.unattached_since; do
    [ -e "$existing_marker" ] || continue
    [ "$existing_marker" = "$marker_file" ] && continue
    rm -f "$existing_marker"
  done

  if [ "$attached" != "0" ]; then
    rm -f "$marker_file"
    continue
  fi

  if [ ! -f "$marker_file" ]; then
    printf '%s' "$now" > "$marker_file"
    continue
  fi

  unattached_since="$(cat "$marker_file" 2>/dev/null || printf '0')"
  if [ $(( now - unattached_since )) -gt "$threshold" ]; then
    tmux kill-session -t "=$session_name"
    rm -f "$marker_file"
  fi
done

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/tmux-claude-session-start"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

pass() {
  printf 'PASS  %s\n' "$1"
}

fail() {
  printf 'FAIL  %s\n' "$1" >&2
  exit 1
}

bin="$tmpdir/bin"
log="$tmpdir/tmux.log"
mkdir -p "$bin"

cat > "$bin/tmux" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
if [ "${1:-}" = "show-options" ]; then
  printf '%s' "${TMUX_TEST_EXISTING:-}"
  exit 0
fi
printf '%s\n' "$*" >> "$TMUX_TEST_LOG"
EOF
chmod +x "$bin/tmux"

# Case 1: happy path — stdin has session_id + TMUX_PANE set
: > "$log"
printf '%s' '{"session_id": "abc-uuid"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 TMUX_TEST_LOG="$log" \
    "$SCRIPT"

rg -q -F -- '@persist_claude_session_id abc-uuid' "$log" \
  || fail 'happy path stores session id on pane'
rg -q -F -- '%99' "$log" \
  || fail 'happy path targets the correct pane'
pass 'happy path stores session id on pane'

# Case 2: no tmux — TMUX_PANE unset; tmux must not be invoked
: > "$log"
printf '%s' '{"session_id": "should-not-store"}' \
  | env -u TMUX -u TMUX_PANE PATH="$bin:$PATH" TMUX_TEST_LOG="$log" \
    "$SCRIPT"

if [ -s "$log" ]; then
  fail 'no-tmux: script must not invoke tmux'
fi
pass 'no-tmux: script is quiet outside tmux'

# Case 3a: empty session_id (null)
: > "$log"
printf '%s' '{"session_id": null}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 TMUX_TEST_LOG="$log" \
    "$SCRIPT"

if [ -s "$log" ]; then
  fail 'null session_id: script must not invoke tmux'
fi
pass 'null session_id: no tmux invocation'

# Case 3b: empty session_id (missing key)
: > "$log"
printf '%s' '{}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 TMUX_TEST_LOG="$log" \
    "$SCRIPT"

if [ -s "$log" ]; then
  fail 'missing session_id: script must not invoke tmux'
fi
pass 'missing session_id: no tmux invocation'

# Case 4: malformed JSON — must exit 0 and not invoke tmux
: > "$log"
set +e
printf '%s' 'not json' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 TMUX_TEST_LOG="$log" \
    "$SCRIPT"
rc=$?
set -e
if [ "$rc" -ne 0 ]; then
  fail "malformed JSON: script must exit 0 (got $rc)"
fi
if [ -s "$log" ]; then
  fail 'malformed JSON: script must not invoke tmux'
fi
pass 'malformed JSON: exits 0 without invoking tmux'

# Case 5: nested startup — source=startup with option already set → skip overwrite
: > "$log"
printf '%s' '{"session_id": "nested-uuid", "source": "startup"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 \
        TMUX_TEST_LOG="$log" TMUX_TEST_EXISTING="outer-uuid" \
    "$SCRIPT"

if [ -s "$log" ]; then
  fail 'nested startup: must not overwrite existing session id'
fi
pass 'nested startup: skips when option already set'

# Case 6: fresh startup — source=startup with option unset → set
: > "$log"
printf '%s' '{"session_id": "fresh-uuid", "source": "startup"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 \
        TMUX_TEST_LOG="$log" \
    "$SCRIPT"

rg -q -F -- '@persist_claude_session_id fresh-uuid' "$log" \
  || fail 'fresh startup: must set session id when option unset'
pass 'fresh startup: sets session id when option unset'

# Case 7: source=clear with option set → overwrite
: > "$log"
printf '%s' '{"session_id": "post-clear-uuid", "source": "clear"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 \
        TMUX_TEST_LOG="$log" TMUX_TEST_EXISTING="pre-clear-uuid" \
    "$SCRIPT"

rg -q -F -- '@persist_claude_session_id post-clear-uuid' "$log" \
  || fail 'clear: must overwrite existing session id'
pass 'clear: overwrites existing session id'

# Case 8: source=compact with option set → overwrite
: > "$log"
printf '%s' '{"session_id": "post-compact-uuid", "source": "compact"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 \
        TMUX_TEST_LOG="$log" TMUX_TEST_EXISTING="pre-compact-uuid" \
    "$SCRIPT"

rg -q -F -- '@persist_claude_session_id post-compact-uuid' "$log" \
  || fail 'compact: must overwrite existing session id'
pass 'compact: overwrites existing session id'

# Case 9: source=resume with option set → overwrite
: > "$log"
printf '%s' '{"session_id": "resumed-uuid", "source": "resume"}' \
  | env PATH="$bin:$PATH" TMUX=/tmp/tmux-socket TMUX_PANE=%99 \
        TMUX_TEST_LOG="$log" TMUX_TEST_EXISTING="some-uuid" \
    "$SCRIPT"

rg -q -F -- '@persist_claude_session_id resumed-uuid' "$log" \
  || fail 'resume: must overwrite existing session id'
pass 'resume: overwrites existing session id'

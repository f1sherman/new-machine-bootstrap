#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/remind-repo-start-on-dev-prompt.sh"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

TMPROOT="$(mktemp -d)"
TMUX_PANE_STATE_DIR="$TMPROOT/pane-state"
mkdir -p "$TMUX_PANE_STATE_DIR"

ISO_CFG="$(mktemp)"; printf "NMB_BRAINSTORMING_SKILL='superpowers:brainstorming'\nNMB_DEBUGGING_SKILL='superpowers:systematic-debugging'\n" > "$ISO_CFG"
export NMB_INITIATION_SKILLS_CONFIG="$ISO_CFG"

trap 'rm -rf "$TMPROOT"; rm -f "$ISO_CFG" "${OVR_CFG:-}"' EXIT

# Test isolation: ensure the harness's tmux state never leaks into the
# cwd-only test cases. Individual bound-pane tests set these explicitly.
unset TMUX_PANE TMUX_AGENT_WORKTREE_STATE_DIR TMUX

GIT_AUTHOR_NAME=test
GIT_AUTHOR_EMAIL=test@example.com
GIT_COMMITTER_NAME=test
GIT_COMMITTER_EMAIL=test@example.com
export GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL

make_repo() {
  local path="$1" branch="$2"
  git -c init.templateDir= init -qb main "$path" >/dev/null
  git -C "$path" commit -q --allow-empty -m init
  if [ "$branch" != "main" ]; then
    git -C "$path" checkout -q -b "$branch"
  fi
}

REMINDER_NEEDLE='repo-start'

run_reminder_case() {
  local name="$1" prompt="$2" branch="$3"
  local repo="$TMPROOT/$name"
  make_repo "$repo" "$branch"
  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$repo" && printf '%s' "$payload" | "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg needle "$REMINDER_NEEDLE" \
      '(.hookSpecificOutput.hookEventName == "UserPromptSubmit")
       and (.hookSpecificOutput.additionalContext | test($needle))' >/dev/null 2>&1; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_case() {
  local name="$1" prompt="$2" branch="$3"
  local repo="$TMPROOT/$name"
  make_repo "$repo" "$branch"
  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$repo" && printf '%s' "$payload" | "$SCRIPT")"
  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_no_repo() {
  local name="$1" prompt="$2"
  local payload output
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$TMPROOT" && printf '%s' "$payload" | "$SCRIPT")"
  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_silent_empty() {
  local name="$1" payload="$2"
  local output
  output="$(printf '%s' "$payload" | "$SCRIPT")"
  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

# Run the script with TMUX_PANE bound to a worktree via state-dir mode.
# Simulates the harness state where the agent's shell cwd is the main
# worktree but the pane is bound to a feature worktree.
run_silent_bound_case() {
  local name="$1" prompt="$2" cwd="$3" bound_path="$4"
  local payload state_dir output
  state_dir="$TMUX_PANE_STATE_DIR"
  printf '%s' "$bound_path" > "$state_dir/%test.@agent_worktree_path"
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$cwd" && TMUX_PANE='%test' TMUX_AGENT_WORKTREE_STATE_DIR="$state_dir" printf '%s' "$payload" | TMUX_PANE='%test' TMUX_AGENT_WORKTREE_STATE_DIR="$state_dir" "$SCRIPT")"
  if [ -z "$output" ]; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
  rm -f "$state_dir/%test.@agent_worktree_path"
}

run_reminder_bound_main_case() {
  local name="$1" prompt="$2" cwd="$3" bound_path="$4"
  local payload state_dir output
  state_dir="$TMUX_PANE_STATE_DIR"
  printf '%s' "$bound_path" > "$state_dir/%test.@agent_worktree_path"
  payload="$(jq -n --arg prompt "$prompt" '{prompt:$prompt}')"
  output="$(cd "$cwd" && TMUX_PANE='%test' TMUX_AGENT_WORKTREE_STATE_DIR="$state_dir" printf '%s' "$payload" | TMUX_PANE='%test' TMUX_AGENT_WORKTREE_STATE_DIR="$state_dir" "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg needle "$REMINDER_NEEDLE" \
      '(.hookSpecificOutput.hookEventName == "UserPromptSubmit")
       and (.hookSpecificOutput.additionalContext | test($needle))' >/dev/null 2>&1; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
  rm -f "$state_dir/%test.@agent_worktree_path"
}

run_reminder_case "reminds for /brainstorming on main" "/superpowers:brainstorming please check the dashboard" "main"
run_reminder_case "reminds for /systematic-debugging on main" "/superpowers:systematic-debugging why is the test broken" "main"
run_reminder_case "reminds for _spec-first on main" "use _spec-first to design this" "main"
run_reminder_case "reminds for _spec-to-pr on main" "run _spec-to-pr on this idea" "main"
run_reminder_case "reminds for _fix on main" "use _fix on issue 123" "main"
run_silent_case "silent for /brainstorming on feature branch" "/superpowers:brainstorming please check the dashboard" "feature/foo"
run_silent_case "silent for plain dev verb on main" "please fix the failing canary" "main"
run_silent_case "silent for implement verb on main" "implement the new dashboard" "main"
run_silent_case "silent for refactor verb on main" "refactor the hook script" "main"
run_silent_case "silent for non-dev prompt on main" "what time is it?" "main"
run_silent_case "silent for question prompt on main" "how does this hook work?" "main"
run_silent_no_repo "silent when cwd is not a git repo" "/superpowers:brainstorming please check the dashboard"
run_silent_empty "silent for empty payload" '{}'
run_silent_empty "silent for missing prompt field" '{"other":"value"}'
run_silent_empty "silent for blank prompt" '{"prompt":""}'

# Pane-binding scenarios: cwd is in a main-branch repo, but TMUX pane is
# bound (via state-dir mode) to a different worktree.
MAIN_REPO="$TMPROOT/main-cwd"
FEATURE_REPO="$TMPROOT/feature-bound"
make_repo "$MAIN_REPO" "main"
make_repo "$FEATURE_REPO" "feature/foo"

run_silent_bound_case \
  "silent when pane bound to non-main worktree (cwd in main)" \
  "/superpowers:brainstorming please check the dashboard" \
  "$MAIN_REPO" \
  "$FEATURE_REPO"

MAIN_BOUND_REPO="$TMPROOT/main-bound"
make_repo "$MAIN_BOUND_REPO" "main"
run_reminder_bound_main_case \
  "reminds when pane bound to a main-branch worktree" \
  "/superpowers:brainstorming please check the dashboard" \
  "$MAIN_REPO" \
  "$MAIN_BOUND_REPO"

# Stale binding (path no longer exists) falls back to cwd
run_reminder_bound_main_case \
  "falls back to cwd when bound path missing" \
  "/superpowers:brainstorming please check the dashboard" \
  "$MAIN_REPO" \
  "$TMPROOT/does-not-exist"

OVR_CFG="$(mktemp)"; printf "NMB_BRAINSTORMING_SKILL='alt:solution-design'\nNMB_DEBUGGING_SKILL='alt:root-cause-debugging'\n" > "$OVR_CFG"
NMB_INITIATION_SKILLS_CONFIG="$OVR_CFG" run_reminder_case "override: reminds for solution-design verb on main" "use alt:solution-design please" "main"
NMB_INITIATION_SKILLS_CONFIG="$OVR_CFG" run_reminder_case "override: reminds for root-cause-debugging verb on main" "alt:root-cause-debugging the test" "main"
NMB_INITIATION_SKILLS_CONFIG="$OVR_CFG" run_silent_case "override: silent for old brainstorming verb on main" "/superpowers:brainstorming check the dashboard" "main"

printf 'PASS  remind-repo-start-on-dev-prompt test suite\n'

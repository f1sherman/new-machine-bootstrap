#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/block-worktree-commands.sh"
TMPROOT="$(mktemp -d)"
trap 'rm -rf "$TMPROOT"' EXIT

GIT_AUTHOR_NAME=test
GIT_AUTHOR_EMAIL=test@example.com
GIT_COMMITTER_NAME=test
GIT_COMMITTER_EMAIL=test@example.com
export GIT_AUTHOR_NAME GIT_AUTHOR_EMAIL GIT_COMMITTER_NAME GIT_COMMITTER_EMAIL

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

run_block_case() {
  local name="$1"
  local command="$2"
  local reason="$3"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$reason" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_block_case_in_dir() {
  local name="$1"
  local dir="$2"
  local command="$3"
  local reason="$4"

  (cd "$dir" && run_block_case "$name" "$command" "$reason")
}

run_block_case_with_home() {
  local name="$1"
  local home_dir="$2"
  local command="$3"
  local reason="$4"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | HOME="$home_dir" "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$reason" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_allow_case() {
  local name="$1"
  local command="$2"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

setup_remote_only_branch_repo() {
  local name="$1"
  local remote_name="${2:-origin}"
  local origin="$TMPROOT/$name-origin.git"
  local repo="$TMPROOT/$name-repo"

  git -c init.templateDir= init -q --bare "$origin"
  git -c init.templateDir= init -qb main "$repo"
  git -C "$repo" remote add "$remote_name" "$origin"
  git -C "$repo" commit -q --allow-empty -m init
  git -C "$repo" push -q -u "$remote_name" main
  git -C "$repo" checkout -q -b foo
  git -C "$repo" commit -q --allow-empty -m foo
  git -C "$repo" push -q -u "$remote_name" foo
  git -C "$repo" checkout -q main
  git -C "$repo" branch -D foo >/dev/null
  printf '%s\n' "$repo"
}

run_empty_case() {
  local name="$1"
  local payload="$2"
  local output

  output="$(printf '%s' "$payload" | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_block_case "blocks raw worktree add" 'git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks raw worktree remove" 'git worktree remove ../foo' 'Do not run git worktree remove directly. Use repo-end to finish work, or cleanup-branches --branch <branch> for cleanup only.'
run_block_case "blocks git -C invocation" 'git -C repo worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks assignment-prefixed invocation" 'GIT_DIR=.git git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks command builtin invocation" 'command git worktree remove ../foo' 'Do not run git worktree remove directly. Use repo-end to finish work, or cleanup-branches --branch <branch> for cleanup only.'
run_block_case "blocks chained invocation" 'cd repo && git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_allow_case "allows repo-start helper" 'repo-start foo'
run_allow_case "allows repo-end helper" 'repo-end'
run_allow_case "allows text mention of worktree add" 'echo git worktree add'
run_allow_case "allows other commands" 'git status --short'
run_empty_case "allows missing command" '{}'
run_empty_case "allows empty command" '{"tool_input":{"command":""}}'

DENY_REASON='Do not create branches directly. Use repo-start <branch> instead.'

run_block_case "blocks git checkout -b" 'git checkout -b foo' "$DENY_REASON"
run_block_case "blocks git checkout -bfoo" 'git checkout -bfoo' "$DENY_REASON"
run_block_case "blocks git checkout -qb" 'git checkout -qb foo' "$DENY_REASON"
run_block_case "blocks git checkout --track" 'git checkout --track origin/foo' "$DENY_REASON"
run_block_case "blocks git checkout -t" 'git checkout -t origin/foo' "$DENY_REASON"
run_block_case "blocks git switch -c" 'git switch -c foo' "$DENY_REASON"
run_block_case "blocks git switch -cfoo" 'git switch -cfoo' "$DENY_REASON"
run_block_case "blocks git switch -qc" 'git switch -qc foo' "$DENY_REASON"
run_block_case "blocks git switch --create" 'git switch --create foo' "$DENY_REASON"
run_block_case "blocks git switch --force-create" 'git switch --force-create foo' "$DENY_REASON"
run_block_case "blocks git switch --orphan" 'git switch --orphan foo' "$DENY_REASON"
run_block_case "blocks git switch --track" 'git switch --track origin/foo' "$DENY_REASON"
run_block_case "blocks git branch <name>" 'git branch foo' "$DENY_REASON"
run_block_case "blocks git branch -- <name>" 'git branch -- foo' "$DENY_REASON"
run_block_case "blocks git branch --track" 'git branch --track foo origin/main' "$DENY_REASON"
run_block_case "blocks git branch -f" 'git branch -f foo HEAD' "$DENY_REASON"
run_block_case "blocks git branch -qf" 'git branch -qf foo HEAD' "$DENY_REASON"
run_block_case "blocks git -C path checkout -b" 'git -C repo checkout -b foo' "$DENY_REASON"
run_block_case "blocks git checkout --orphan" 'git checkout --orphan foo' "$DENY_REASON"
run_block_case "blocks command git checkout -b" 'command git checkout -b foo' "$DENY_REASON"
run_block_case "blocks chained git checkout -b" 'cd repo && git checkout -b foo' "$DENY_REASON"
run_allow_case "allows git branch (no args)" 'git branch'
run_allow_case "allows git branch --show-current" 'git branch --show-current'
run_allow_case "allows git branch --list" 'git branch --list'
run_allow_case "allows git branch -d foo" 'git branch -d foo'
run_allow_case "allows git branch -D foo" 'git branch -D foo'
run_allow_case "allows git branch -v" 'git branch -v'
run_allow_case "allows git branch --merged" 'git branch --merged'
run_allow_case "allows git checkout main" 'git checkout main'
run_allow_case "allows git switch main" 'git switch main'
run_allow_case "allows checkout followed by diff -b" 'git checkout main && git diff -b'
run_allow_case "allows switch followed by diff -b" 'git switch main; git diff -b'

implicit_repo="$(setup_remote_only_branch_repo implicit)"
run_block_case_in_dir "blocks implicit git checkout remote branch" "$implicit_repo" 'git checkout foo' "$DENY_REASON"
run_block_case_in_dir "blocks quoted implicit git checkout remote branch" "$implicit_repo" 'git checkout "foo"' "$DENY_REASON"
run_block_case_in_dir "blocks implicit git switch remote branch" "$implicit_repo" 'git switch foo' "$DENY_REASON"
run_block_case_in_dir "blocks chained implicit git checkout remote branch" "$implicit_repo" 'git checkout main && git checkout foo' "$DENY_REASON"
run_block_case_in_dir "blocks chained implicit git switch remote branch" "$implicit_repo" 'git switch main; git switch foo' "$DENY_REASON"
run_block_case_in_dir "blocks multiline implicit git checkout remote branch" "$implicit_repo" $'git status\ngit checkout foo' "$DENY_REASON"
run_block_case_in_dir "blocks separator-attached implicit git checkout remote branch" "$implicit_repo" 'git checkout foo; git status' "$DENY_REASON"
run_block_case_in_dir "blocks separator-attached implicit git switch remote branch" "$implicit_repo" 'git switch foo&& git status' "$DENY_REASON"
run_block_case_in_dir "blocks optioned implicit git checkout remote branch" "$implicit_repo" 'git checkout --recurse-submodules foo' "$DENY_REASON"
run_block_case_in_dir "blocks optioned implicit git switch remote branch" "$implicit_repo" 'git switch --discard-changes foo' "$DENY_REASON"
run_allow_case "allows echo mention of implicit checkout" 'echo git checkout foo'
run_block_case "blocks cd then implicit git checkout remote branch" "cd $implicit_repo && git checkout foo" "$DENY_REASON"
home_dir="$TMPROOT/home"
mkdir -p "$home_dir"
ln -s "$implicit_repo" "$home_dir/repo"
run_block_case_with_home "blocks home cd then implicit git checkout remote branch" "$home_dir" 'cd ~/repo && git checkout foo' "$DENY_REASON"
parent_dir="$TMPROOT/parent"
mkdir -p "$parent_dir"
ln -s "$implicit_repo" "$parent_dir/repo"
run_block_case "blocks cd then relative -C implicit checkout remote branch" "cd $parent_dir && git -C repo checkout foo" "$DENY_REASON"
run_block_case "blocks quoted -C path implicit git checkout remote branch" "git -C \"$implicit_repo\" checkout foo" "$DENY_REASON"
upstream_repo="$(setup_remote_only_branch_repo upstream upstream)"
run_block_case_in_dir "blocks implicit checkout from non-origin remote" "$upstream_repo" 'git checkout foo' "$DENY_REASON"

printf 'PASS  blocker helper test suite\n'

#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/block-worktree-commands.sh"

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

run_block_case() {
  local name="$1"
  local command="$2"
  local reason="$3"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$reason" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_allow_case() {
  local name="$1"
  local command="$2"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_empty_case() {
  local name="$1"
  local payload="$2"
  local output

  output="$(printf '%s' "$payload" | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_block_case "blocks raw worktree add" 'git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks raw worktree remove" 'git worktree remove ../foo' 'Do not run git worktree remove directly. Use repo-end to finish work, or cleanup-branches --branch <branch> for cleanup only.'
run_block_case "blocks git -C invocation" 'git -C repo worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks assignment-prefixed invocation" 'GIT_DIR=.git git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_block_case "blocks command builtin invocation" 'command git worktree remove ../foo' 'Do not run git worktree remove directly. Use repo-end to finish work, or cleanup-branches --branch <branch> for cleanup only.'
run_block_case "blocks chained invocation" 'cd repo && git worktree add -b foo ../foo' 'Do not run git worktree add directly. Use repo-start instead.'
run_allow_case "allows repo-start helper" 'repo-start foo'
run_allow_case "allows repo-end helper" 'repo-end'
run_allow_case "allows text mention of worktree add" 'echo git worktree add'
run_allow_case "allows other commands" 'git status --short'
run_empty_case "allows missing command" '{}'
run_empty_case "allows empty command" '{"tool_input":{"command":""}}'

DENY_REASON='Do not create branches directly. Use repo-start <branch> instead.'

run_block_case "blocks git checkout -b" 'git checkout -b foo' "$DENY_REASON"
run_block_case "blocks git checkout -bfoo" 'git checkout -bfoo' "$DENY_REASON"
run_block_case "blocks git switch -c" 'git switch -c foo' "$DENY_REASON"
run_block_case "blocks git switch -cfoo" 'git switch -cfoo' "$DENY_REASON"
run_block_case "blocks git switch --create" 'git switch --create foo' "$DENY_REASON"
run_block_case "blocks git switch --track" 'git switch --track origin/foo' "$DENY_REASON"
run_block_case "blocks git branch <name>" 'git branch foo' "$DENY_REASON"
run_block_case "blocks git branch --track" 'git branch --track foo origin/main' "$DENY_REASON"
run_block_case "blocks git branch -f" 'git branch -f foo HEAD' "$DENY_REASON"
run_block_case "blocks git -C path checkout -b" 'git -C repo checkout -b foo' "$DENY_REASON"
run_block_case "blocks git checkout --orphan" 'git checkout --orphan foo' "$DENY_REASON"
run_block_case "blocks command git checkout -b" 'command git checkout -b foo' "$DENY_REASON"
run_block_case "blocks chained git checkout -b" 'cd repo && git checkout -b foo' "$DENY_REASON"
run_allow_case "allows git branch (no args)" 'git branch'
run_allow_case "allows git branch --show-current" 'git branch --show-current'
run_allow_case "allows git branch --list" 'git branch --list'
run_allow_case "allows git branch -d foo" 'git branch -d foo'
run_allow_case "allows git branch -D foo" 'git branch -D foo'
run_allow_case "allows git branch -v" 'git branch -v'
run_allow_case "allows git branch --merged" 'git branch --merged'
run_allow_case "allows git checkout main" 'git checkout main'
run_allow_case "allows git switch main" 'git switch main'

printf 'PASS  blocker helper test suite\n'

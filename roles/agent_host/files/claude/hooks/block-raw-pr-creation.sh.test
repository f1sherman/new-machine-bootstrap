#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPT="$SCRIPT_DIR/block-raw-pr-creation.sh"
REASON='Use the _pull-request skill to create pull requests; do not call raw PR creation commands directly.'
TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

if [ ! -x "$SCRIPT" ]; then
  printf 'ERROR: %s is not executable (or does not exist)\n' "$SCRIPT" >&2
  exit 2
fi

run_block_case() {
  local name="$1"
  local command="$2"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$REASON" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_block_case_from_dir() {
  local name="$1"
  local cwd="$2"
  local command="$3"
  local output

  output="$(cd "$cwd" && jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$REASON" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_custom_reason_block_case() {
  local name="$1"
  local command="$2"
  local reason="$3"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | PR_WORKFLOW_RAW_PR_BLOCK_REASON="$reason" "$SCRIPT")"
  if printf '%s' "$output" | jq -e --arg reason "$reason" '. == {hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny",permissionDecisionReason:$reason}}' >/dev/null; then
    printf 'PASS  %s\n' "$name"
  else
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  fi
}

run_allow_case() {
  local name="$1"
  local command="$2"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_allow_case_with_hook_env() {
  local name="$1"
  local command="$2"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | PR_WORKFLOW_ALLOW_RAW_PR_HELPERS=1 "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_allow_case_with_home() {
  local name="$1"
  local home="$2"
  local command="$3"
  local output

  output="$(jq -n --arg command "$command" '{tool_input:{command:$command}}' | HOME="$home" PR_WORKFLOW_ALLOW_RAW_PR_HELPERS=1 "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_empty_case() {
  local name="$1"
  local payload="$2"
  local output

  output="$(printf '%s' "$payload" | "$SCRIPT")"
  [ -z "$output" ] || {
    printf 'FAIL  %s\n' "$name" >&2
    printf '      output: %s\n' "$output" >&2
    exit 1
  }
  printf 'PASS  %s\n' "$name"
}

run_block_case "blocks gh pr create" 'gh pr create --fill'
run_block_case "blocks path-qualified gh pr create" '/usr/bin/gh pr create --fill'
run_block_case "blocks gh pr new alias" 'gh pr new --fill'
run_block_case "blocks assignment-prefixed gh pr create" 'GH_TOKEN=x gh pr create --fill'
run_block_case "blocks env assignment gh pr create" 'env GH_TOKEN=x gh pr create --fill'
run_block_case "blocks env option-wrapped gh pr create" "env -i PATH=\$PATH GH_TOKEN=x gh pr create --fill"
run_block_case "blocks repo-scoped gh pr create" 'gh -R example/project pr create --fill'
run_block_case "blocks attached repo-scoped gh pr create" 'gh -Rexample/project pr create --fill'
run_block_case "blocks pr-level repo-scoped gh pr create" 'gh pr --repo example/project create --fill'
run_block_case "blocks pr-level attached repo-scoped gh pr create" 'gh pr -Rexample/project create --fill'
run_block_case "blocks conditional gh pr create" 'if gh pr create --fill; then echo ok; fi'
run_block_case "blocks shell-wrapped gh pr create" "bash -lc 'gh pr create --fill'"
run_block_case "blocks separated login shell gh pr create" "bash -l -c 'gh pr create --fill'"
run_block_case "blocks separated shell option gh pr create" "bash -e -c 'gh pr create --fill'"
scripted_gh_pr="$TMP_DIR/scripted-gh-pr.sh"
printf '%s\n' '#!/usr/bin/env bash' 'gh pr create --fill' > "$scripted_gh_pr"
chmod +x "$scripted_gh_pr"
noop_script="$TMP_DIR/noop.sh"
printf '%s\n' '#!/usr/bin/env bash' 'echo ok' > "$noop_script"
chmod +x "$noop_script"
run_block_case "blocks script-file gh pr create" "bash $scripted_gh_pr"
run_block_case "blocks quoted script-file gh pr create" "bash \"$scripted_gh_pr\""
run_block_case "blocks first script in compound command" "bash $scripted_gh_pr; bash $noop_script"
cd_script_repo="$TMP_DIR/cd-script-repo"
mkdir -p "$cd_script_repo/scripts"
printf '%s\n' '#!/usr/bin/env bash' 'gh pr create --fill' > "$cd_script_repo/scripts/create-pr.sh"
run_block_case "blocks cd-relative script gh pr create" "cd $cd_script_repo && bash scripts/create-pr.sh"
cd_current_repo="$TMP_DIR/cd-current-repo"
cd_target_repo="$TMP_DIR/cd-target-repo"
mkdir -p "$cd_current_repo/scripts" "$cd_target_repo/scripts"
printf '%s\n' '#!/usr/bin/env bash' 'echo ok' > "$cd_current_repo/scripts/create-pr.sh"
printf '%s\n' '#!/usr/bin/env bash' 'gh pr create --fill' > "$cd_target_repo/scripts/create-pr.sh"
run_block_case_from_dir "blocks cd-relative script when original cwd has same path" "$cd_current_repo" "cd $cd_target_repo && bash scripts/create-pr.sh"
cd_later_repo="$TMP_DIR/cd-later-repo"
mkdir -p "$cd_later_repo/scripts"
printf '%s\n' '#!/usr/bin/env bash' 'echo ok' > "$cd_later_repo/scripts/create-pr.sh"
run_block_case_from_dir "blocks cd-relative script before later cd" "$cd_current_repo" "cd $cd_target_repo && bash scripts/create-pr.sh; cd $cd_later_repo"
run_block_case "blocks sourced script gh pr create" "source $scripted_gh_pr"
run_block_case "blocks dot-sourced script gh pr create" ". $scripted_gh_pr"
run_block_case "blocks direct executable gh pr create" "$scripted_gh_pr"
run_block_case "blocks quoted direct executable gh pr create" "\"$scripted_gh_pr\""
run_block_case "blocks command-prefixed gh pr create" 'command gh pr create --title test'
run_block_case "blocks sudo user-wrapped gh pr create" 'sudo -u brian gh pr create --fill'
run_block_case "blocks time option-wrapped gh pr create" 'time -p gh pr create --fill'
run_block_case "blocks gh api pull create" 'gh api -X POST repos/example/project/pulls -f title=test'
run_block_case "blocks host-scoped gh api pull create" 'gh --hostname forgejo.brianjohn.com api repos/example/project/pulls -f title=test -f head=branch -f base=main'
run_block_case "blocks implicit POST gh api pull create" 'gh api repos/example/project/pulls -f title=test -f head=branch -f base=main'
run_block_case "blocks gh api input pull create" 'gh api repos/example/project/pulls --input payload.json'
run_block_case "blocks quoted gh api pull create" "gh api 'repos/example/project/pulls' -f title=test -f head=branch -f base=main"
run_block_case "blocks GraphQL createPullRequest" "gh api graphql -f query='mutation { createPullRequest(input:{repositoryId:\"R\",baseRefName:\"main\",headRefName:\"b\",title:\"t\"}) { pullRequest { url } } }'"
graphql_create_payload="$TMP_DIR/graphql-create-pr.json"
printf '%s\n' '{"query":"mutation { createPullRequest(input:{repositoryId:\"R\",baseRefName:\"main\",headRefName:\"b\",title:\"t\"}) { pullRequest { url } } }"}' > "$graphql_create_payload"
graphql_create_query="$TMP_DIR/graphql-create-pr.graphql"
printf '%s\n' 'mutation { createPullRequest(input:{repositoryId:"R",baseRefName:"main",headRefName:"b",title:"t"}) { pullRequest { url } } }' > "$graphql_create_query"
run_block_case "blocks GraphQL input createPullRequest" "gh api graphql --method POST --input $graphql_create_payload"
run_block_case "blocks GraphQL field file createPullRequest" "gh api graphql -F query=@$graphql_create_query"
run_block_case "blocks GraphQL long field file createPullRequest" "gh api graphql --field query=@$graphql_create_query"
run_block_case "blocks curl GraphQL createPullRequest" 'curl -X POST https://api.github.com/graphql -d query=createPullRequest'
run_block_case "blocks curl GraphQL data file createPullRequest" "curl -X POST https://api.github.com/graphql -d @$graphql_create_payload"
run_block_case "blocks Forgejo curl pull create" 'curl -fsSL -X POST https://forgejo.brianjohn.com/api/v1/repos/example/project/pulls'
run_block_case "blocks custom Forgejo curl pull create" 'curl -fsSL -X POST https://forgejo.example.com/api/v1/repos/example/project/pulls'
scripted_curl_pr="$TMP_DIR/scripted-curl-pr.sh"
printf '%s\n' '#!/usr/bin/env bash' 'curl -fsSL -X POST https://forgejo.brianjohn.com/api/v1/repos/example/project/pulls' > "$scripted_curl_pr"
chmod +x "$scripted_curl_pr"
run_block_case "blocks script-file curl pull create" "sh $scripted_curl_pr"
run_block_case "blocks quoted script-file curl pull create" "sh '$scripted_curl_pr'"
run_block_case "blocks direct executable curl pull create" "$scripted_curl_pr"
run_block_case "blocks path-qualified curl pull create" '/usr/bin/curl -X POST https://api.github.com/repos/example/project/pulls'
run_block_case "blocks GitHub curl pull create" 'curl --request POST https://api.github.com/repos/example/project/pulls'
run_block_case "blocks quoted curl pull create" "curl -X POST 'https://api.github.com/repos/example/project/pulls'"
run_block_case "blocks curl data-raw pull create" "curl --data-raw '{\"title\":\"x\"}' https://api.github.com/repos/example/project/pulls"
run_block_case "blocks curl attached short data pull create" "curl -d'{\"title\":\"x\"}' https://api.github.com/repos/example/project/pulls"
run_block_case "blocks curl data-ascii pull create" "curl --data-ascii '{\"title\":\"x\"}' https://api.github.com/repos/example/project/pulls"
run_block_case "blocks direct Forgejo helper" 'bash ~/.local/share/skills/_pr-forgejo/create.sh --title test --body test'
run_block_case "blocks direct GitHub helper" 'bash ~/.local/share/skills/_pr-github/create.sh --title test --body test'
run_block_case "blocks helper when allow marker is echoed separately" 'echo PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1; bash ~/.local/share/skills/_pr-github/create.sh --title test'
run_block_case "blocks raw create before workflow-marked helper" 'gh pr create --fill; PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title test'
run_block_case "blocks raw create after workflow-marked helper" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title test; gh pr create --fill'
run_block_case "blocks workflow helper without hook allowance" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title test'
run_block_case "blocks workflow helper backtick substitution" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title `gh pr create --fill` --body x'
run_block_case "blocks workflow helper command substitution" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title "$(gh pr create --fill)" --body x'
helper_wrapper="$TMP_DIR/helper-wrapper.sh"
printf '%s\n' '#!/usr/bin/env bash' '# PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1' 'bash ~/.local/share/skills/_pr-github/create.sh --title test' > "$helper_wrapper"
chmod +x "$helper_wrapper"
run_block_case "blocks helper wrapper with marker comment" "bash $helper_wrapper"
run_custom_reason_block_case "blocks with custom runtime reason" 'gh pr create --fill' 'Commit changes only; the service creates the PR.'
run_allow_case "allows _pull-request skill mention" 'echo invoke _pull-request'
run_allow_case "allows gh pr list" 'gh pr list --state open'
run_allow_case "allows explicit GET gh api pull query with fields" 'gh api --method GET repos/example/project/pulls -f state=open'
run_allow_case "allows host-scoped GET gh api pull query" 'gh --hostname forgejo.brianjohn.com api --method GET repos/example/project/pulls -f state=open'
run_allow_case "allows curl pull read" 'curl -fsSL https://forgejo.example/api/v1/repos/example/project/pulls?state=open'
run_allow_case "allows curl GET query with encoded fields" 'curl -G --data-urlencode state=open https://api.github.com/repos/example/project/pulls'
run_allow_case "allows gh api nested PR comment POST" 'gh api --method POST repos/example/project/pulls/123/comments/456/replies -f body=ok'
run_allow_case "allows curl nested PR comment POST" 'curl -X POST https://api.github.com/repos/example/project/pulls/123/comments'
run_allow_case "allows local app pulls POST" 'curl -X POST http://localhost:3000/pulls -d name=x'
run_allow_case "allows local GraphQL createPullRequest test" 'curl -X POST http://localhost:3000/graphql -d query=createPullRequest'
graphql_query_payload="$TMP_DIR/graphql-query.json"
printf '%s\n' '{"query":"query { viewer { login } }"}' > "$graphql_query_payload"
run_allow_case "allows GraphQL input without createPullRequest" "gh api graphql --method POST --input $graphql_query_payload"
run_allow_case "allows reading executable script contents" "cat $scripted_gh_pr"
# shellcheck disable=SC2016
run_block_case "blocks helper handoff without workflow marker" 'pr_output="$(bash ~/.local/share/skills/_pr-forgejo/create.sh --base "$BASE" --head "$BRANCH" --title "$PR_TITLE" --body "$PR_BODY")"'
run_allow_case_with_hook_env "allows workflow-marked helper invocation" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-forgejo/create.sh --title test'
helper_home="$TMP_DIR/helper-home"
mkdir -p "$helper_home/.local/share/skills/_pr-github"
printf '%s\n' '#!/usr/bin/env bash' 'gh pr create --repo example/project --base main --head branch --title test --body test' > "$helper_home/.local/share/skills/_pr-github/create.sh"
chmod +x "$helper_home/.local/share/skills/_pr-github/create.sh"
run_allow_case_with_home "allows workflow-marked GitHub helper with internal gh create" "$helper_home" 'PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title test'
run_allow_case_with_home "allows wrapped workflow-marked GitHub helper with internal gh create" "$helper_home" 'cd "$REPO_DIR"; pr_output="$(PR_WORKFLOW_ALLOW_RAW_PR_CREATE=1 bash ~/.local/share/skills/_pr-github/create.sh --title test)"'
run_allow_case "allows unrelated commands" 'git status --short'
run_empty_case "allows missing command" '{}'
run_empty_case "allows empty command" '{"tool_input":{"command":""}}'

printf 'PASS  raw PR creation blocker test suite\n'

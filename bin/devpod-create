#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'

SCRIPT_DIR = File.expand_path('..', __dir__)
require_relative '../lib/dev_env_syncer'
require_relative '../lib/claude_session_syncer'
require_relative '../lib/remote_transport'

def command_exists?(cmd)
  system("command -v #{cmd} >/dev/null 2>&1")
end

def ensure_devpod_installed
  return if command_exists?('devpod')

  puts "Error: devpod CLI is required but not installed"
  puts "Install from: https://devpod.sh/docs/getting-started/install"
  exit 1
end

def parse_repository_from_source(source)
  # github.com/org/repo or github.com/org/repo.git → "org/repo"
  if source =~ %r{github\.com/([^/]+/[^/]+?)(?:\.git)?$}
    $1
  end
end

def sync_bootstrap_repo(workspace_name)
  puts "\n==> Syncing bootstrap repo to DevPod workspace..."

  Dir.chdir(SCRIPT_DIR)

  tar_cmd = "COPYFILE_DISABLE=1 tar czf - --no-mac-metadata --exclude='.git' --exclude='.coding-agent' --exclude='.claude' --exclude='*.backup' --exclude='.DS_Store' --exclude='._*' --exclude='.codespace-defaults.yml' ."
  ssh_cmd = "ssh #{workspace_name}.devpod 'mkdir -p ~/new-machine-bootstrap && cd ~/new-machine-bootstrap && tar xzf -'"
  sync_cmd = "#{tar_cmd} | #{ssh_cmd}"

  system(sync_cmd)

  unless $?.success?
    puts "Error: Failed to sync bootstrap repo to #{workspace_name}"
    return false
  end

  puts "==> Bootstrap repo sync complete!"
  true
end

def run_provisioning(workspace_name)
  puts "\n==> Running Ansible provisioning in DevPod workspace..."

  provision_cmd = "ssh #{workspace_name}.devpod 'cd ~/new-machine-bootstrap && CODESPACES=true ./bin/provision'"
  puts "Running: ssh #{workspace_name}.devpod '... CODESPACES=true ./bin/provision'"
  system(provision_cmd)

  unless $?.success?
    puts ""
    puts "=" * 60
    puts "ERROR: Provisioning failed for #{workspace_name}!"
    puts "=" * 60
    puts ""
    puts "To investigate, check the log file:"
    puts "  ssh #{workspace_name}.devpod 'cat /tmp/provision-latest.log'"
    puts ""
    puts "Or SSH in manually:"
    puts "  devpod ssh #{workspace_name}"
    puts ""
    return false
  end

  puts "\n==> Provisioning complete!"
  true
end

def sync_dev_env(workspace_name, repository, repo_name)
  remote_path = "/workspaces/#{repo_name}/.coding-agent"
  transport = RemoteTransport::DevpodTransport.new(workspace_name)

  begin
    DevEnvSyncer.sync_to_codespace(Dir.pwd, workspace_name, remote_path,
                                   codespace_repository: repository,
                                   transport: transport)
  rescue DevEnvSyncer::SyncError => e
    puts "\nWarning: Failed to sync dev environment"
    puts e.message
    puts "You can manually sync later with: bin/sync-dev-env"
  end
end

def sync_sessions(workspace_name, repo_name)
  transport = RemoteTransport::DevpodTransport.new(workspace_name)

  puts "\n==> Syncing Claude sessions to #{workspace_name}..."
  ClaudeSessionSyncer.sync_sessions_to_codespace(repo_name, workspace_name, transport: transport)
rescue StandardError => e
  puts "    Warning: Could not sync sessions: #{e.message}"
end

def main
  ensure_devpod_installed

  options = {
    compose_profile: 'rspec'
  }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: devpod-create --source SOURCE --id WORKSPACE_ID [OPTIONS]"
    opts.separator ""
    opts.separator "Required options:"

    opts.on("-s", "--source SOURCE", "Repository source (e.g., github.com/org/repo or local path)") do |v|
      options[:source] = v
    end

    opts.on("-i", "--id WORKSPACE_ID", "Workspace ID/name") do |v|
      options[:id] = v
    end

    opts.separator ""
    opts.separator "Optional:"

    opts.on("-p", "--compose-profile PROFILE", "Docker Compose profile (default: rspec)") do |v|
      options[:compose_profile] = v
    end

    opts.on("--no-provision", "Skip Ansible provisioning") do
      options[:no_provision] = true
    end

    opts.on("--no-sessions", "Skip syncing Claude sessions") do
      options[:no_sessions] = true
    end

    opts.separator ""
    opts.separator "Examples:"
    opts.separator "  devpod-create --source github.com/org/repo --id my-feature"
    opts.separator "  devpod-create --source ~/projects/my-repo --id local-test --compose-profile rails"

    opts.on("-h", "--help", "Show this help message") do
      puts opts
      exit
    end
  end

  begin
    parser.parse!
  rescue OptionParser::InvalidOption, OptionParser::MissingArgument => e
    puts "Error: #{e.message}"
    puts ""
    puts parser
    exit 1
  end

  missing = []
  missing << "--source" unless options[:source]
  missing << "--id" unless options[:id]

  unless missing.empty?
    puts "Error: Missing required arguments: #{missing.join(', ')}"
    puts ""
    puts parser
    exit 1
  end

  source = options[:source]
  workspace_id = options[:id]
  compose_profile = options[:compose_profile]

  puts "\n==> Creating DevPod workspace..."
  puts "    Source: #{source}"
  puts "    Workspace ID: #{workspace_id}"
  puts "    Compose profile: #{compose_profile}"
  puts ""

  cmd = [
    'devpod', 'up', source,
    '--ide', 'none',
    '--id', workspace_id,
    '--devcontainer-path', '.devcontainer/devpod/devcontainer.json',
    '--workspace-env-file', File.expand_path('~/.devpod-env'),
    '--workspace-env', "DEVPOD_COMPOSE_PROFILE=#{compose_profile}"
  ]

  unless system(*cmd)
    puts "Error: Failed to create DevPod workspace"
    exit 1
  end

  puts "==> DevPod workspace created: #{workspace_id}"

  # Create /workspaces/{repo_name} symlink so devcontainer scripts that
  # reference the repo by name (not workspace ID) work correctly
  repo_name = source.split('/').last.sub(/\.git$/, '')
  workspace_dir = "/workspaces/#{workspace_id}"
  repo_symlink = "/workspaces/#{repo_name}"
  if repo_name != workspace_id
    system("ssh #{workspace_id}.devpod '[ ! -e #{repo_symlink} ] && ln -s #{workspace_dir} #{repo_symlink} || true'")
  end

  unless options[:no_provision]
    unless sync_bootstrap_repo(workspace_id)
      exit 1
    end

    unless run_provisioning(workspace_id)
      puts "\nWarning: Provisioning failed, but workspace is available"
      puts "You can retry with: sync-to-devpod #{workspace_id}"
    end
  end

  repository = parse_repository_from_source(source)

  sync_dev_env(workspace_id, repository, repo_name)

  unless options[:no_sessions]
    sync_sessions(workspace_id, repo_name)
  end

  puts "\n==> Done! Your DevPod workspace is ready."
  puts "\nTo connect, run:"
  puts "  devpod-ssh #{workspace_id}"
end

main

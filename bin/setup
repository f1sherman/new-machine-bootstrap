#!/bin/bash
# One-time system setup for macOS (must be run as root via sudo)
#
# This script configures system-level settings that require root access.
# It only needs to be run once per machine, or after a macOS update resets settings.
#
# Run this BEFORE bin/provision on a new machine:
#
#   sudo bin/setup
#
# Running as root in one shot avoids the per-statement password prompts that
# happen when individual `sudo` calls can't reuse the credential cache.

set -e

if [[ "$OSTYPE" != "darwin"* ]]; then
  echo "Error: bin/setup is only for macOS."
  exit 1
fi

if [[ $EUID -ne 0 ]]; then
  echo "Error: bin/setup must be run as root."
  echo "  Re-run with: sudo $0"
  exit 1
fi

if [[ -z "${SUDO_USER:-}" || "$SUDO_USER" == "root" ]]; then
  echo "Error: bin/setup must be invoked via sudo from a non-root user account."
  echo "  Re-run with: sudo $0"
  exit 1
fi

# The invoking user (and their homedir) — needed for per-user state like the
# default shell and the flushdns sudoers entry.
TARGET_USER="$SUDO_USER"
TARGET_HOME=$(dscl . -read "/Users/$TARGET_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
if [[ -z "$TARGET_HOME" ]]; then
  TARGET_HOME="/Users/$TARGET_USER"
fi

BREW_PREFIX=$(sudo -u "$TARGET_USER" brew --prefix 2>/dev/null)
if [[ -z "$BREW_PREFIX" ]]; then
  echo "Error: Homebrew is not installed. Install it first:"
  echo '  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"'
  exit 1
fi

HOMEBREW_ZSH="$BREW_PREFIX/bin/zsh"
if [[ ! -x "$HOMEBREW_ZSH" ]]; then
  echo "Error: Homebrew's zsh not found at $HOMEBREW_ZSH"
  echo "  Install it with: brew install zsh"
  exit 1
fi

echo "==> Setting default shell to Homebrew's zsh..."
if ! grep -qF "$HOMEBREW_ZSH" /etc/shells; then
  echo "    Adding $HOMEBREW_ZSH to /etc/shells..."
  echo "$HOMEBREW_ZSH" | sudo tee -a /etc/shells >/dev/null
fi
dscl . -create "/Users/$TARGET_USER" UserShell "$HOMEBREW_ZSH"
echo "    Done."

echo "==> Configuring system settings..."
sudo nvram SystemAudioVolume=" "
sudo systemsetup -setrestartfreeze on
sudo systemsetup -settimezone America/Chicago
sudo defaults write /Library/Preferences/com.apple.loginwindow SHOWFULLNAME -bool true
sudo defaults write /Library/Preferences/com.apple.loginwindow GuestEnabled -bool false
sudo pmset -a hibernatemode 0
sudo pmset -a sms 0
if pmset -g cap 2>/dev/null | grep -qw lowpowermode; then
  sudo pmset -b powermode 1
  sudo pmset -c powermode 0
fi
sudo chflags nohidden /Volumes
echo "    Done."

echo "==> Raising launchctl maxfiles soft limit..."
# macOS ships with a 256-fd soft limit, which the tmux server inherits at boot.
# Long-lived sessions with ~30+ panes plus per-pane subprocesses can exhaust 256
# fds; once fd-locked, every tmux hook spawns a hung shell waiting on the locked
# server, compounding the problem until tmux can no longer fork. A persistent
# LaunchDaemon raises the limit for processes started by launchd at boot.
MAXFILES_SOFT=65536
MAXFILES_HARD=524288
MAXFILES_PLIST=/Library/LaunchDaemons/limit.maxfiles.plist
maxfiles_plist_body() {
  cat <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>limit.maxfiles</string>
  <key>ProgramArguments</key>
  <array>
    <string>launchctl</string>
    <string>limit</string>
    <string>maxfiles</string>
    <string>$MAXFILES_SOFT</string>
    <string>$MAXFILES_HARD</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>ServiceIPC</key>
  <false/>
</dict>
</plist>
PLIST
}
desired="$(maxfiles_plist_body)"
if [[ ! -f "$MAXFILES_PLIST" ]] || ! sudo cmp -s <(printf '%s' "$desired") "$MAXFILES_PLIST"; then
  printf '%s' "$desired" | sudo tee "$MAXFILES_PLIST" >/dev/null
  sudo chown root:wheel "$MAXFILES_PLIST"
  sudo chmod 0644 "$MAXFILES_PLIST"
  sudo launchctl load -w "$MAXFILES_PLIST" 2>/dev/null || true
fi
sudo launchctl limit maxfiles "$MAXFILES_SOFT" "$MAXFILES_HARD" 2>/dev/null || true
echo "    Done. (a logout/login is required for already-running launchd children to inherit the new limit)"

echo "==> Configuring flushdns sudoers entry..."
FLUSHDNS_PATH="$TARGET_HOME/.local/bin/flushdns"
SUDOERS_LINE="%admin    ALL = (root) NOPASSWD: $FLUSHDNS_PATH"
if sudo grep -qF "$FLUSHDNS_PATH" /etc/sudoers; then
  echo "    Already configured."
else
  # Remove any old flushdns entry pointing to /opt/local/bin
  sudo sed -i '' '/flushdns/d' /etc/sudoers
  echo "$SUDOERS_LINE" | sudo tee -a /etc/sudoers >/dev/null
  echo "    Done."
fi

echo ""
echo "System setup complete. You can now run bin/provision without sudo."

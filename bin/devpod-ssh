#!/usr/bin/env ruby
# frozen_string_literal: true

require 'json'
require 'open3'
require 'optparse'

SCRIPT_DIR = File.expand_path('..', __dir__)

require_relative '../lib/devpod_selector'
require_relative '../lib/dev_env_syncer'
require_relative '../lib/claude_session_syncer'
require_relative '../lib/claude_permissions_merger'
require_relative '../lib/remote_transport'

def transport_for(workspace_name)
  RemoteTransport::DevpodTransport.new(workspace_name)
end

def repo_name_for(workspace_name)
  DevpodSelector.repo_name_for_workspace(workspace_name)
end

def workspace_running?(workspace_name)
  stdout, _stderr, status = Open3.capture3('devpod', 'status', workspace_name, '--output', 'json')
  return false unless status.success?

  state = JSON.parse(stdout)['state']
  state == 'Running'
rescue JSON::ParserError
  false
end

def needs_provisioning?(workspace_name)
  _stdout, _stderr, status = Open3.capture3(
    'ssh', "#{workspace_name}.devpod", 'test -d ~/new-machine-bootstrap'
  )
  !status.success?
end

def remove_stale_devcontainer_images
  puts "    Removing cached devcontainer images to force rebuild on retry..."
  stale = `docker images --format '{{.Repository}}:{{.Tag}}' | grep '^vsc-content-.*:devpod-'`.strip.split("\n")
  running_images = `docker ps --format '{{.Image}}'`.strip.split("\n")
  stale.each do |img|
    next if running_images.include?(img)

    system("docker rmi #{img} >/dev/null 2>&1")
  end
end

def workspace_source(workspace_name)
  workspaces = JSON.parse(Open3.capture3('devpod', 'list', '--output', 'json').first)
  ws = workspaces.find { |w| w['id'] == workspace_name }
  ws&.dig('source', 'gitRepository')
rescue JSON::ParserError
  nil
end

def recreate_workspace(workspace_name, source:, compose_profile:)
  puts "==> Deleting workspace and recreating from scratch..."
  puts "    Source: #{source}"
  puts ""
  system('devpod', 'delete', workspace_name)

  cmd = [
    'devpod', 'up', source,
    '--ide', 'none',
    '--id', workspace_name,
    '--devcontainer-path', '.devcontainer/devpod/devcontainer.json',
    '--workspace-env-file', File.expand_path('~/.devpod-env'),
    '--workspace-env', "DEVPOD_COMPOSE_PROFILE=#{compose_profile}"
  ]

  unless system(*cmd)
    puts "Error: Failed to recreate DevPod workspace"
    exit 1
  end
end

def start_workspace(workspace_name, compose_profile:)
  puts "==> Starting DevPod workspace..."
  puts ""

  cmd = [
    'devpod', 'up', workspace_name,
    '--ide', 'none',
    '--workspace-env-file', File.expand_path('~/.devpod-env'),
    '--workspace-env', "DEVPOD_COMPOSE_PROFILE=#{compose_profile}"
  ]

  return if system(*cmd)

  # First retry: remove stale images and try again
  content_dir = File.expand_path("~/.devpod/agent/contexts/default/workspaces/#{workspace_name}/content")
  if File.directory?(content_dir)
    puts "\n==> First attempt failed. Removing stale devcontainer images and retrying..."
    remove_stale_devcontainer_images
    puts "==> Retrying devpod up..."
    return if system(*cmd)
  end

  # Final fallback: full delete and recreate
  source = workspace_source(workspace_name)
  unless source
    puts "Error: Failed to start workspace and could not determine source repository for recreation"
    exit 1
  end

  puts "\n==> Retry failed. Attempting full workspace recreation..."
  print "Delete and recreate workspace from scratch? [y/N] "
  $stdout.flush
  response = $stdin.gets&.strip&.downcase
  if response == 'y'
    recreate_workspace(workspace_name, source: source, compose_profile: compose_profile)
  else
    puts "Error: Failed to start DevPod workspace"
    exit 1
  end
end

def provision_workspace(workspace_name)
  repo_name = repo_name_for(workspace_name)

  # Create /workspaces/{repo_name} symlink
  if repo_name && repo_name != workspace_name
    workspace_dir = "/workspaces/#{workspace_name}"
    repo_symlink = "/workspaces/#{repo_name}"
    system("ssh #{workspace_name}.devpod '[ ! -e #{repo_symlink} ] && ln -s #{workspace_dir} #{repo_symlink} || true'")
  end

  # Write workspace directory for .zprofile
  target_dir = "/workspaces/#{repo_name || workspace_name}"
  system("ssh #{workspace_name}.devpod 'echo #{target_dir} > ~/.workspace-dir'")

  # Sync bootstrap repo
  puts "==> Syncing bootstrap repo to DevPod workspace..."
  Dir.chdir(SCRIPT_DIR)

  tar_cmd = "COPYFILE_DISABLE=1 tar czf - --no-mac-metadata --exclude='.git' --exclude='.coding-agent' --exclude='.claude' --exclude='*.backup' --exclude='.DS_Store' --exclude='._*' --exclude='.codespace-defaults.yml' ."
  ssh_cmd = "ssh #{workspace_name}.devpod 'mkdir -p ~/new-machine-bootstrap && cd ~/new-machine-bootstrap && tar xzf -'"
  unless system("#{tar_cmd} | #{ssh_cmd}")
    puts "Warning: Failed to sync bootstrap repo"
    return
  end

  # Run provisioning
  puts "\n==> Running Ansible provisioning..."
  puts "Running: ssh #{workspace_name}.devpod '... CODESPACES=true ./bin/provision'"
  unless system("ssh #{workspace_name}.devpod 'cd ~/new-machine-bootstrap && CODESPACES=true ./bin/provision'")
    puts ""
    puts "=" * 60
    puts "WARNING: Provisioning failed!"
    puts "=" * 60
    puts ""
    puts "You can retry with: sync-to-devpod #{workspace_name}"
    puts ""
    return
  end

  puts "\n==> Provisioning complete!"

  # Sync dev environment
  return unless repo_name

  transport = transport_for(workspace_name)
  remote_path = "/workspaces/#{repo_name}/.coding-agent"

  begin
    local_remote = `git remote get-url origin 2>/dev/null`.strip
    return if local_remote.empty?

    repository = if local_remote =~ %r{github\.com[:/]([^/]+/[^/]+?)(?:\.git)?$}
                   $1
                 end
    return unless repository

    DevEnvSyncer.sync_to_codespace(Dir.pwd, workspace_name, remote_path,
                                   codespace_repository: repository,
                                   transport: transport)
  rescue DevEnvSyncer::SyncError => e
    puts "Warning: Failed to sync dev environment: #{e.message}"
  end
end

def prompt_for_new_permissions(workspace_name, repo_name)
  transport = transport_for(workspace_name)
  remote_dir = "/workspaces/#{repo_name}"

  new_permissions = DevEnvSyncer.get_new_permissions_from_codespace(
    Dir.pwd, workspace_name, remote_dir, transport: transport
  )

  local_settings_path = File.join(Dir.pwd, ClaudePermissionsMerger::SETTINGS_SUBPATH)
  ClaudePermissionsMerger.prompt_and_merge(new_permissions, local_settings_path)
end

def sync_coding_agent_back(workspace_name)
  repo_name = repo_name_for(workspace_name)
  return unless repo_name

  transport = transport_for(workspace_name)
  remote_dir = "/workspaces/#{repo_name}"

  begin
    local_remote = `git remote get-url origin 2>/dev/null`.strip
    return if local_remote.empty?

    DevEnvSyncer.sync_from_codespace(Dir.pwd, workspace_name, remote_dir, transport: transport)

    puts "\n==> Syncing Claude sessions..."
    ClaudeSessionSyncer.sync_sessions_from_codespace(repo_name, workspace_name, transport: transport)

    prompt_for_new_permissions(workspace_name, repo_name)
  rescue DevEnvSyncer::SyncError, StandardError => e
    $stderr.puts "Warning: Could not sync back from DevPod: #{e.message}"
  end
end

def sync_sessions_before_connect(workspace_name)
  repo_name = repo_name_for(workspace_name)
  return unless repo_name

  transport = transport_for(workspace_name)

  begin
    local_remote = `git remote get-url origin 2>/dev/null`.strip
    return if local_remote.empty?

    puts "==> Syncing Claude sessions..."

    puts "    Pulling from DevPod..."
    ClaudeSessionSyncer.sync_sessions_from_codespace(repo_name, workspace_name, transport: transport)

    puts "    Pushing to DevPod..."
    ClaudeSessionSyncer.sync_sessions_to_codespace(repo_name, workspace_name, transport: transport)

    puts ""
  rescue StandardError => e
    $stderr.puts "Warning: Could not sync sessions before connect: #{e.message}"
  end
end

def upgrade_cli_tools(workspace_name)
  puts "==> Upgrading Claude Code and Codex to latest versions..."
  upgrade_cmd = [
    'curl -fsSL https://claude.ai/install.sh 2>/dev/null | bash >/dev/null 2>&1',
    'PATH="$HOME/.local/bin:$PATH" mise exec node@lts -- npm install -g @openai/codex@latest >/dev/null 2>&1',
    'echo "    claude $(~/.local/bin/claude --version 2>/dev/null || echo unknown)"',
    'echo "    codex  $(PATH=$HOME/.local/bin:$PATH mise exec node@lts -- codex --version 2>/dev/null || echo unknown)"'
  ].join('; ')
  system("ssh", "#{workspace_name}.devpod", upgrade_cmd)
  puts ""
end

def main
  options = { compose_profile: 'rspec' }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: devpod-ssh [OPTIONS] [WORKSPACE_NAME]"
    opts.separator ""
    opts.separator "Connect to a DevPod workspace via SSH. If the workspace is stopped,"
    opts.separator "it will be started automatically. If the workspace name is omitted,"
    opts.separator "selects from available workspaces (uses fzf if multiple)."
    opts.separator ""
    opts.separator "Options:"

    opts.on("-p", "--compose-profile PROFILE", "Docker Compose profile for workspace start (default: rspec)") do |v|
      options[:compose_profile] = v
    end

    opts.on("--recreate", "Force delete and recreate the workspace from scratch") do
      options[:recreate] = true
    end

    opts.on("-h", "--help", "Show this help message") do
      puts opts
      exit
    end

    opts.separator ""
    opts.separator "Examples:"
    opts.separator "  devpod-ssh                                  # Select from available workspaces"
    opts.separator "  devpod-ssh my-feature                       # Connect to a specific workspace"
    opts.separator "  devpod-ssh --recreate my-feature             # Rebuild a broken workspace"
    opts.separator "  devpod-ssh --recreate -p rails my-feature    # Rebuild with a different compose profile"
  end

  begin
    parser.parse!
  rescue OptionParser::InvalidOption, OptionParser::MissingArgument => e
    puts "Error: #{e.message}"
    puts ""
    puts parser
    exit 1
  end

  workspace_name = begin
    DevpodSelector.select_workspace(workspace_name: ARGV[0])
  rescue DevpodSelector::SelectionError => e
    puts "Error: #{e.message}"
    exit 1
  end

  puts "==> Connecting to DevPod workspace: #{workspace_name}"
  puts ""

  if options[:recreate]
    source = workspace_source(workspace_name)
    unless source
      puts "Error: Could not determine source repository for workspace"
      exit 1
    end

    recreate_workspace(workspace_name, source: source, compose_profile: options[:compose_profile])

    puts "==> Running post-creation setup..."
    puts ""
    provision_workspace(workspace_name)
  elsif !workspace_running?(workspace_name)
    puts "Workspace is not running."
    puts ""
    start_workspace(workspace_name, compose_profile: options[:compose_profile])

    if needs_provisioning?(workspace_name)
      puts "==> Container was rebuilt, running post-creation setup..."
      puts ""
      provision_workspace(workspace_name)
    end
  end

  sync_sessions_before_connect(workspace_name)

  upgrade_cli_tools(workspace_name)

  # Save last workspace for quick reconnect (per-terminal)
  tty_suffix = `tty 2>/dev/null`.strip.gsub(%r{^/dev/}, '').gsub('/', '-')
  unless tty_suffix.empty?
    File.write(File.expand_path("~/.last-devpod-#{tty_suffix}"), workspace_name)
  end

  system("devpod ssh #{workspace_name}")
  ssh_exit_code = $?.exitstatus

  # Reset terminal state
  system("stty sane 2>/dev/null")

  puts "\n==> Disconnected from DevPod workspace: #{workspace_name}"

  sync_coding_agent_back(workspace_name)

  print "Stop this DevPod workspace? [y/N] "
  $stdout.flush
  response = $stdin.gets&.strip&.downcase
  if response == 'y'
    puts "==> Stopping workspace..."
    system("devpod stop #{workspace_name}")
  else
    puts "To reconnect run: devpod-ssh #{workspace_name}"
  end

  exit ssh_exit_code
end

main

#!/usr/bin/env ruby
# frozen_string_literal: true

# Ensure output is not buffered
$stdout.sync = true
$stderr.sync = true

require 'optparse'

SCRIPT_DIR = File.expand_path('..', __dir__)
require_relative File.join(SCRIPT_DIR, 'lib', 'devpod_selector')
require_relative File.join(SCRIPT_DIR, 'lib', 'claude_session_syncer')
require_relative File.join(SCRIPT_DIR, 'lib', 'remote_transport')

def sync_to_devpod(workspace_name)
  puts "==> Syncing repository to DevPod workspace: #{workspace_name}"
  puts "    Excluding: .git/, .coding-agent/, .claude/, *.backup files, macOS metadata"
  puts ""

  Dir.chdir(SCRIPT_DIR)

  tar_cmd = "COPYFILE_DISABLE=1 tar czf - --no-mac-metadata --exclude='.git' --exclude='.coding-agent' --exclude='.claude' --exclude='*.backup' --exclude='.DS_Store' --exclude='._*' --exclude='.codespace-defaults.yml' ."
  ssh_cmd = "ssh #{workspace_name}.devpod 'mkdir -p ~/new-machine-bootstrap && cd ~/new-machine-bootstrap && tar xzf -'"
  sync_cmd = "#{tar_cmd} | #{ssh_cmd}"

  system(sync_cmd)

  unless $?.success?
    puts "Error: Failed to sync repository to #{workspace_name}"
    return false
  end

  puts ""
  puts "==> Sync complete!"
  puts ""
  puts "==> Running provisioning in DevPod workspace..."
  puts ""

  provision_cmd = "ssh #{workspace_name}.devpod 'cd ~/new-machine-bootstrap && CODESPACES=true ./bin/provision'"
  puts "Running: ssh #{workspace_name}.devpod '... CODESPACES=true ./bin/provision'"
  system(provision_cmd)

  unless $?.success?
    puts ""
    puts "=" * 60
    puts "ERROR: Provisioning failed for #{workspace_name}!"
    puts "=" * 60
    puts ""
    puts "To investigate, check the log file:"
    puts "  ssh #{workspace_name}.devpod 'cat /tmp/provision-latest.log'"
    puts ""
    puts "Or SSH in manually:"
    puts "  devpod ssh #{workspace_name}"
    puts ""
    return false
  end

  puts ""
  puts "==> Provisioning complete for #{workspace_name}!"
  true
end

def sync_sessions_to_devpod(workspace_name, repo_name)
  transport = RemoteTransport::DevpodTransport.new(workspace_name)

  puts "\n==> Syncing Claude sessions to #{workspace_name}..."
  ClaudeSessionSyncer.sync_sessions_to_codespace(repo_name, workspace_name, transport: transport)
  true
rescue StandardError => e
  puts "    Warning: Could not sync sessions: #{e.message}"
  false
end

def main
  options = { sessions: true }

  parser = OptionParser.new do |opts|
    opts.banner = "Usage: sync-to-devpod [OPTIONS] [WORKSPACE_NAME]"
    opts.separator ""
    opts.separator "Syncs bootstrap repository to DevPod workspace and runs provisioning."
    opts.separator "If no workspace name provided, syncs to all running workspaces."
    opts.separator ""
    opts.separator "Options:"

    opts.on("--no-sessions", "Skip syncing Claude sessions") do
      options[:sessions] = false
    end

    opts.on("-h", "--help", "Show this help message") do
      puts opts
      exit
    end
  end

  begin
    parser.parse!
  rescue OptionParser::InvalidOption => e
    puts "Error: #{e.message}"
    puts ""
    puts parser
    exit 1
  end

  if ARGV[0]
    repo_name = DevpodSelector.repo_name_for_workspace(ARGV[0])
    sync_to_devpod(ARGV[0]) || exit(1)
    sync_sessions_to_devpod(ARGV[0], repo_name) if options[:sessions] && repo_name
  else
    workspaces = DevpodSelector.all_running_workspaces

    if workspaces.empty?
      puts "Error: No running DevPod workspaces found. Create one with: devpod-create"
      exit 1
    end

    puts "==> Found #{workspaces.size} running workspace(s): #{workspaces.join(', ')}"
    puts ""

    failed = []
    workspaces.each_with_index do |workspace_name, index|
      puts "=" * 60
      puts "==> [#{index + 1}/#{workspaces.size}] Processing: #{workspace_name}"
      puts "=" * 60
      puts ""

      if sync_to_devpod(workspace_name)
        if options[:sessions]
          repo_name = DevpodSelector.repo_name_for_workspace(workspace_name)
          sync_sessions_to_devpod(workspace_name, repo_name) if repo_name
        end
      else
        failed << workspace_name
      end
      puts ""
    end

    if failed.any?
      puts "Error: Failed to sync to: #{failed.join(', ')}"
      exit 1
    end

    puts "=" * 60
    puts "==> All #{workspaces.size} workspace(s) synced successfully!"
    puts "=" * 60
  end
end

main

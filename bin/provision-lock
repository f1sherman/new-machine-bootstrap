#!/bin/bash

PROVISION_LOCK_OWNED=false
PROVISION_LOCK_OWNER_DIR=""
PROVISION_LOCK_WAIT_STARTED=""

provision_lock_path() {
  printf '%s\n' "${PROVISION_LOCK_DIR:-/tmp/new-machine-bootstrap-provision-$(id -u).lock}"
}

provision_lock_process_start() {
  ps -p "$1" -o lstart= 2>/dev/null | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

provision_lock_process_start_checksum() {
  provision_lock_process_start "$1" | cksum | awk '{ print $1 }'
}

provision_lock_owner_token_is_alive() {
  local owner_dir=$1 token identity pid expected_checksum actual_checksum
  token=$(basename "$owner_dir")
  identity=${token#owner-}
  [[ "$identity" != "$token" ]] || return 1
  pid=${identity%%-*}
  identity=${identity#*-}
  expected_checksum=${identity%%-*}
  [[ "$pid" =~ ^[0-9]+$ && "$expected_checksum" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  actual_checksum=$(provision_lock_process_start_checksum "$pid")
  [[ -n "$actual_checksum" && "$actual_checksum" == "$expected_checksum" ]]
}

provision_lock_current_owner_dir() {
  local lock_dir=$1 owner_dir
  for owner_dir in "$lock_dir"/owner-*; do
    [[ -d "$owner_dir" ]] || continue
    printf '%s\n' "$owner_dir"
    return 0
  done
  return 1
}

provision_lock_owner_value() {
  local key=$1 owner_dir=$2
  [[ -f "$owner_dir/owner" ]] || return 1
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$owner_dir/owner"
}

provision_lock_owner_is_alive() {
  local owner_dir=$1 pid expected_start actual_start
  pid=$(provision_lock_owner_value pid "$owner_dir") || return 1
  [[ "$pid" =~ ^[0-9]+$ ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  expected_start=$(provision_lock_owner_value process_start "$owner_dir") || return 1
  actual_start=$(provision_lock_process_start "$pid")
  [[ -n "$actual_start" && "$actual_start" == "$expected_start" ]]
}

provision_lock_write_owner() {
  local owner_dir=$1
  shift || true
  (
    umask 077
    {
      printf 'pid=%s\n' "$$"
      printf 'process_start=%s\n' "$(provision_lock_process_start "$$")"
      printf 'started_at=%s\n' "$(date -Iseconds)"
      printf 'working_directory=%s\n' "$PWD"
      printf 'command=%s\n' "$0${*:+ }$*"
    } > "$owner_dir/owner"
  )
}

provision_lock_metadata_complete() {
  local owner_dir=$1 pid process_start started_at working_directory command
  pid=$(provision_lock_owner_value pid "$owner_dir") || return 1
  process_start=$(provision_lock_owner_value process_start "$owner_dir") || return 1
  started_at=$(provision_lock_owner_value started_at "$owner_dir") || return 1
  working_directory=$(provision_lock_owner_value working_directory "$owner_dir") || return 1
  command=$(provision_lock_owner_value command "$owner_dir") || return 1
  [[ -n "$pid" && -n "$process_start" && -n "$started_at" && -n "$working_directory" && -n "$command" ]]
}

provision_lock_report_blocked() {
  local owner_dir=$1 prefix=$2 owner_pid working_directory owner_command
  owner_pid=$(provision_lock_owner_value pid "$owner_dir" 2>/dev/null || true)
  working_directory=$(provision_lock_owner_value working_directory "$owner_dir" 2>/dev/null || true)
  owner_command=$(provision_lock_owner_value command "$owner_dir" 2>/dev/null || true)

  echo "$prefix" >&2
  echo "Owner PID: ${owner_pid:-unknown}" >&2
  echo "Working directory: ${working_directory:-unknown}" >&2
  echo "Command: ${owner_command:-unknown}" >&2
}

provision_lock_remove_stale_owner() {
  local lock_dir=$1 owner_dir=$2
  case "$owner_dir" in
    "$lock_dir"/owner-*) ;;
    *) return 1 ;;
  esac
  [[ -d "$owner_dir" ]] || return 1
  rm -f "$owner_dir/owner"
  rmdir "$owner_dir" 2>/dev/null || return 1
  rmdir "$lock_dir" 2>/dev/null || return 1
}

provision_lock_report_wait() {
  local owner_dir=$1 message=$2 now=$3
  provision_lock_report_blocked "$owner_dir" "$message"
  PROVISION_LOCK_LAST_NOTICE=$now
}

provision_lock_acquire() {
  local lock_dir owner_dir owner_token blocked_reported=false incomplete_since="" now elapsed
  lock_dir=$(provision_lock_path)
  PROVISION_LOCK_WAIT_STARTED=""
  PROVISION_LOCK_LAST_NOTICE=0

  while true; do
    if (umask 077 && mkdir "$lock_dir") 2>/dev/null; then
      owner_token="owner-$$-$(provision_lock_process_start_checksum "$$")-$(date +%s)-$RANDOM"
      owner_dir="$lock_dir/$owner_token"
      if ! (umask 077 && mkdir "$owner_dir") 2>/dev/null; then
        rmdir "$lock_dir" 2>/dev/null || true
        sleep 2
        continue
      fi

      PROVISION_LOCK_OWNED=true
      PROVISION_LOCK_OWNER_DIR=$owner_dir
      provision_lock_write_owner "$owner_dir" "$@"
      if [[ -n "$PROVISION_LOCK_WAIT_STARTED" ]]; then
        elapsed=$(($(date +%s) - PROVISION_LOCK_WAIT_STARTED))
        echo "Waited ${elapsed}s for provision lock." >&2
      fi
      return 0
    fi

    now=$(date +%s)
    if [[ -z "$PROVISION_LOCK_WAIT_STARTED" ]]; then
      PROVISION_LOCK_WAIT_STARTED=$now
    fi
    owner_dir=$(provision_lock_current_owner_dir "$lock_dir" 2>/dev/null || true)

    if [[ -n "$owner_dir" ]] && provision_lock_metadata_complete "$owner_dir"; then
      incomplete_since=""
      if provision_lock_owner_is_alive "$owner_dir"; then
        if ! $blocked_reported; then
          provision_lock_report_wait "$owner_dir" "Another provision is running. Waiting for lock: $lock_dir" "$now"
          blocked_reported=true
        elif [[ $((now - PROVISION_LOCK_LAST_NOTICE)) -ge 30 ]]; then
          provision_lock_report_wait "$owner_dir" "Still waiting for provision lock after $((now - PROVISION_LOCK_WAIT_STARTED))s: $lock_dir" "$now"
        fi
        sleep 2
        continue
      fi

      if provision_lock_remove_stale_owner "$lock_dir" "$owner_dir"; then
        continue
      fi
    else
      if [[ -n "$owner_dir" ]] && provision_lock_owner_token_is_alive "$owner_dir"; then
        incomplete_since=""
        if ! $blocked_reported; then
          provision_lock_report_wait "$owner_dir" "Another provision is running. Waiting for lock: $lock_dir" "$now"
          blocked_reported=true
        elif [[ $((now - PROVISION_LOCK_LAST_NOTICE)) -ge 30 ]]; then
          provision_lock_report_wait "$owner_dir" "Still waiting for provision lock after $((now - PROVISION_LOCK_WAIT_STARTED))s: $lock_dir" "$now"
        fi
        sleep 2
        continue
      fi

      if [[ -z "$incomplete_since" ]]; then
        incomplete_since=$now
      fi

      if [[ $((now - incomplete_since)) -lt 5 ]]; then
        if ! $blocked_reported; then
          provision_lock_report_wait "${owner_dir:-$lock_dir}" "Another provision is running. Waiting for lock: $lock_dir" "$now"
          blocked_reported=true
        elif [[ $((now - PROVISION_LOCK_LAST_NOTICE)) -ge 30 ]]; then
          provision_lock_report_wait "${owner_dir:-$lock_dir}" "Still waiting for provision lock after $((now - PROVISION_LOCK_WAIT_STARTED))s: $lock_dir" "$now"
        fi
        sleep 2
        continue
      fi

      if [[ -n "$owner_dir" ]]; then
        provision_lock_remove_stale_owner "$lock_dir" "$owner_dir" || true
      else
        rmdir "$lock_dir" 2>/dev/null || true
      fi
      incomplete_since=""
      continue
    fi

    sleep 2
  done
}

provision_lock_release() {
  local lock_dir owner_pid
  [[ "$PROVISION_LOCK_OWNED" == true ]] || return 0
  [[ -n "$PROVISION_LOCK_OWNER_DIR" ]] || return 0

  lock_dir=$(provision_lock_path)
  owner_pid=$(provision_lock_owner_value pid "$PROVISION_LOCK_OWNER_DIR" 2>/dev/null || true)
  if [[ "$owner_pid" != "$$" ]]; then
    PROVISION_LOCK_OWNED=false
    PROVISION_LOCK_OWNER_DIR=""
    return 0
  fi

  rm -f "$PROVISION_LOCK_OWNER_DIR/owner"
  rmdir "$PROVISION_LOCK_OWNER_DIR" 2>/dev/null || return 1
  rmdir "$lock_dir" 2>/dev/null || return 1
  PROVISION_LOCK_OWNED=false
  PROVISION_LOCK_OWNER_DIR=""
  PROVISION_LOCK_WAIT_STARTED=""
}
